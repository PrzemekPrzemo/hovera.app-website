# Hovera contact form configuration
# Copy this file to .env on the production server (httpdocs/api/.env) and fill in real values.
# Do NOT commit the real .env to git (it's gitignored).

# ─── Recipients ───
HOVERA_MAIL_TO=hello@hovera.app
HOVERA_MAIL_FROM=hello@hovera.app
HOVERA_MAIL_FROM_NAME=Hovera

# ─── SMTP (Google Workspace example) ───
# Generate an App Password at https://myaccount.google.com/apppasswords
# (requires 2-Step Verification on the account first)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=hello@hovera.app
SMTP_PASSWORD=xxxx-xxxx-xxxx-xxxx
SMTP_SECURITY=starttls

# Alternative — SSL on port 465:
# SMTP_PORT=465
# SMTP_SECURITY=ssl

# Other providers:
# SMTP_HOST=smtp.sendgrid.net (port 587, starttls)
# SMTP_HOST=smtp-relay.brevo.com (port 587, starttls)
# SMTP_HOST=smtp.postmarkapp.com (port 587, starttls)

# ─── Notes ───
# - If SMTP_HOST is empty, the script falls back to PHP mail() via local Postfix
# - File should be readable by the PHP process (chmod 640, owned by Plesk user)
# - Restart PHP-FPM after changes if your Plesk caches env vars

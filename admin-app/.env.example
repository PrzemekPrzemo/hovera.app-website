# Hovera admin-app — copy to .env and fill in.
# Never commit .env. Permissions: chmod 600 .env

# Basic Auth for /admin/social/* and /api/admin/*
ADMIN_USER=hovera
ADMIN_PASSWORD=replace-with-a-strong-password

# Claude API (Anthropic)
# Get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Instagram Graph API
# 1. Create FB Developer App: https://developers.facebook.com/apps/
# 2. Add "Instagram Graph API" product
# 3. Convert your IG account to Business and connect a Facebook Page
# 4. Generate a long-lived Page token (60d) — see README_ADMIN.md
IG_ACCESS_TOKEN=EAAB...
IG_BUSINESS_ACCOUNT_ID=
IG_APP_ID=
IG_APP_SECRET=

# Server
PORT=3001
HOST=127.0.0.1
DATA_DIR=./data

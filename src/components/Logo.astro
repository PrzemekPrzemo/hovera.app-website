---
interface Props {
  variant?: 'full' | 'mark';
  class?: string;
  ariaLabel?: string;
}
const { variant = 'full', class: className = '', ariaLabel = 'Hovera' } = Astro.props;
---

{variant === 'full' ? (
  <span class={`hovera-logo inline-flex items-baseline gap-[0.18em] ${className}`} aria-label={ariaLabel}>
    <span class="hovera-wordmark font-medium tracking-[-0.04em] leading-none">hovera</span>
    <svg
      class="hovera-mark"
      viewBox="0 0 24 24"
      fill="none"
      xmlns="http://www.w3.org/2000/svg"
      aria-hidden="true"
      width="0.62em"
      height="0.62em"
      style="transform: translateY(-0.12em);"
    >
      <path
        d="M5 16 C 5 9, 8 5, 12 5 C 16 5, 19 9, 19 16"
        stroke="currentColor"
        stroke-width="3.2"
        stroke-linecap="round"
        fill="none"
      />
      <path
        d="M5 16 C 5 18, 6.5 19, 8 19"
        stroke="currentColor"
        stroke-width="3.2"
        stroke-linecap="round"
        fill="none"
      />
      <path
        d="M19 16 C 19 18, 17.5 19, 16 19"
        stroke="currentColor"
        stroke-width="3.2"
        stroke-linecap="round"
        fill="none"
      />
    </svg>
  </span>
) : (
  <svg
    class={className}
    viewBox="0 0 24 24"
    fill="none"
    xmlns="http://www.w3.org/2000/svg"
    role="img"
    aria-label={ariaLabel}
  >
    <path
      d="M5 16 C 5 9, 8 5, 12 5 C 16 5, 19 9, 19 16"
      stroke="currentColor"
      stroke-width="3"
      stroke-linecap="round"
      fill="none"
    />
    <path
      d="M5 16 C 5 18.5, 6.5 19.5, 8.2 19.5"
      stroke="currentColor"
      stroke-width="3"
      stroke-linecap="round"
      fill="none"
    />
    <path
      d="M19 16 C 19 18.5, 17.5 19.5, 15.8 19.5"
      stroke="currentColor"
      stroke-width="3"
      stroke-linecap="round"
      fill="none"
    />
  </svg>
)}

<style>
  .hovera-wordmark {
    font-size: 1em;
  }
  .hovera-logo {
    color: var(--color-bark);
  }
</style>

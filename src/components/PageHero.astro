---
interface Props {
  eyebrow?: string;
  title: string;
  subtitle?: string;
  align?: 'center' | 'left';
}
const { eyebrow, title, subtitle, align = 'center' } = Astro.props;
---

<section class="page-hero relative overflow-hidden">
  <div aria-hidden="true" class="ph-mesh"></div>
  <div class="container-x relative pt-12 pb-16 md:pt-20 md:pb-20">
    <div class={`max-w-4xl ${align === 'center' ? 'mx-auto text-center' : ''}`} data-reveal>
      {eyebrow && <span class="eyebrow">{eyebrow}</span>}
      <h1 class={`display-2 mt-4 text-balance`}>{title}</h1>
      {subtitle && <p class="lead mt-5 text-balance max-w-2xl mx-auto">{subtitle}</p>}
      <slot />
    </div>
  </div>
</section>

<style>
  .ph-mesh {
    position: absolute;
    inset: -10% -10% auto -10%;
    height: 100%;
    background:
      radial-gradient(circle at 30% 20%, rgba(168,149,107,0.32), transparent 50%),
      radial-gradient(circle at 75% 30%, rgba(232,221,208,0.7), transparent 55%);
    filter: blur(8px);
    z-index: -1;
  }
</style>

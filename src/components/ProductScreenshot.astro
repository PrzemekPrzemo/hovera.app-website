        { item: 'Owies', amount: '50 kg', warn: true, days: '~3 dni' },
        { item: 'Musli low-sugar', amount: '120 kg', warn: false, days: '~9 dni' },
        { item: 'Olej lniany', amount: '4 L', warn: true, days: '~5 dni' },

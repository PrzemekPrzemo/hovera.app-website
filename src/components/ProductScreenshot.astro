        { name: 'Niko', plan: 'musli 2 kg + siano + elektrolity', done: false, current: true },
        { name: 'Riko', plan: 'owies 1.5 kg + siano', done: false },
      ],
      stockTitle: 'Magazyn (najniższe stany)',

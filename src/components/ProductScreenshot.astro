---
type Slug = 'kalendarz' | 'karnety' | 'finanse-ksef' | 'zapisy-online' | 'dziennik-konia' | 'pensjonat' | 'pasza-zywienie';
type Locale = 'pl' | 'en';

interface Props {
  slug: Slug;
  locale: Locale;
}

const { slug, locale } = Astro.props;

const t = {
  pl: {
    urls: {
      kalendarz: 'app.hovera.app/kalendarz',
      karnety: 'app.hovera.app/karnety',
      'finanse-ksef': 'app.hovera.app/faktury',
      'zapisy-online': 'hovera.app/zapisz/stajnia-pod-debem',

  en: {
    urls: {
      kalendarz: 'app.hovera.app/calendar',
      karnety: 'app.hovera.app/passes',
      'finanse-ksef': 'app.hovera.app/invoices',
      'zapisy-online': 'hovera.app/book/stable-under-the-oak',
      'dziennik-konia': 'app.hovera.app/horses/zorza',
      'pensjonat': 'app.hovera.app/boarding/map',
      'pasza-zywienie': 'app.hovera.app/feeding/round',
    },
    cal: { title: 'Calendar · Monday Nov 10', conflict: 'Booking conflict', conflictBody: 'Zorza and Tomek — 2:00 PM. Pick another horse or move the time.', resolve: 'Show free slots', cancel: 'Cancel', monday: 'Mon', dayLabels: ['7:00','8:00','9:00','10:00','11:00','12:00','13:00','14:00','15:00','16:00'] },
    pass: { title: 'Passes · all active', headerName: 'Client', headerType: 'Type', headerLeft: 'Remaining', headerStatus: 'Status', rows: [
      { name: 'Anna Kowalska', type: '10× adults', left: '8/10', pct: 80, status: 'Active' },
      { name: 'Jakub Nowak', type: '4× kids', left: '1/4', pct: 25, status: 'Ending' },
      { name: 'Maria Piotrowska', type: '20× sport', left: '14/20', pct: 70, status: 'Active' },
      { name: 'Tomasz Lis', type: '10× adults', left: '0/10', pct: 0, status: 'Expired' },
    ], cta: 'Sell new pass' },
    inv: { title: 'Invoices · November 2026', kpi1Label: 'Issued', kpi1Value: '47', kpi2Label: 'Paid', kpi2Value: '38', kpi3Label: 'Total', kpi3Value: '€5,580', headers: ['No.','Client','Amount','Status','KSeF'], rows: [
      { num: 'FV/11/041', client: 'A. Kowalska', amount: '€175', status: 'Paid', ksef: 'OK' },
      { num: 'FV/11/042', client: 'J. Nowak', amount: '€72', status: 'Pending', ksef: 'OK' },
      { num: 'FV/11/043', client: 'M. Piotrowska', amount: '€350', status: 'Paid', ksef: 'OK' },
    ] },

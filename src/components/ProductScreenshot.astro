    horse: { name: 'Zorza', meta: 'Klacz · 12 lat · własność stajni', timelineTitle: 'Oś czasu', events: [
      { time: 'dziś 09:00', label: 'Trening · Marta', kind: 'training' },
      { time: 'wczoraj', label: 'Kowal · podkucie przednich', kind: 'farrier' },
      { time: '3 dni temu', label: 'Wizyta wet · szczepienia', kind: 'vet' },
      { time: '5 dni temu', label: 'Pasza zmieniona na musli', kind: 'feed' },
    ] },
    boarding: {
      title: 'Pensjonat · mapa boksów',
      legend: { occupied: 'Zajęty', free: 'Wolny', service: 'Serwis' },
      summaryA: 'Stajnia A · 18 boksów · 16 zajętych',
      summaryB: 'Stajnia B · 12 boksów · 11 zajętych',
      boxes: [
        { id: 1, name: 'Halina', state: 'occupied' },
        { id: 2, name: 'Atos', state: 'occupied' },
        { id: 3, name: '—', state: 'free' },
        { id: 4, name: 'Bonita', state: 'occupied' },
        { id: 5, name: 'Niko', state: 'occupied' },
        { id: 6, name: 'Riko', state: 'occupied' },
        { id: 7, name: 'Misia', state: 'occupied' },
        { id: 8, name: '—', state: 'service' },
        { id: 9, name: 'Lima', state: 'occupied' },
        { id: 10, name: 'Karo', state: 'occupied' },
        { id: 11, name: 'Mocca', state: 'occupied' },
        { id: 12, name: 'Bystry', state: 'occupied' },
      ],
      footer: 'Klik na boks → karta konia, historia przypisań, faktura cykliczna',
    },
    feed: {
      title: 'Karmienie · 6:30 · 24 konie',
      progress: '17 z 24 zrobione',
      rows: [
        { name: 'Halina', plan: 'owies 2 kg + siano + suplement stawów', done: true },
        { name: 'Atos', plan: 'musli 1.5 kg + siano + olej lniany', done: true },

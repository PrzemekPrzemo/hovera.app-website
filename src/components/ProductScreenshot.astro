    horse: { name: 'Zorza', meta: 'Mare · 12 yrs · stable-owned', timelineTitle: 'Timeline', events: [
      { time: 'today 9:00', label: 'Training · Marta', kind: 'training' },
      { time: 'yesterday', label: 'Farrier · front shoes', kind: 'farrier' },
      { time: '3 days ago', label: 'Vet · vaccinations', kind: 'vet' },
      { time: '5 days ago', label: 'Feed switched to muesli', kind: 'feed' },
    ] },
    boarding: {
      title: 'Boarding · box map',
      legend: { occupied: 'Occupied', free: 'Free', service: 'Service' },
      summaryA: 'Stable A · 18 boxes · 16 occupied',
      summaryB: 'Stable B · 12 boxes · 11 occupied',
      boxes: [
        { id: 1, name: 'Halina', state: 'occupied' },
        { id: 2, name: 'Atos', state: 'occupied' },
        { id: 3, name: '—', state: 'free' },
        { id: 4, name: 'Bonita', state: 'occupied' },
        { id: 5, name: 'Niko', state: 'occupied' },
        { id: 6, name: 'Riko', state: 'occupied' },
        { id: 7, name: 'Misia', state: 'occupied' },
        { id: 8, name: '—', state: 'service' },
        { id: 9, name: 'Lima', state: 'occupied' },
        { id: 10, name: 'Karo', state: 'occupied' },
        { id: 11, name: 'Mocca', state: 'occupied' },
        { id: 12, name: 'Bystry', state: 'occupied' },
      ],
      footer: 'Click a box → horse card, assignment history, recurring invoice',
    },
    feed: {
      title: 'Feeding · 6:30 · 24 horses',
      progress: '17 of 24 done',
      rows: [
        { name: 'Halina', plan: 'oats 2 kg + hay + joint supplement', done: true },
        { name: 'Atos', plan: 'muesli 1.5 kg + hay + linseed oil', done: true },
        { name: 'Bonita', plan: 'oats 1.8 kg + hay · LOW SUGAR', done: true },
        { name: 'Niko', plan: 'muesli 2 kg + hay + electrolytes', done: false, current: true },
        { name: 'Riko', plan: 'oats 1.5 kg + hay', done: false },
      ],
      stockTitle: 'Stock (lowest items)',
      stock: [
        { item: 'Oats', amount: '50 kg', warn: true, days: '~3 days' },
        { item: 'Low-sugar muesli', amount: '120 kg', warn: false, days: '~9 days' },
        { item: 'Linseed oil', amount: '4 L', warn: true, days: '~5 days' },
      ],
    },
  },
};

const x = t[locale];
const url = x.urls[slug];
---

<div class="ps-frame" data-reveal>
  <div class="ps-bar">
    <span class="ps-dot ps-dot--r"></span>
    <span class="ps-dot ps-dot--y"></span>
    <span class="ps-dot ps-dot--g"></span>
    <span class="ps-url">{url}</span>
  </div>

  <div class="ps-body">
    {slug === 'kalendarz' && (
      <div class="cal">
        <div class="cal-head"><span class="ps-eyebrow">{x.cal.title}</span></div>
        <div class="cal-grid">
          {x.cal.dayLabels.map((h, i) => (
            <div class={`cal-row ${i === 7 ? 'cal-row--conflict' : ''}`}>
              <span class="cal-time">{h}</span>
              {i === 1 && <span class="cal-evt cal-evt--a">Anna · Zorza</span>}
              {i === 3 && <span class="cal-evt cal-evt--b">Jakub · Bystry</span>}
              {i === 5 && <span class="cal-evt cal-evt--c">Sport grupa</span>}
              {i === 7 && <span class="cal-evt cal-evt--conflict">Tomek · Zorza ⚠</span>}
              {i === 9 && <span class="cal-evt cal-evt--a">Maria · Iskra</span>}
            </div>
          ))}
        </div>
        <div class="cal-modal">
          <span class="cal-modal-title">{x.cal.conflict}</span>
          <p class="cal-modal-body">{x.cal.conflictBody}</p>
          <div class="cal-modal-actions">
            <button class="ps-btn ps-btn--ghost">{x.cal.cancel}</button>
            <button class="ps-btn ps-btn--primary">{x.cal.resolve}</button>
          </div>
        </div>
      </div>
    )}

    {slug === 'karnety' && (
      <div class="pass">
        <div class="pass-head">
          <span class="ps-eyebrow">{x.pass.title}</span>
          <button class="ps-btn ps-btn--primary">{x.pass.cta}</button>
        </div>
        <table class="pass-table">
          <thead>
            <tr>
              <th>{x.pass.headerName}</th>
              <th>{x.pass.headerType}</th>
              <th>{x.pass.headerLeft}</th>
              <th>{x.pass.headerStatus}</th>
            </tr>
          </thead>
          <tbody>
            {x.pass.rows.map((r) => (
              <tr>
                <td>{r.name}</td>
                <td class="muted-cell">{r.type}</td>
                <td><span class="pass-bar"><span class="pass-bar-fill" style={`width:${r.pct}%`}></span></span><span class="pass-num">{r.left}</span></td>
                <td><span class={`status status--${r.status === 'Aktywny' || r.status === 'Active' ? 'ok' : r.status === 'Wygasł' || r.status === 'Expired' ? 'err' : 'warn'}`}>{r.status}</span></td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    )}

    {slug === 'finanse-ksef' && (
      <div class="inv">
        <div class="inv-head">
          <span class="ps-eyebrow">{x.inv.title}</span>
          <span class="ksef-chip">KSeF · live</span>
        </div>
        <div class="inv-kpis">
          <div class="kpi"><span class="kpi-num">{x.inv.kpi1Value}</span><span class="kpi-label">{x.inv.kpi1Label}</span></div>
          <div class="kpi"><span class="kpi-num">{x.inv.kpi2Value}</span><span class="kpi-label">{x.inv.kpi2Label}</span></div>
          <div class="kpi"><span class="kpi-num">{x.inv.kpi3Value}</span><span class="kpi-label">{x.inv.kpi3Label}</span></div>
        </div>
        <table class="inv-table">
          <thead><tr>{x.inv.headers.map((h) => <th>{h}</th>)}</tr></thead>
          <tbody>
            {x.inv.rows.map((r) => (
              <tr>
                <td class="mono">{r.num}</td>
                <td>{r.client}</td>
                <td class="mono">{r.amount}</td>
                <td><span class={`status status--${r.status === 'Opłacona' || r.status === 'Paid' ? 'ok' : 'warn'}`}>{r.status}</span></td>
                <td><span class="ksef-ok">{r.ksef}</span></td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    )}

    {slug === 'zapisy-online' && (
      <div class="book">
        <div class="book-card">
          <span class="book-stable">{x.book.stable}</span>
          <p class="book-sub">{x.book.subtitle}</p>
          <div class="book-row"><span class="book-key">📅</span><span>{x.book.when}</span></div>
          <div class="book-row"><span class="book-key">🐎</span><span>{x.book.horse}</span></div>
          <div class="book-row"><span class="book-key">👤</span><span>{x.book.instructor}</span></div>
          <div class="book-price">{x.book.price}</div>
          <button class="ps-btn ps-btn--primary book-pay">{x.book.payBtn}</button>
          <p class="book-hint">{x.book.payHint}</p>
          <div class="book-blik"><span></span><span></span><span></span><span></span><span></span><span></span></div>
          <div class="book-success">{x.book.success}</div>
        </div>
      </div>
    )}

    {slug === 'dziennik-konia' && (
      <div class="horse">
        <div class="horse-head">
          <div class="horse-avatar">Z</div>
          <div>
            <h3 class="horse-name">{x.horse.name}</h3>
            <p class="horse-meta">{x.horse.meta}</p>
          </div>
        </div>
        <div class="horse-timeline">
          <span class="ps-eyebrow">{x.horse.timelineTitle}</span>
          <ul>
            {x.horse.events.map((e) => (
              <li class={`hev hev--${e.kind}`}>
                <span class="hev-dot"></span>
                <span class="hev-time">{e.time}</span>
                <span class="hev-label">{e.label}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    )}

    {slug === 'pensjonat' && (
      <div class="brd">
        <div class="brd-head">
          <span class="ps-eyebrow">{x.boarding.title}</span>
          <span class="brd-legend">
            <span class="brd-leg-item"><span class="brd-leg brd-leg--occ"></span>{x.boarding.legend.occupied}</span>
            <span class="brd-leg-item"><span class="brd-leg brd-leg--free"></span>{x.boarding.legend.free}</span>
            <span class="brd-leg-item"><span class="brd-leg brd-leg--svc"></span>{x.boarding.legend.service}</span>
          </span>
        </div>
        <div class="brd-summary">{x.boarding.summaryA}</div>
        <div class="brd-grid">
          {x.boarding.boxes.map((b: { id: number; name: string; state: string }) => (
            <div class={`brd-box brd-box--${b.state}`}>
              <span class="brd-box-id">#{b.id}</span>
              <span class="brd-box-name">{b.name}</span>
            </div>
          ))}
        </div>
        <div class="brd-summary brd-summary--b">{x.boarding.summaryB}</div>
        <p class="brd-footer">{x.boarding.footer}</p>
      </div>
    )}

    {slug === 'pasza-zywienie' && (
      <div class="fd">
        <div class="fd-head">
          <span class="ps-eyebrow">{x.feed.title}</span>
          <span class="status status--ok">{x.feed.progress}</span>
        </div>
        <ul class="fd-list">
          {x.feed.rows.map((r: { name: string; plan: string; done: boolean; current?: boolean }) => (
            <li class={`fd-row ${r.done ? 'is-done' : ''} ${r.current ? 'is-current' : ''}`}>
              <span class={`fd-check ${r.done ? 'is-checked' : ''}`}>
                {r.done && <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M2.5 6.5l2.5 2.5L9.5 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>}
              </span>
              <span class="fd-name">{r.name}</span>
              <span class="fd-plan muted-cell">{r.plan}</span>
            </li>
          ))}
        </ul>

        <div class="fd-stock">
          <span class="ps-eyebrow">{x.feed.stockTitle}</span>
          <ul class="fd-stock-list">
            {x.feed.stock.map((s: { item: string; amount: string; warn: boolean; days: string }) => (
              <li class={`fd-stock-row ${s.warn ? 'is-warn' : ''}`}>
                <span class="fd-stock-name">{s.item}</span>
                <span class="fd-stock-amount mono">{s.amount}</span>
                <span class={`status ${s.warn ? 'status--warn' : 'status--ok'}`}>{s.days}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    )}
  </div>
</div>

<style>
  .ps-frame {
    max-width: 56rem;
    margin: 0 auto;
    background: var(--color-bark);
    border-radius: 18px;
    padding: 0.6rem;
    box-shadow: 0 24px 60px -16px rgba(61,46,34,0.35);
    overflow: hidden;
  }
  .ps-bar { display: flex; align-items: center; gap: 0.5rem; padding: 0.4rem 0.6rem 0.7rem; }
  .ps-dot { width: 11px; height: 11px; border-radius: 999px; }
  .ps-dot--r { background: #E2725B; }
  .ps-dot--y { background: var(--color-ochre); }
  .ps-dot--g { background: #6B8E5A; }
  .ps-url {
    margin-left: 0.6rem;
    font-size: 0.78rem;
    color: var(--color-cream);
    opacity: 0.78;
    background: rgba(250,248,244,0.07);
    padding: 0.25rem 0.7rem;
    border-radius: 999px;
    font-family: ui-monospace, SFMono-Regular, monospace;
  }
  .ps-body {
    background: var(--color-cream);
    border-radius: 12px;
    padding: 1.5rem;
    min-height: 380px;
    position: relative;
    overflow: hidden;
  }
  .ps-eyebrow { font-size: 0.72rem; letter-spacing: 0.08em; text-transform: uppercase; color: var(--color-fg-muted); }
  .ps-btn { padding: 0.55rem 0.95rem; border-radius: 10px; font-size: 0.85rem; font-weight: 500; border: none; cursor: pointer; transition: opacity 0.2s; }
  .ps-btn--primary { background: var(--color-bark); color: var(--color-cream); }
  .ps-btn--ghost { background: transparent; color: var(--color-fg-muted); border: 1px solid var(--color-border); }
  .ps-btn:hover { opacity: 0.9; }
  .muted-cell { color: var(--color-fg-muted); font-size: 0.88rem; }
  .mono { font-family: ui-monospace, SFMono-Regular, monospace; font-size: 0.85rem; }

  .status { display: inline-block; padding: 0.18rem 0.6rem; border-radius: 999px; font-size: 0.72rem; font-weight: 500; }
  .status--ok { background: #DCEAD0; color: #3D5C2C; }
  .status--warn { background: #F7E5C5; color: #6B4E18; }
  .status--err { background: #F4D7CF; color: #7A2E1A; }

  /* CALENDAR */
  .cal { position: relative; }
  .cal-head { margin-bottom: 0.8rem; }
  .cal-grid { display: flex; flex-direction: column; gap: 4px; }
  .cal-row { display: flex; align-items: center; gap: 0.6rem; padding: 0.45rem 0.6rem; border-radius: 8px; background: rgba(232,221,208,0.35); min-height: 32px; }
  .cal-time { font-size: 0.75rem; color: var(--color-fg-muted); width: 48px; font-family: ui-monospace, monospace; }
  .cal-evt { font-size: 0.8rem; padding: 0.18rem 0.55rem; border-radius: 6px; }
  .cal-evt--a { background: var(--color-ochre); color: var(--color-cream); }
  .cal-evt--b { background: #C8B79A; color: var(--color-bark); }
  .cal-evt--c { background: #B8A87B; color: var(--color-cream); }
  .cal-evt--conflict { background: #E2725B; color: white; animation: pulse-warn 2s ease-in-out infinite; }
  @keyframes pulse-warn { 0%,100% { opacity: 1; } 50% { opacity: 0.7; } }
  .cal-row--conflict { background: rgba(226,114,91,0.12); }
  .cal-modal {
    position: absolute;
    right: 1rem;
    top: 35%;
    width: 220px;
    padding: 1rem;
    background: var(--color-cream);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    box-shadow: 0 16px 30px -8px rgba(61,46,34,0.3);
    animation: modal-in 0.6s 0.4s both var(--ease-out-expo);
  }
  @keyframes modal-in { from { transform: translateY(8px) scale(0.96); opacity: 0; } to { transform: translateY(0) scale(1); opacity: 1; } }
  .cal-modal-title { font-weight: 600; font-size: 0.9rem; }
  .cal-modal-body { font-size: 0.78rem; color: var(--color-fg-muted); margin-top: 0.4rem; line-height: 1.45; }
  .cal-modal-actions { display: flex; gap: 0.5rem; margin-top: 0.8rem; }

  .cal-cell.is-free::before { content: ""; display: block; position: absolute; inset: 4px; background: rgba(111,182,122,0.5); border: 1.5px solid #6FB67A; border-radius: 3px; animation: cellPulse 1.2s ease-in-out infinite; }

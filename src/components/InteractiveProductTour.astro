---
import { type Locale } from '../i18n/utils';
interface Props { locale: Locale; }
const { locale } = Astro.props;
const t = (pl: string, en: string) => (locale === 'pl' ? pl : en);

type Scene = {
  id: string;
  url: string;
  active: 'dashboard' | 'calendar' | 'clients' | 'horses' | 'passes' | 'invoices' | 'reports';
  eyebrow: string;
  caption: string;
  visual: 'dashboard' | 'calendar' | 'conflict' | 'checkout' | 'pass' | 'invoices' | 'owner' | 'vet' | 'report';
};

const scenes: Scene[] = locale === 'pl' ? [
  { id: 'dashboard', url: 'app.hovera.app/dashboard',     active: 'dashboard', eyebrow: '07:00 · Poranek',                    caption: 'Otwierasz Hoverę. Widzisz dziś 18 jazd, 2 odwołania, 1 nowy klient. Wszystko w jednym ekranie — bez logowania do trzech systemów.', visual: 'dashboard' },
  { id: 'calendar',  url: 'app.hovera.app/kalendarz',     active: 'calendar',  eyebrow: '08:30 · Telefon',                     caption: 'Klient pyta o piątek 17:00. System pokazuje wolne sloty pasujące do jej poziomu. Bookingujesz w 5 sekund — nie trzeba sprawdzać 3 zeszytów.', visual: 'calendar' },
  { id: 'conflict',  url: 'app.hovera.app/kalendarz',     active: 'calendar',  eyebrow: '10:15 · Wykryty konflikt',             caption: 'Próbujesz dać Halince drugą jazdę o 11:00 — system blokuje, koń już zajęty. Zero pomyłek, zero "ojej, znowu".', visual: 'conflict' },
  { id: 'checkout',  url: 'stajnia-halicz.hovera.app',    active: 'clients',   eyebrow: '12:00 · Klient kupuje online',         caption: 'Anna wchodzi na publiczną stronę Twojej stajni. Wybiera karnet, płaci BLIKiem, dostaje fakturę. Zero Twojego udziału.', visual: 'checkout' },
  { id: 'pass',      url: 'app.hovera.app/karnety',       active: 'passes',    eyebrow: '14:00 · Karnet rozlicza się',          caption: 'Po jeździe karnet sam ubywa o 1. Anna widzi swoje saldo w portalu klienta. Bez SMS-a "ile mi zostało?".', visual: 'pass' },
  { id: 'invoices',  url: 'app.hovera.app/faktury',       active: 'invoices',  eyebrow: '16:30 · Faktury cykliczne',            caption: 'Pensjonat: 30 faktur 1. dnia miesiąca. Każda do KSeF, każda do biura rachunkowego. Twój udział: 0 minut.', visual: 'invoices' },
  { id: 'owner',     url: 'app.hovera.app — portal klienta', active: 'horses',  eyebrow: '18:00 · Właściciel sprawdza konia',    caption: 'Marek loguje się z telefonu. Widzi: dziś jazda 16:00, wczoraj kowal, przedwczoraj weterynarz. Bez SMS-a do Ciebie.', visual: 'owner' },
  { id: 'vet',       url: 'app.hovera.app/konie/halina',  active: 'horses',    eyebrow: '19:30 · Weterynarz online',            caption: 'Halinka kuleje. Wysyłasz dr Nowakowi link do pełnego dziennika konia. 247 wpisów chronologicznie — bez paczek PDF.', visual: 'vet' },
  { id: 'report',    url: 'app.hovera.app/raporty',       active: 'reports',   eyebrow: '21:00 · Koniec dnia',                  caption: 'Hovera pokazuje raport: 18 jazd, 2 400 zł, 1 koń przeciążony. Idziesz spać spokojna. Klienci zarezerwują jutrzejsze jazdy sami.', visual: 'report' },
] : [
  { id: 'dashboard', url: 'app.hovera.app/dashboard',     active: 'dashboard', eyebrow: '7:00 · Morning',           caption: 'You open Hovera. Today: 18 rides, 2 cancellations, 1 new client. All in one screen — no logging into three systems.',             visual: 'dashboard' },
  { id: 'calendar',  url: 'app.hovera.app/calendar',      active: 'calendar',  eyebrow: '8:30 · Phone rings',       caption: 'Client asks about Friday 5pm. System shows free slots matching her level. You book in 5 seconds — no checking 3 notebooks.', visual: 'calendar' },
  { id: 'conflict',  url: 'app.hovera.app/calendar',      active: 'calendar',  eyebrow: '10:15 · Conflict caught',  caption: "You try to give Halina a second ride at 11am — system blocks it, horse is already busy. Zero mistakes, zero 'oh no, again'.", visual: 'conflict' },
  { id: 'checkout',  url: 'halicz-stables.hovera.app',    active: 'clients',   eyebrow: '12:00 · Client buys online', caption: 'Anna lands on your stable\'s public page. Picks a pass, pays instantly, gets an invoice. Zero input from you.',             visual: 'checkout' },
  { id: 'pass',      url: 'app.hovera.app/passes',        active: 'passes',    eyebrow: '14:00 · Pass settles itself', caption: "After the ride the pass auto-deducts. Anna sees her balance in the client portal. No SMS asking 'how many left?'.",        visual: 'pass' },
  { id: 'invoices',  url: 'app.hovera.app/invoices',      active: 'invoices',  eyebrow: '16:30 · Recurring invoices', caption: 'Boarding: 30 invoices on the 1st, each to e-invoicing, each to the accountant. Your time: 0 minutes.',                       visual: 'invoices' },
  { id: 'owner',     url: 'app.hovera.app — owner portal', active: 'horses',   eyebrow: '18:00 · Owner checks horse', caption: "Marek logs in from his phone. Sees: today's ride at 4pm, farrier yesterday, vet the day before. No SMS to you.",          visual: 'owner' },
  { id: 'vet',       url: 'app.hovera.app/horses/halina', active: 'horses',    eyebrow: '19:30 · Vet online',         caption: 'Halina is lame. You send Dr Nowak a link to the full horse journal. 247 entries chronologically — no PDF packs.',            visual: 'vet' },
  { id: 'report',    url: 'app.hovera.app/reports',       active: 'reports',   eyebrow: '21:00 · End of day',         caption: 'Hovera shows the report: 18 rides, €600, 1 overworked horse. You sleep easy. Clients book tomorrow themselves.',         visual: 'report' },
];

const navLabels = locale === 'pl'
  ? { dashboard: 'Dashboard', calendar: 'Kalendarz', clients: 'Klienci', horses: 'Konie', passes: 'Karnety', invoices: 'Faktury', reports: 'Raporty' }
  : { dashboard: 'Dashboard', calendar: 'Calendar', clients: 'Clients', horses: 'Horses', passes: 'Passes', invoices: 'Invoices', reports: 'Reports' };
---

<div class="ipt" data-ipt data-total={scenes.length}>
  <!-- Header bar: progress + controls -->
  <div class="ipt-header">
    <div class="ipt-progress">
      <div class="ipt-progress-bar" data-progress-bar></div>
    </div>
    <div class="ipt-controls">
      <button type="button" class="ipt-btn" data-prev aria-label={t('Poprzednia', 'Previous')}>
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M9 11l-4-4 4-4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </button>
      <button type="button" class="ipt-btn ipt-btn-play" data-play aria-label={t('Pauza', 'Pause')}>
        <svg class="play-icon" width="14" height="14" viewBox="0 0 14 14" fill="currentColor" style="display:none;"><path d="M3 2l8 5-8 5V2z"/></svg>
        <svg class="pause-icon" width="14" height="14" viewBox="0 0 14 14" fill="currentColor"><path d="M4 2h2v10H4zM8 2h2v10H8z"/></svg>
      </button>
      <button type="button" class="ipt-btn" data-next aria-label={t('Następna', 'Next')}>
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M5 11l4-4-4-4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </button>
      <span class="ipt-counter">
        <span data-current>1</span>
        <span class="muted">/ {scenes.length}</span>
      </span>
    </div>
  </div>

  <!-- Stage with browser frame -->
  <div class="ipt-stage">
    {scenes.map((scene, i) => (
      <article
        class={`ipt-scene ${i === 0 ? 'is-active' : ''}`}
        data-scene
        data-index={i}
      >
        <!-- Browser chrome -->
        <div class="browser">
          <div class="browser-bar">
            <div class="browser-dots"><span></span><span></span><span></span></div>
            <div class="browser-url">
              <svg width="11" height="11" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.4">
                <rect x="2" y="5" width="8" height="6" rx="1"/>
                <path d="M4 5V3.5a2 2 0 014 0V5"/>
              </svg>
              <span>{scene.url}</span>
            </div>
          </div>

          <!-- App shell: sidebar + main -->
          {scene.visual === 'owner' || scene.visual === 'checkout' ? (
            <!-- Special layouts (no full app shell) -->
            <div class="app-special">
              {scene.visual === 'checkout' && (
                <div class="checkout-page">
                  <div class="checkout-header">
                    <div class="checkout-stable-name">Stajnia Halicz</div>
                    <div class="checkout-stable-meta">{t('Karnety · Booking online · Konie szkółkowe', 'Passes · Online booking · School horses')}</div>
                  </div>
                  <div class="checkout-products">
                    <div class="checkout-product checkout-product-active">
                      <div class="checkout-product-info">
                        <div class="checkout-product-name">{t('Karnet 12 jazd', '12-ride pass')}</div>
                        <div class="checkout-product-desc muted">{t('Ważny 3 miesiące · Wszystkie konie szkółkowe', 'Valid 3 months · All school horses')}</div>
                      </div>
                      <div class="checkout-product-price">580 zł</div>
                    </div>
                    <div class="checkout-product">
                      <div class="checkout-product-info">
                        <div class="checkout-product-name">{t('Karnet 4 jazdy', '4-ride pass')}</div>
                        <div class="checkout-product-desc muted">{t('Ważny 30 dni', 'Valid 30 days')}</div>
                      </div>
                      <div class="checkout-product-price">220 zł</div>
                    </div>
                  </div>
                  <div class="checkout-payment">
                    <div class="checkout-blik-row">
                      <div class="checkout-blik-badge">BLIK</div>
                      <div class="checkout-blik-code">2<span>5</span>3<span>0</span>9<span>7</span></div>
                    </div>
                    <div class="checkout-success-banner">
                      <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="7" fill="#6FB67A"/><path d="M5 8l2 2 4-4" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                      <div>
                        <div><strong>{t('Płatność potwierdzona', 'Payment confirmed')}</strong></div>
                        <div class="text-xs muted">{t('Faktura wysłana na anna@example.com', 'Invoice sent to anna@example.com')}</div>
                      </div>
                    </div>
                  </div>
                </div>
              )}

              {scene.visual === 'owner' && (
                <div class="owner-portal">
                  <div class="owner-phone-frame">
                    <div class="owner-phone-screen">
                      <div class="owner-phone-status">
                        <span>9:41</span>
                        <span>📶 100%</span>
                      </div>
                      <div class="owner-portal-greeting">
                        <div class="owner-portal-hi">{t('Cześć Marek', 'Hi Marek')} 👋</div>
                        <div class="owner-portal-sub muted">{t('Twoja Halinka czeka na zalogowanie', 'Your Halinka is waiting')}</div>
                      </div>
                      <div class="owner-horse-card">
                        <div class="owner-horse-avatar">H</div>
                        <div class="owner-horse-info">
                          <div class="owner-horse-name">Halinka</div>
                          <div class="owner-horse-status muted">{t('KWPN · 7 lat · Pensjonat boks #4', 'KWPN · 7 years · Boarding box #4')}</div>
                        </div>
                        <div class="owner-horse-pulse">
                          <span class="owner-pulse-dot"></span>
                        </div>
                      </div>

                      <div class="owner-section-title">{t('Dziś', 'Today')}</div>
                      <div class="owner-event">
                        <span class="owner-event-time">16:00</span>
                        <div class="owner-event-content">
                          <div class="owner-event-name">{t('Jazda — Anna K.', 'Ride — Anna K.')}</div>
                          <div class="owner-event-meta muted">{t('Hala kryta · 60 min', 'Indoor · 60 min')}</div>
                        </div>
                        <span class="owner-event-dot d-train"></span>
                      </div>

                      <div class="owner-section-title">{t('Wczoraj', 'Yesterday')}</div>
                      <div class="owner-event">
                        <span class="owner-event-time">13:00</span>
                        <div class="owner-event-content">
                          <div class="owner-event-name">{t('Kowal — pełne podk.', 'Farrier — full set')}</div>
                          <div class="owner-event-meta muted">{t('Jan Kowalski · 280 zł', 'Jan Kowalski · €65')}</div>
                        </div>
                        <span class="owner-event-dot d-shoe"></span>
                      </div>

                      <div class="owner-section-title">{t('Przedwczoraj', '2 days ago')}</div>
                      <div class="owner-event">
                        <span class="owner-event-time">09:30</span>
                        <div class="owner-event-content">
                          <div class="owner-event-name">{t('Wet — szczepienie', 'Vet — vaccination')}</div>
                          <div class="owner-event-meta muted">{t('dr Nowak · grypa+tężec', 'Dr Nowak · flu+tetanus')}</div>
                        </div>
                        <span class="owner-event-dot d-vet"></span>
                      </div>
                    </div>
                  </div>
                </div>
              )}
            </div>
          ) : (
            <!-- Standard app shell -->
            <div class="app-shell">
              <!-- Sidebar -->
              <aside class="app-sidebar">
                <div class="app-brand">
                  <span class="app-brand-mark">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round">
                      <path d="M5 16 C 5 9, 8 5, 12 5 C 16 5, 19 9, 19 16"/>
                      <path d="M5 16 C 5 18.5, 6.5 19.5, 8 19.5"/>
                      <path d="M19 16 C 19 18.5, 17.5 19.5, 16 19.5"/>
                    </svg>
                  </span>
                  <span class="app-brand-name">hovera</span>
                </div>
                <nav class="app-nav">
                  <a class={`app-nav-item ${scene.active === 'dashboard' ? 'is-active' : ''}`}>
                    <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.6"><rect x="2" y="2" width="4" height="4" rx="1"/><rect x="8" y="2" width="4" height="4" rx="1"/><rect x="2" y="8" width="4" height="4" rx="1"/><rect x="8" y="8" width="4" height="4" rx="1"/></svg>
                    {navLabels.dashboard}
                  </a>
                  <a class={`app-nav-item ${scene.active === 'calendar' ? 'is-active' : ''}`}>
                    <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.6"><rect x="2" y="3" width="10" height="9" rx="1"/><path d="M2 5h10M5 2v2M9 2v2"/></svg>
                    {navLabels.calendar}
                  </a>
                  <a class={`app-nav-item ${scene.active === 'clients' ? 'is-active' : ''}`}>
                    <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.6"><circle cx="7" cy="5" r="2.2"/><path d="M3 12c0-2.5 1.8-4 4-4s4 1.5 4 4"/></svg>
                    {navLabels.clients}
                  </a>
                  <a class={`app-nav-item ${scene.active === 'horses' ? 'is-active' : ''}`}>
                    <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M3 11V8c0-2 1.5-4 4-4s4 2 4 4v3M5 11v-2M9 11v-2"/></svg>
                    {navLabels.horses}
                  </a>
                  <a class={`app-nav-item ${scene.active === 'passes' ? 'is-active' : ''}`}>
                    <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.6"><rect x="2" y="3" width="10" height="8" rx="1"/><path d="M2 6h10"/></svg>
                    {navLabels.passes}
                  </a>
                  <a class={`app-nav-item ${scene.active === 'invoices' ? 'is-active' : ''}`}>
                    <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M3 1.5h6l3 3v8a1 1 0 01-1 1H3a1 1 0 01-1-1v-10a1 1 0 011-1zM5 7h4M5 9h4"/></svg>
                    {navLabels.invoices}
                  </a>
                  <a class={`app-nav-item ${scene.active === 'reports' ? 'is-active' : ''}`}>
                    <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M2 12h10M4 12V8M7 12V5M10 12V9"/></svg>
                    {navLabels.reports}
                  </a>
                </nav>
                <div class="app-user">
                  <div class="app-user-avatar">A</div>
                  <div class="app-user-info">
                    <div class="app-user-name">Anna</div>
                    <div class="app-user-role muted">Stajnia Halicz</div>
                  </div>
                </div>
              </aside>

              <!-- Main content area -->
              <main class="app-main">
                <header class="app-topbar">
                  <div class="app-search">
                    <svg width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.6"><circle cx="5" cy="5" r="3"/><path d="M7.5 7.5L10 10"/></svg>
                    <span class="muted">{t('Szukaj klienta, konia, faktury...', 'Search client, horse, invoice...')}</span>
                  </div>
                  <div class="app-topbar-actions">
                    <span class="app-bell">
                      <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M11 9.5c-.5-.5-1-1.5-1-3 0-2-1-3.5-3-3.5s-3 1.5-3 3.5c0 1.5-.5 2.5-1 3M3 9.5h8M5.5 11.5a1.5 1.5 0 003 0"/></svg>
                      <span class="app-bell-dot"></span>
                    </span>
                  </div>
                </header>

                <div class="app-content">
                  {/* SCENE 1: Dashboard */}
                  {scene.visual === 'dashboard' && (
                    <div class="dash">
                      <div class="dash-greet">
                        <div class="dash-greet-text">{t('Cześć, Anna 👋', 'Hi, Anna 👋')}</div>
                        <div class="dash-greet-sub muted">{t('06.05.2026 · 18 jazd · 2 odwołania', '6 May 2026 · 18 rides · 2 cancellations')}</div>
                      </div>
                      <div class="dash-grid">
                        <div class="dash-card" style="--d: 0s">
                          <div class="dash-card-label muted">{t('Jazdy dziś', 'Rides today')}</div>
                          <div class="dash-card-num" data-count="18">0</div>
                          <div class="dash-card-foot text-green">↑ 12% {t('vs śr. tygodnia', 'vs week avg')}</div>
                        </div>
                        <div class="dash-card" style="--d: 0.15s">
                          <div class="dash-card-label muted">{t('Aktywne karnety', 'Active passes')}</div>
                          <div class="dash-card-num" data-count="84">0</div>
                          <div class="dash-card-foot muted">{t('12 kończy się w tym tyg.', '12 expire this week')}</div>
                        </div>
                        <div class="dash-card" style="--d: 0.3s">
                          <div class="dash-card-label muted">{t('Obrót dzisiejszy', 'Today revenue')}</div>
                          <div class="dash-card-num">2&nbsp;400 <span class="text-base">zł</span></div>
                          <div class="dash-card-foot text-green">↑ 8% {t('vs wczoraj', 'vs yesterday')}</div>
                        </div>
                        <div class="dash-card" style="--d: 0.45s">
                          <div class="dash-card-label muted">{t('Nowy klient', 'New client')}</div>
                          <div class="dash-card-num">+1</div>
                          <div class="dash-card-foot muted">Marta K. · {t('zapisała się', 'signed up')}</div>
                        </div>
                      </div>

                      <div class="dash-section">
                        <div class="dash-section-head">
                          <h3>{t('Najbliższe jazdy', 'Upcoming rides')}</h3>
                          <span class="muted text-xs">{t('następne 3h', 'next 3h')}</span>
                        </div>
                        <div class="dash-list">
                          <div class="dash-row">
                            <span class="dash-row-time">16:00</span>
                            <span class="dash-row-name">Anna K.</span>
                            <span class="dash-row-horse">Halina</span>
                            <span class="dash-row-instr muted">{t('inst. Marek', 'Marek')}</span>
                          </div>
                          <div class="dash-row">
                            <span class="dash-row-time">17:00</span>
                            <span class="dash-row-name">Karolina W.</span>
                            <span class="dash-row-horse">Bonita</span>
                            <span class="dash-row-instr muted">{t('inst. Anna', 'Anna')}</span>
                          </div>
                          <div class="dash-row">
                            <span class="dash-row-time">17:30</span>
                            <span class="dash-row-name">Tomek P.</span>
                            <span class="dash-row-horse">Atos</span>
                            <span class="dash-row-instr muted">{t('inst. Marek', 'Marek')}</span>
                          </div>
                        </div>
                      </div>
                    </div>
                  )}

                  {/* SCENE 2: Calendar */}
                  {scene.visual === 'calendar' && (
                    <div class="cal">
                      <div class="cal-toolbar">
                        <div class="cal-toolbar-left">
                          <span class="cal-week">{t('Tydzień 5–11 maja 2026', 'Week 5–11 May 2026')}</span>
                          <span class="cal-call-pulse">📞 {t('Klient czeka na termin', 'Client on the line')}</span>
                        </div>
                        <div class="cal-toolbar-right">
                          <span class="cal-pill">{t('Tydzień', 'Week')}</span>
                          <span class="cal-pill is-active">{t('Dziś', 'Today')}</span>
                        </div>
                      </div>
                      <div class="cal-table">
                        <div class="cal-head-row">
                          <span></span>
                          {['Pn 5','Wt 6','Śr 7','Cz 8','Pt 9','Sb 10','Nd 11'].map((d) => <span class="cal-head-cell">{d}</span>)}
                        </div>
                        {[16,17,18,19].map((hour) => (
                          <div class="cal-time-row">
                            <span class="cal-time">{hour}:00</span>
                            {[0,1,2,3,4,5,6].map((day) => {
                              const free = (day === 4 && hour === 17);
                              const busy = (day + hour) % 3 === 0;
                              return (
                                <span class={`cal-cell ${free ? 'is-free' : ''} ${busy ? 'is-busy' : ''}`}>
                                  {busy && <span class="cal-cell-event">·</span>}
                                  {free && <span class="cal-cell-free">✓ {t('wolne', 'free')}</span>}
                                </span>
                              );
                            })}
                          </div>
                        ))}
                      </div>
                      <div class="cal-suggestion">
                        💡 {t('Pasuje: Pt 9 maja, 17:00 — Halina z instruktorem Markiem', 'Match: Fri 9 May, 5pm — Halina with instructor Marek')}
                      </div>
                    </div>
                  )}

                  {/* SCENE 3: Conflict */}
                  {scene.visual === 'conflict' && (
                    <div class="conf-scene">
                      <div class="cal-toolbar">
                        <span class="cal-week">{t('Środa 7 maja 2026', 'Wednesday 7 May 2026')}</span>
                      </div>
                      <div class="conf-grid">
                        <div class="conf-row">
                          <span class="conf-time">10:00</span>
                          <div class="conf-event conf-existing">
                            <div><strong>Halina</strong> · Anna K.</div>

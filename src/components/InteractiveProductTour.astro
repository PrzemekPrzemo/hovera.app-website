  .app-bell-dot { position: absolute; top: -2px; right: -2px; width: 8px; height: 8px; border-radius: 999px; background: #B14848; border: 2px solid white; }

  .app-content { flex: 1; padding: 18px; overflow: auto; }

  /* ─────── DASHBOARD ─────── */
  .dash-greet { margin-bottom: 16px; }
  .dash-greet-text { font-size: 1.4rem; font-weight: 500; letter-spacing: -0.02em; }
  .dash-greet-sub { font-size: 12px; margin-top: 2px; }
  .dash-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; }
  @media (max-width: 800px) { .dash-grid { grid-template-columns: repeat(2, 1fr); } }
  .dash-card {
    padding: 14px; background: var(--color-sand-light);
    border: 1px solid var(--color-border); border-radius: 10px;
    animation: fadeUp 0.5s var(--ease-out-expo) var(--d) backwards;
  }
  @keyframes fadeUp { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: translateY(0); } }
  .dash-card-label { font-size: 11px; }
  .dash-card-num { font-size: 1.6rem; font-weight: 500; letter-spacing: -0.04em; line-height: 1.1; margin-top: 4px; }
  .dash-card-foot { font-size: 11px; margin-top: 4px; }

  .dash-section { margin-top: 18px; background: var(--color-cream); border: 1px solid var(--color-border); border-radius: 10px; overflow: hidden; }
  .dash-section-head { display: flex; justify-content: space-between; align-items: center; padding: 12px 14px; border-bottom: 1px solid var(--color-border); }
  .dash-section h3 { font-size: 13px; font-weight: 500; }
  .dash-list { display: flex; flex-direction: column; }
  .dash-row { display: grid; grid-template-columns: 60px 1fr 1fr 1fr; gap: 12px; padding: 8px 14px; font-size: 12px; border-bottom: 1px solid var(--color-border); }
  .dash-row:last-child { border-bottom: none; }
  .dash-row-time { font-family: var(--font-mono); color: var(--color-fg-muted); }
  .dash-row-name { font-weight: 500; }

  /* ─────── CALENDAR / CONFLICT ─────── */
  .cal-toolbar { display: flex; justify-content: space-between; align-items: center; margin-bottom: 14px; gap: 8px; flex-wrap: wrap; }
  .cal-toolbar-left { display: inline-flex; gap: 12px; align-items: center; flex-wrap: wrap; }
  .cal-week { font-weight: 500; }
  .cal-call-pulse {
    display: inline-flex; align-items: center; gap: 4px;
    padding: 4px 10px;
    background: rgba(168,149,107,0.18);
    border-radius: 999px;
    font-size: 11px;
    animation: callPulse 1.4s ease-in-out infinite;
  }
  @keyframes callPulse {
    0%,100% { box-shadow: 0 0 0 0 rgba(168,149,107,0.5); }
    50% { box-shadow: 0 0 0 6px rgba(168,149,107,0); }
  }
  .cal-pill { padding: 4px 10px; background: var(--color-cream); border: 1px solid var(--color-border); border-radius: 999px; font-size: 11px; }
  .cal-pill.is-active { background: var(--color-bark); color: var(--color-cream); border-color: var(--color-bark); }

  .cal-table {
    border: 1px solid var(--color-border);
    border-radius: 8px;
    overflow: hidden;
    background: white;
  }
  .cal-head-row, .cal-time-row {
    display: grid;
    grid-template-columns: 50px repeat(7, 1fr);
    border-bottom: 1px solid var(--color-border);
  }
  .cal-time-row:last-child { border-bottom: none; }
  .cal-head-cell { padding: 8px 4px; font-size: 11px; text-align: center; color: var(--color-fg-muted); background: var(--color-sand-light); }
  .cal-head-cell:not(:last-child) { border-right: 1px solid var(--color-border); }
  .cal-time { padding: 8px 4px; font-family: var(--font-mono); font-size: 10px; color: var(--color-fg-muted); text-align: center; background: var(--color-sand-light); border-right: 1px solid var(--color-border); }

---
import { type Locale } from '../i18n/utils';
interface Props { locale: Locale; }
const { locale } = Astro.props;
const t = (pl: string, en: string) => (locale === 'pl' ? pl : en);

type Scene = {
  id: string;
  eyebrow: string;
  caption: string;
  visual: 'dashboard' | 'calendar' | 'conflict' | 'checkout' | 'pass' | 'invoices' | 'owner' | 'vet' | 'report';
};

const scenes: Scene[] = locale === 'pl' ? [
  { id: 'morning', eyebrow: '07:00 · Poranek', caption: 'Otwierasz Hoverę. Widzisz dziś 18 jazd, 2 odwołania, 1 nowy klient.', visual: 'dashboard' },
  { id: 'booking', eyebrow: '08:30 · Telefon', caption: 'Klient pyta o piątek 17:00. System pokazuje sloty pasujące do jego poziomu.', visual: 'calendar' },
  { id: 'conflict', eyebrow: '10:15 · Wykryty konflikt', caption: 'Próbujesz dać Halince drugą jazdę o 11:00 — system blokuje, koń już zajęty.', visual: 'conflict' },
  { id: 'checkout', eyebrow: '12:00 · Klient kupuje online', caption: 'Anna kupuje karnet 12-jazd przez stronę stajni. BLIK, faktura, gotowe — bez Ciebie.', visual: 'checkout' },
  { id: 'pass', eyebrow: '14:00 · Karnet rozlicza się', caption: 'Po jeździe karnet sam ubywa o 1. Anna widzi swoje saldo w aplikacji.', visual: 'pass' },
  { id: 'invoices', eyebrow: '16:30 · Faktury cykliczne', caption: 'Pensjonat: 30 faktur za 1. dnia miesiąca, każda do KSeF, każda do biura. Sam.', visual: 'invoices' },
  { id: 'owner', eyebrow: '18:00 · Właściciel sprawdza konia', caption: 'Marek loguje się. Widzi: dziś jazda 16:00, wczoraj kowal, przedwczoraj weterynarz. Bez SMS-a do Ciebie.', visual: 'owner' },
  { id: 'vet', eyebrow: '19:30 · Weterynarz online', caption: 'Halinka kuleje. Wysyłasz dr Nowakowi link do dziennika konia. Pełna historia w 5 sekund.', visual: 'vet' },
  { id: 'report', eyebrow: '21:00 · Koniec dnia', caption: 'Hovera pokazuje raport: 18 jazd, 2 400 zł, 1 koń przeciążony. Idziesz spać spokojna.', visual: 'report' },
] : [
  { id: 'morning', eyebrow: '7:00 · Morning', caption: 'You open Hovera. Today: 18 rides, 2 cancellations, 1 new client.', visual: 'dashboard' },
  { id: 'booking', eyebrow: '8:30 · Phone rings', caption: 'Client asks about Friday 5pm. System shows slots matching their level.', visual: 'calendar' },
  { id: 'conflict', eyebrow: '10:15 · Conflict caught', caption: 'You try to give Halina a second ride at 11am — system blocks it, horse is already booked.', visual: 'conflict' },
  { id: 'checkout', eyebrow: '12:00 · Client buys online', caption: 'Anna buys a 12-ride pass on your stable page. Instant payment, instant invoice — no input from you.', visual: 'checkout' },
  { id: 'pass', eyebrow: '14:00 · Pass settles itself', caption: 'After the ride the pass auto-deducts. Anna sees her balance in the app.', visual: 'pass' },
  { id: 'invoices', eyebrow: '16:30 · Recurring invoices', caption: 'Boarding: 30 invoices on the 1st, each through e-invoicing, each to the accountant. Itself.', visual: 'invoices' },
  { id: 'owner', eyebrow: '18:00 · Owner checks the horse', caption: "Marek logs in. Sees: today's ride at 4pm, farrier yesterday, vet the day before. Zero SMS to you.", visual: 'owner' },
  { id: 'vet', eyebrow: '19:30 · Vet online', caption: 'Halina is lame. You send Dr Nowak a link to the horse journal. Full history in 5 seconds.', visual: 'vet' },
  { id: 'report', eyebrow: '21:00 · End of day', caption: 'Hovera shows the report: 18 rides, €600, 1 overworked horse. You sleep easy.', visual: 'report' },
];

const labels = {
  play: t('Odtwórz', 'Play'),
  pause: t('Pauza', 'Pause'),
  prev: t('Poprzednia', 'Previous'),
  next: t('Następna', 'Next'),
  restart: t('Od początku', 'Restart'),
  step: t('Krok', 'Step'),
  of: t('z', 'of'),
};
---

<div class="ipt" data-ipt data-total={scenes.length}>
  <!-- Header: progress + controls -->
  <div class="ipt-header">
    <div class="ipt-progress">
      <div class="ipt-progress-bar" data-progress-bar></div>
    </div>
    <div class="ipt-controls">
      <button type="button" class="ipt-btn" data-prev aria-label={labels.prev}>
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M9 11l-4-4 4-4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </button>
      <button type="button" class="ipt-btn ipt-btn-play" data-play aria-label={labels.pause}>
        <svg class="play-icon" width="14" height="14" viewBox="0 0 14 14" fill="currentColor" style="display:none;"><path d="M3 2l8 5-8 5V2z"/></svg>
        <svg class="pause-icon" width="14" height="14" viewBox="0 0 14 14" fill="currentColor"><path d="M4 2h2v10H4zM8 2h2v10H8z"/></svg>
      </button>
      <button type="button" class="ipt-btn" data-next aria-label={labels.next}>
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M5 11l4-4-4-4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </button>
      <span class="ipt-counter">
        <span data-current>1</span>
        <span class="muted">/ {scenes.length}</span>
      </span>
    </div>
  </div>

  <!-- Stage -->
  <div class="ipt-stage">
    {scenes.map((scene, i) => (
      <article
        class={`ipt-scene ipt-scene-${scene.visual} ${i === 0 ? 'is-active' : ''}`}
        data-scene
        data-index={i}
      >
        <div class="ipt-canvas">
          {/* SCENE 1: Dashboard */}
          {scene.visual === 'dashboard' && (
            <div class="dash">
              <div class="dash-greeting">{t('Cześć, Anna 👋', 'Hi, Anna 👋')}</div>
              <div class="dash-grid">
                <div class="dash-stat" style="--d: 0s;">
                  <div class="dash-stat-num" data-count="18">0</div>
                  <div class="dash-stat-label">{t('jazd dzisiaj', 'rides today')}</div>
                </div>
                <div class="dash-stat" style="--d: 0.2s;">
                  <div class="dash-stat-num" data-count="2">0</div>
                  <div class="dash-stat-label">{t('odwołania', 'cancellations')}</div>
                </div>
                <div class="dash-stat" style="--d: 0.4s;">
                  <div class="dash-stat-num" data-count="1">0</div>
                  <div class="dash-stat-label">{t('nowy klient', 'new client')}</div>
                </div>
                <div class="dash-stat" style="--d: 0.6s;">
                  <div class="dash-stat-num">2 400 <span class="text-base">zł</span></div>
                  <div class="dash-stat-label">{t('wczorajszy obrót', 'yesterday revenue')}</div>
                </div>
              </div>
            </div>
          )}

          {/* SCENE 2: Calendar with available slots */}
          {scene.visual === 'calendar' && (
            <div class="cal-stage">
              <div class="cal-phone-icon">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M20 15.5c-1.25 0-2.45-.2-3.57-.57a1 1 0 00-1.02.24l-2.2 2.2a15.07 15.07 0 01-6.59-6.59l2.2-2.2a1 1 0 00.24-1.02A11.5 11.5 0 018.5 4 1 1 0 007.5 3H4a1 1 0 00-1 1 17 17 0 0017 17 1 1 0 001-1v-3.5a1 1 0 00-1-1z"/></svg>
                <span>{t('Klient dzwoni…', 'Client calling…')}</span>
              </div>
              <div class="cal-grid">
                {[0,1,2,3,4,5,6].map((d) => (
                  <div class="cal-day">
                    <div class="cal-day-name">{['Pn','Wt','Śr','Cz','Pt','Sb','Nd'][d]}</div>
                    <div class="cal-slots">
                      {[0,1,2,3,4].map((s) => {
                        const free = (d === 4 && s === 2) || (d === 4 && s === 3) || (d === 1 && s === 1) || (d === 5 && s === 0);
                        const busy = !free && Math.abs(d - s) % 2 === 0;
                        return <div class={`cal-slot ${free ? 'is-free' : ''} ${busy ? 'is-busy' : ''}`}></div>;
                      })}
                    </div>
                  </div>
                ))}
              </div>
              <div class="cal-callout">{t('✓ Wolne: Pt 17:00 — Halina', '✓ Free: Fri 5pm — Halina')}</div>
            </div>
          )}

          {/* SCENE 3: Conflict */}
          {scene.visual === 'conflict' && (
            <div class="conf">
              <div class="conf-grid">
                <div class="conf-row">
                  <span class="conf-time">10:00</span>
                  <div class="conf-event conf-existing"><b>Halina</b> · Anna K.</div>
                </div>
                <div class="conf-row">
                  <span class="conf-time">11:00</span>
                  <div class="conf-event conf-dragging">
                    <b>Halina</b> · Marek W.
                    <span class="conf-warning">⚠ {t('Konflikt — koń zajęty', 'Conflict — horse busy')}</span>
                  </div>
                </div>
                <div class="conf-row">
                  <span class="conf-time">12:00</span>
                  <div class="conf-event conf-empty">{t('— wolne —', '— free —')}</div>
                </div>
              </div>
              <div class="conf-suggest">
                💡 {t('Spróbuj: Atos 11:00 (wolny)', 'Try: Atos 11am (free)')}
              </div>
            </div>
          )}

          {/* SCENE 4: Online checkout */}
          {scene.visual === 'checkout' && (
            <div class="checkout">
              <div class="checkout-card">
                <div class="checkout-head">
                  <span class="checkout-stable">stajnia-halicz.hovera.app</span>
                </div>
                <div class="checkout-product">
                  <div class="checkout-name">{t('Karnet 12 jazd', '12-ride pass')}</div>
                  <div class="checkout-price">580 zł</div>
                </div>
                <div class="checkout-method">
                  <div class="checkout-blik">BLIK</div>
                  <div class="checkout-blik-code">2&nbsp;5&nbsp;3&nbsp;0&nbsp;9&nbsp;7</div>
                </div>
                <div class="checkout-success">
                  <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M3 7l3 3 5-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  {t('Płatność OK · Faktura wysłana', 'Payment OK · Invoice sent')}
                </div>
              </div>
            </div>
          )}

          {/* SCENE 5: Pass auto-deduct */}
          {scene.visual === 'pass' && (
            <div class="passwrap">
              <div class="passwrap-card">
                <div class="passwrap-header">
                  <span>Anna Kowalska</span>
                  <span class="passwrap-pill" data-pass-counter><span data-pass-num>11</span>/12</span>
                </div>
                <div class="passwrap-meter"><div class="passwrap-meter-fill" style="--target: 92%"></div></div>
                <div class="passwrap-foot muted">
                  {t('Karnet 12 jazd · ważny do 30.06', '12-ride pass · valid until 30/06')}
                </div>
              </div>
              <div class="passwrap-event">
                <span class="passwrap-event-dot"></span>
                {t('Wt 14:00 · Halina · Anna · -1 jazda', 'Tue 2pm · Halina · Anna · -1 ride')}
              </div>
            </div>
          )}

          {/* SCENE 6: Recurring invoices */}
          {scene.visual === 'invoices' && (
            <div class="invs">
              <div class="invs-stack">
                {Array.from({length: 6}).map((_, i) => (
                  <div class="invs-card" style={`--i: ${i}; --delay: ${i * 0.12}s;`}>
                    <div class="invs-num">FV/2026/{(i + 41).toString().padStart(3, '0')}</div>
                    <div class="invs-row">
                      <span>{['Halina', 'Atos', 'Bonita', 'Niko', 'Riko', 'Misia'][i]}</span>
                      <span>1 200 zł</span>
                    </div>
                    <div class="invs-stamp">KSeF ✓</div>
                  </div>
                ))}
              </div>
              <div class="invs-meta">
                {t('30 faktur · 0 minut Twojej pracy', '30 invoices · 0 minutes of your work')}
              </div>
            </div>
          )}

          {/* SCENE 7: Owner checks the horse */}
          {scene.visual === 'owner' && (
            <div class="ownerwrap">
              <div class="owner-phone">
                <div class="owner-screen">
                  <div class="owner-status">
                    <span>9:41</span>
                    <span>📶 100%</span>
                  </div>
                  <div class="owner-greeting">
                    {t('Cześć Marek', 'Hi Marek')}
                  </div>
                  <div class="owner-horse">
                    <div class="owner-horse-avatar">H</div>
                    <div>
                      <div class="owner-horse-name">Halinka</div>
                      <div class="owner-horse-sub">{t('Twój koń', 'Your horse')}</div>
                    </div>
                  </div>
                  <div class="owner-section-label">{t('Dzisiaj', 'Today')}</div>
                  <div class="owner-event owner-event-1">
                    <span class="owner-event-dot d-train"></span>
                    <div>
                      <div class="owner-event-title">{t('Jazda 16:00 · Anna K.', 'Ride 4pm · Anna K.')}</div>
                      <div class="owner-event-sub muted">{t('hala kryta · 60 min', 'indoor arena · 60 min')}</div>
                    </div>
                  </div>
                  <div class="owner-section-label">{t('Wczoraj', 'Yesterday')}</div>
                  <div class="owner-event owner-event-2">
                    <span class="owner-event-dot d-shoe"></span>
                    <div>
                      <div class="owner-event-title">{t('Kowal · pełne podk.', 'Farrier · full set')}</div>
                      <div class="owner-event-sub muted">{t('Jan Kowalski · 13:00', 'Jan Kowalski · 1pm')}</div>
                    </div>
                  </div>
                  <div class="owner-section-label">{t('Przedwczoraj', '2 days ago')}</div>
                  <div class="owner-event owner-event-3">
                    <span class="owner-event-dot d-vet"></span>
                    <div>
                      <div class="owner-event-title">{t('Weterynarz · szczepienie', 'Vet · vaccination')}</div>
                      <div class="owner-event-sub muted">{t('dr Nowak · grypa+tężec', 'Dr Nowak · flu + tetanus')}</div>
                    </div>
                  </div>
                </div>
              </div>
              <div class="owner-callout">
                💡 {t('Bez SMS-a do Ciebie. Marek wie wszystko sam.', 'Zero SMS to you. Marek knows everything himself.')}
              </div>
            </div>
          )}

          {/* SCENE 8: Vet link */}
          {scene.visual === 'vet' && (
            <div class="vetwrap">
              <div class="vet-journal">
                <div class="vet-journal-head">
                  <div class="vet-avatar">H</div>
                  <div>
                    <div class="font-medium">Halina · KWPN, 2018</div>
                    <div class="text-xs muted">{t('Pełna historia · 247 wpisów', 'Full history · 247 entries')}</div>
                  </div>
                </div>
                <ul class="vet-timeline">
                  <li><span class="dot d-vet"></span><b>{t('Szczepienie', 'Vaccination')}</b><small>· 12.03</small></li>
                  <li><span class="dot d-train"></span><b>{t('Trening skok', 'Jumping')}</b><small>· 15.03</small></li>
                  <li><span class="dot d-shoe"></span><b>{t('Kowal', 'Farrier')}</b><small>· 20.03</small></li>
                  <li><span class="dot d-note"></span><b>{t('Notatka — kulawizna', 'Note — lameness')}</b><small>· 22.03</small></li>
                  <li class="vet-timeline-new"><span class="dot d-vet"></span><b>{t('Wysłano do wet.', 'Sent to vet')}</b><small>· 22.03</small></li>
                </ul>
              </div>
              <div class="vet-link-toast">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10 14a5 5 0 007 0l4-4a5 5 0 00-7-7l-1 1M14 10a5 5 0 00-7 0l-4 4a5 5 0 007 7l1-1"/></svg>
                {t('Link wysłany do dr Nowak', 'Link sent to Dr Nowak')}
              </div>
            </div>
          )}

          {/* SCENE 9: End of day report */}
          {scene.visual === 'report' && (
            <div class="rep">
              <div class="rep-head">{t('Raport dnia · 6 maja 2026', 'Daily report · 6 May 2026')}</div>
              <div class="rep-grid">
                <div class="rep-stat">
                  <div class="rep-stat-num" data-count="18">0</div>
                  <div class="rep-stat-label">{t('zaplanowane jazdy', 'planned rides')}</div>
                </div>
                <div class="rep-stat">
                  <div class="rep-stat-num" data-count="16">0</div>
                  <div class="rep-stat-label">{t('zrealizowane', 'completed')}</div>
                </div>
                <div class="rep-stat">
                  <div class="rep-stat-num">2 400 <span class="text-base">zł</span></div>
                  <div class="rep-stat-label">{t('przychód', 'revenue')}</div>
                </div>
                <div class="rep-stat rep-stat-warn">
                  <div class="rep-stat-num">1</div>
                  <div class="rep-stat-label">{t('koń przeciążony', 'overworked horse')}</div>
                </div>
              </div>
              <div class="rep-note">
                {t('💤 Idź spać spokojna. Klienci zarezerwują jutrzejsze jazdy sami.', "💤 Sleep easy. Clients book tomorrow's rides themselves.")}
              </div>
            </div>
          )}
        </div>

        <div class="ipt-caption">
          <span class="eyebrow">{scene.eyebrow}</span>
          <p class="ipt-caption-text">{scene.caption}</p>
        </div>
      </article>
    ))}
  </div>

  <!-- Dots -->
  <div class="ipt-dots">
    {scenes.map((_, i) => (
      <button type="button" class={`ipt-dot ${i === 0 ? 'is-active' : ''}`} data-dot data-index={i} aria-label={`${labels.step} ${i + 1}`}></button>
    ))}
  </div>
</div>

<style>
  .ipt {
    width: 100%;
    max-width: 1100px;
    margin: 0 auto;
    background: linear-gradient(180deg, var(--color-cream) 0%, var(--color-sand-light) 100%);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-2xl);
    box-shadow: var(--shadow-warm);
    overflow: hidden;
    position: relative;
  }

  .ipt-header {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    padding: 1rem 1.5rem;
    border-bottom: 1px solid var(--color-border);
    background: rgba(255, 255, 255, 0.5);
  }
  .ipt-progress {
    flex: 1;
    height: 3px;
    background: var(--color-sand-dark);
    border-radius: 999px;
    overflow: hidden;
  }
  .ipt-progress-bar {
    height: 100%;
    width: 0%;
    background: linear-gradient(90deg, var(--color-ochre) 0%, var(--color-ochre-dark) 100%);
    border-radius: 999px;
    transition: width 0.1s linear;
  }
  .ipt-controls { display: flex; align-items: center; gap: 0.4rem; }
  .ipt-btn {
    width: 32px; height: 32px;
    border-radius: 999px;
    background: var(--color-cream);
    border: 1px solid var(--color-border);
    color: var(--color-fg);
    display: inline-flex; align-items: center; justify-content: center;
    cursor: pointer;
    transition: background 0.2s, border-color 0.2s;
  }
  .ipt-btn:hover { background: var(--color-bark); color: var(--color-cream); border-color: var(--color-bark); }
  .ipt-btn-play { background: var(--color-bark); color: var(--color-cream); border-color: var(--color-bark); }
  .ipt-btn-play:hover { background: var(--color-bark-700); }
  .ipt-counter { font-size: 12px; font-family: var(--font-mono); color: var(--color-fg-muted); margin-left: 0.4rem; }
  .ipt-counter [data-current] { color: var(--color-fg); font-weight: 600; }

  .ipt-stage {
    position: relative;
    aspect-ratio: 16 / 9;
    background: var(--color-cream);
  }
  @media (max-width: 700px) { .ipt-stage { aspect-ratio: 4 / 5; } }

  .ipt-scene {
    position: absolute;
    inset: 0;
    padding: 2rem;
    display: grid;
    grid-template-rows: 1fr auto;
    gap: 1.25rem;
    opacity: 0;
    transform: translateX(20px);
    transition: opacity 0.5s var(--ease-out-expo), transform 0.5s var(--ease-out-expo);
    pointer-events: none;
  }
  .ipt-scene.is-active {
    opacity: 1;
    transform: translateX(0);
    pointer-events: auto;
  }

  .ipt-canvas {
    position: relative;
    border-radius: var(--radius-xl);
    background: white;
    border: 1px solid var(--color-border);
    overflow: hidden;
    padding: 1.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ipt-caption {
    text-align: center;
    padding: 0 1rem;
  }
  .ipt-caption-text {
    margin-top: 0.5rem;
    font-size: clamp(1rem, 2vw, 1.25rem);
    line-height: 1.4;
    color: var(--color-fg);
    font-weight: 500;
  }

  .ipt-dots {
    display: flex;
    justify-content: center;
    gap: 6px;
    padding: 1rem;
    border-top: 1px solid var(--color-border);
    background: rgba(255, 255, 255, 0.5);
  }
  .ipt-dot {
    width: 8px; height: 8px;
    border-radius: 999px;
    background: var(--color-sand-dark);
    border: none;
    cursor: pointer;
    transition: background 0.2s, width 0.2s;
    padding: 0;
  }
  .ipt-dot:hover { background: var(--color-ochre); }
  .ipt-dot.is-active { background: var(--color-bark); width: 24px; border-radius: 4px; }

  /* ─────────────────────────── SCENE: Dashboard ─────────────────────────── */
  .dash { width: 100%; max-width: 600px; }
  .dash-greeting {
    font-size: 1.5rem; font-weight: 500; letter-spacing: -0.02em;
    margin-bottom: 1.5rem;
  }
  .dash-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1rem; }
  .dash-stat {
    padding: 1.25rem;
    background: var(--color-sand-light);
    border-radius: 12px;
    animation: dashFade 0.6s var(--ease-out-expo) both;
    animation-delay: var(--d);
  }
  .ipt-scene.is-active .dash-stat { animation-name: dashFade; }
  .dash-stat-num { font-size: 2rem; font-weight: 500; letter-spacing: -0.04em; line-height: 1; }
  .dash-stat-label { font-size: 0.8rem; color: var(--color-fg-muted); margin-top: 0.4rem; }
  @keyframes dashFade {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* ─────────────────────────── SCENE: Calendar ─────────────────────────── */
  .cal-stage { width: 100%; position: relative; }
  .cal-phone-icon {
    display: inline-flex; align-items: center; gap: 0.5rem;
    padding: 6px 12px; background: rgba(168,149,107,0.18); border-radius: 999px;
    font-size: 0.85rem; color: var(--color-bark);

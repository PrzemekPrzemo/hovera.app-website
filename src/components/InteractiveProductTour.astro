<script>
  function initInteractiveTour() {
    const tour = document.querySelector<HTMLElement>('[data-ipt]');
    if (!tour) return;

    const total = Number(tour.dataset.total || 9);
    const sceneEls = Array.from(tour.querySelectorAll<HTMLElement>('[data-scene]'));
    const dotEls = Array.from(tour.querySelectorAll<HTMLButtonElement>('[data-dot]'));
    const progressBar = tour.querySelector<HTMLElement>('[data-progress-bar]');
    const currentLabel = tour.querySelector<HTMLElement>('[data-current]');
    const playBtn = tour.querySelector<HTMLButtonElement>('[data-play]');
    const prevBtn = tour.querySelector<HTMLButtonElement>('[data-prev]');
    const nextBtn = tour.querySelector<HTMLButtonElement>('[data-next]');
    const playIcon = tour.querySelector<HTMLElement>('.play-icon');
    const pauseIcon = tour.querySelector<HTMLElement>('.pause-icon');

    let current = 0;
    let isPlaying = true;
    let sceneStartedAt = 0;
    const SCENE_DURATION = 7000;

    function animateCounters() {
      const activeScene = sceneEls[current];
      if (!activeScene) return;
      activeScene.querySelectorAll<HTMLElement>('[data-count]').forEach((el) => {
        const target = Number(el.dataset.count || 0);
        const startedAt = performance.now();
        const duration = 800;
        const step = (now: number) => {
          const t = Math.min(1, (now - startedAt) / duration);
          const eased = 1 - Math.pow(1 - t, 3);
          el.textContent = Math.round(target * eased).toString();
          if (t < 1) requestAnimationFrame(step);
        };
        requestAnimationFrame(step);
      });

      const passDisplay = activeScene.querySelector<HTMLElement>('[data-pass-display]');
      if (passDisplay) {
        passDisplay.textContent = '12/12';
        setTimeout(() => { passDisplay.textContent = '11/12'; }, 1100);
      }
    }

    function setScene(idx: number) {
      current = ((idx % total) + total) % total;
      sceneEls.forEach((el, i) => el.classList.toggle('is-active', i === current));
      dotEls.forEach((el, i) => el.classList.toggle('is-active', i === current));
      if (currentLabel) currentLabel.textContent = (current + 1).toString();
      sceneStartedAt = performance.now();
      animateCounters();
    }

    function tick() {
      if (!isPlaying || !progressBar) {
        requestAnimationFrame(tick);
        return;
      }
      const elapsed = performance.now() - sceneStartedAt;
      const pct = Math.min(100, (elapsed / SCENE_DURATION) * 100);
      progressBar.style.width = pct + '%';
      if (elapsed >= SCENE_DURATION) {
        setScene(current + 1);
        if (progressBar) progressBar.style.width = '0%';
      }
      requestAnimationFrame(tick);
    }

    function play() {
      isPlaying = true;
      if (playIcon) playIcon.style.display = 'none';
      if (pauseIcon) pauseIcon.style.display = 'block';
      sceneStartedAt = performance.now();
    }
    function pause() {
      isPlaying = false;
      if (playIcon) playIcon.style.display = 'block';
      if (pauseIcon) pauseIcon.style.display = 'none';
    }

    playBtn?.addEventListener('click', () => isPlaying ? pause() : play());
    prevBtn?.addEventListener('click', () => { setScene(current - 1); if (progressBar) progressBar.style.width = '0%'; });
    nextBtn?.addEventListener('click', () => { setScene(current + 1); if (progressBar) progressBar.style.width = '0%'; });
    dotEls.forEach((dot) => {
      dot.addEventListener('click', () => {
        setScene(Number(dot.dataset.index || 0));
        if (progressBar) progressBar.style.width = '0%';
      });
    });

    tour.tabIndex = 0;
    tour.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowLeft') { prevBtn?.click(); e.preventDefault(); }
      if (e.key === 'ArrowRight') { nextBtn?.click(); e.preventDefault(); }
      if (e.key === ' ') { playBtn?.click(); e.preventDefault(); }
    });

    setScene(0);
    tick();
  }

  initInteractiveTour();
  document.addEventListener('astro:page-load', initInteractiveTour);
</script>

  @media (max-width: 800px) { .app-nav-item { justify-content: center; } .app-nav-item span:not(svg) { display: none; } }
  @media (max-width: 800px) { .app-nav-item:not(.is-active) { padding: 7px 0; } .app-nav-item:has(+ svg) { padding: 7px 0; } }

  .app-user { display: flex; gap: 8px; align-items: center; padding: 8px; border-top: 1px solid var(--color-border); }
  .app-user-avatar { width: 28px; height: 28px; border-radius: 999px; background: var(--color-ochre); color: var(--color-cream); display: inline-flex; align-items: center; justify-content: center; font-weight: 600; font-size: 12px; }

---
import { type Locale } from '../i18n/utils';
interface Props {
  locale: Locale;
  defaultPlan?: string;
  defaultUseCase?: string;
  compact?: boolean;
}
const { locale, defaultPlan = '', defaultUseCase = '', compact = false } = Astro.props;

const t = (pl: string, en: string) => (locale === 'pl' ? pl : en);
const plans = locale === 'pl'
  ? ['Free', 'Solo', 'Stable', 'Pro', 'Enterprise']
  : ['Free', 'Solo', 'Stable', 'Pro', 'Enterprise'];
const useCases = locale === 'pl'
  ? ['Szkółka', 'Pensjonat', 'Sport i trening', 'Hodowla', 'Sieć stajni', 'Inne']
  : ['Riding school', 'Boarding', 'Sport & training', 'Breeding', 'Stable network', 'Other'];
const sizes = locale === 'pl'
  ? ['1-5 koni', '6-15 koni', '16-30 koni', '31-50 koni', '50+ koni']
  : ['1-5 horses', '6-15 horses', '16-30 horses', '31-50 horses', '50+ horses'];
---

<form
  class={`inquiry-form ${compact ? 'is-compact' : ''}`}
  action="/api/contact.php"
  method="POST"
  data-form
>
  <input type="hidden" name="_locale" value={locale} />
  <input type="hidden" name="_subject" value={`Hovera inquiry${defaultPlan ? ` · ${defaultPlan}` : ''}`} />
  <div class="hp-field" aria-hidden="true">
    <label>{t('Nie wypełniaj', 'Leave empty')}</label>
    <input type="text" name="_honeypot" tabindex="-1" autocomplete="off" />
  </div>

  <div class="grid gap-4 md:grid-cols-2">
    <label class="field">
      <span>{t('Imię i nazwisko', 'Full name')}</span>
      <input type="text" name="name" required autocomplete="name" placeholder={t('Anna Kowalska', 'Jane Doe')} />
    </label>

    <label class="field">
      <span>{t('Adres email', 'Email')}</span>
      <input type="email" name="email" required autocomplete="email" placeholder="anna@stajnia.pl" />
    </label>

    <label class="field">
      <span>{t('Nazwa stajni', 'Stable name')}</span>
      <input type="text" name="stable" autocomplete="organization" placeholder={t('Stajnia Halicz', 'Halicz Stables')} />
    </label>

    <label class="field">
      <span>{t('Telefon (opcjonalnie)', 'Phone (optional)')}</span>
      <input type="tel" name="phone" autocomplete="tel" placeholder="+48 600 000 000" />
    </label>

    <label class="field">
      <span>{t('Profil stajni', 'Stable profile')}</span>
      <select name="useCase">
        <option value="">{t('Wybierz', 'Choose')}</option>
        {useCases.map((u) => <option value={u} selected={u === defaultUseCase}>{u}</option>)}
      </select>
    </label>

    <label class="field">
      <span>{t('Wielkość', 'Size')}</span>
      <select name="size">
        <option value="">{t('Wybierz', 'Choose')}</option>
        {sizes.map((s) => <option value={s}>{s}</option>)}
      </select>
    </label>

    <label class="field">
      <span>{t('Interesujący Cię plan', 'Plan of interest')}</span>
      <select name="plan">
        <option value="">{t('Pomożemy wybrać', 'Help me choose')}</option>
        {plans.map((p) => <option value={p} selected={p === defaultPlan}>{p}</option>)}
      </select>
    </label>

    <label class="field">
      <span>{t('Jak się o nas dowiedziałaś?', 'How did you hear about us?')}</span>
      <select name="source">
        <option value="">{t('Wybierz', 'Choose')}</option>
        <option>Google</option>
        <option>{t('Polecenie', 'Referral')}</option>
        <option>Instagram</option>
        <option>Facebook</option>
        <option>{t('Targi / wydarzenie', 'Trade show / event')}</option>
        <option>{t('Inne', 'Other')}</option>
      </select>
    </label>
  </div>

  <label class="field mt-4">
    <span>{t('Wiadomość (opcjonalnie)', 'Message (optional)')}</span>
    <textarea name="message" rows="4" placeholder={t('Napisz coś o swojej stajni i tym, czego potrzebujesz.', 'Tell us a bit about your stable and what you need.')}></textarea>
  </label>

  <label class="consent mt-4">
    <input type="checkbox" name="consent" required />
    <span>
      {t(
        'Wyrażam zgodę na kontakt zwrotny i przetwarzanie moich danych zgodnie z',
        'I consent to follow-up contact and the processing of my data in line with our'
      )}
      {' '}
      <a href={locale === 'pl' ? '/polityka-prywatnosci' : '/en/polityka-prywatnosci'} class="underline">
        {t('Polityką prywatności', 'Privacy policy')}
      </a>.
    </span>
  </label>

  <div class="form-actions mt-6 flex flex-wrap items-center gap-3">
    <button type="submit" class="btn btn-primary">
      {t('Wyślij zapytanie', 'Send inquiry')}
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
        <path d="M3 7h8m-3-3l3 3-3 3" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>
    <span class="muted text-sm">
      {t('Odpowiadamy w 24h.', 'We reply within 24h.')}
    </span>
  </div>

  <div class="form-status" data-status hidden></div>
</form>

<style>
  .inquiry-form { width: 100%; }
  .hp-field {
    position: absolute !important;
    left: -9999px;
    width: 1px; height: 1px;
    overflow: hidden;
  }
  .field { display: flex; flex-direction: column; gap: 0.4rem; }
  .field span { font-size: 0.8rem; font-weight: 500; color: var(--color-fg-muted); }
  .field input,
  .field select,
  .field textarea {
    width: 100%;
    background: var(--color-cream);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: 0.85rem 1rem;
    font-family: inherit;
    font-size: 0.95rem;
    color: var(--color-fg);
    transition: border-color 0.2s, box-shadow 0.2s, background 0.2s;
  }
  .field input:focus,
  .field select:focus,
  .field textarea:focus {
    outline: none;
    border-color: var(--color-bark);
    box-shadow: 0 0 0 4px rgba(168,149,107,0.18);
    background: white;
  }
  .field textarea { resize: vertical; min-height: 6rem; }
  .consent {
    display: flex;
    gap: 0.6rem;
    align-items: flex-start;
    font-size: 0.85rem;
    color: var(--color-fg-muted);
    line-height: 1.45;
  }
  .consent input { margin-top: 0.2rem; accent-color: var(--color-bark); }
  .form-status {
    margin-top: 1rem;
    padding: 1rem;
    border-radius: 12px;
    background: var(--color-sand-light);
    border: 1px solid var(--color-border);
  }
  .form-status.is-success {
    background: rgba(111,182,122,0.16);
    border-color: rgba(111,182,122,0.4);
    color: #2c5530;
  }
  .form-status.is-error {
    background: rgba(177,72,72,0.12);
    border-color: rgba(177,72,72,0.35);
    color: #7d2424;
  }
</style>

<script>
  document.querySelectorAll<HTMLFormElement>('[data-form]').forEach((form) => {
    form.addEventListener('submit', async (e) => {
      const honey = (form.elements.namedItem('_honeypot') as HTMLInputElement | null)?.value;
      if (honey) { e.preventDefault(); return; }
      // Allow native submit fallback. Optional: convert to fetch when API endpoint is ready.
    });
  });
</script>

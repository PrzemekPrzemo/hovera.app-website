---
interface Props {
  eyebrow: string;
  headline: string;
  subtitle: string;
  accent: 'calendar' | 'passes' | 'invoice' | 'journal' | 'mobile' | 'booking' | 'ai';
}
const { eyebrow, headline, subtitle, accent } = Astro.props;
---

<section class="ph-hero relative overflow-hidden">
  <div class="ph-mesh" aria-hidden="true"></div>
  <div class="container-x relative pt-12 pb-24 md:pt-20 md:pb-32">
    <div class="max-w-3xl mx-auto text-center" data-reveal>
      <span class="eyebrow">{eyebrow}</span>
      <h1 class="display-1 mt-5 text-balance">{headline}</h1>
      <p class="lead mt-6 max-w-2xl mx-auto text-balance">{subtitle}</p>
    </div>

    <div class="ph-visual mt-16 mx-auto max-w-5xl" data-reveal>
      <div class={`ph-frame ph-frame-${accent}`}>
        {accent === 'calendar' && (
          <div class="ph-cal">
            <div class="ph-cal-head">
              {['Pn', 'Wt', 'Śr', 'Cz', 'Pt', 'Sb', 'Nd'].map((d) => <span>{d}</span>)}
            </div>
            <div class="ph-cal-body">
              <div class="ph-cal-event" style="--c:var(--color-ochre); --x:2%; --w:12%; --y:8%;"><span>09:00 Anna</span></div>
              <div class="ph-cal-event" style="--c:var(--color-bark); --x:16%; --w:12%; --y:18%;"><span>10:30 Marek</span></div>
              <div class="ph-cal-event" style="--c:var(--color-ochre-dark); --x:30%; --w:12%; --y:12%;"><span>11:00 Karolina</span></div>
              <div class="ph-cal-event ph-conflict" style="--c:#B14848; --x:44%; --w:12%; --y:32%;"><span>13:00 ⚠ Konflikt</span></div>
              <div class="ph-cal-event" style="--c:var(--color-ochre); --x:58%; --w:12%; --y:22%;"><span>14:00 Grupa B</span></div>
              <div class="ph-cal-event" style="--c:var(--color-bark); --x:72%; --w:12%; --y:14%;"><span>16:00 Tomek</span></div>
              <div class="ph-cal-event ph-drag" style="--c:var(--color-ochre-dark); --x:86%; --w:12%; --y:24%;"><span>17:00 → drag</span></div>
            </div>
          </div>
        )}
        {accent === 'passes' && (
          <div class="ph-pass">
            <div class="ph-pass-card">
              <div class="ph-pass-header"><span>Anna Kowalska</span><span class="ph-pill">8/12</span></div>
              <div class="ph-meter"><div class="ph-meter-fill"></div></div>
              <div class="ph-pass-meta"><span>Karnet 12 jazd</span><span>580 zł</span></div>
            </div>
            <div class="ph-flow">
              <div>Jazda</div><span>→</span><div>Karnet -1</div><span>→</span><div class="active">Faktura KSeF</div>
            </div>
          </div>
        )}
        {accent === 'invoice' && (
          <div class="ph-invoice">
            <div class="ph-invoice-head">
              <div>
                <div class="text-xs muted">FV/2026/041</div>
                <div class="font-medium mt-1">Hovera Sp. z o.o.</div>
              </div>
              <div class="ph-stamp"><span>KSeF</span><small>wysłana</small></div>
            </div>
            <div class="ph-invoice-row"><span>Karnet 12 jazd</span><span>580,00 zł</span></div>
            <div class="ph-invoice-row"><span>Pensjonat — Halina</span><span>1 200,00 zł</span></div>
            <div class="ph-invoice-row"><span>Lekcja indywidualna</span><span>180,00 zł</span></div>
            <div class="ph-invoice-total"><span>Razem brutto</span><span class="text-xl">1 960,00 zł</span></div>
            <div class="ph-invoice-status"><span class="dot"></span>Numer KSeF: 5260123456-2026</div>
          </div>
        )}
        {accent === 'journal' && (
          <div class="ph-journal">
            <div class="ph-jh"><div class="ph-jh-avatar">H</div><div><div class="font-medium">Halina · KWPN, 2018</div><div class="text-xs muted">Ostatnia szczepionka: 12 mar</div></div></div>
            <ul class="ph-timeline">
              <li><span class="dot d-vet"></span><b>Szczepienie</b><small>12.03 · Wet. Nowak</small></li>
              <li><span class="dot d-train"></span><b>Trening skok</b><small>15.03 · 95cm</small></li>
              <li><span class="dot d-shoe"></span><b>Kowal</b><small>20.03 · pełne</small></li>
              <li><span class="dot d-note"></span><b>Notatka</b><small>22.03 · lekka kontuzja</small></li>
            </ul>
          </div>
        )}
        {accent === 'mobile' && (
          <div class="ph-mobile">
            <div class="ph-phone">
              <div class="ph-phone-screen">
                <div class="ph-mob-row ph-offline">offline · 3 zmiany</div>
                <div class="ph-mob-card"><div class="font-medium text-xs">Dzisiaj · 6 jazd</div><div class="text-xs muted mt-2">09:00 Anna<br/>10:30 Marek<br/>11:00 Karolina</div></div>
                <div class="ph-mob-action">+ Dodaj jazdę</div>
              </div>
            </div>
            <div class="ph-mobile-callout"><span class="dot"></span>Synchronizacja gdy wrócisz</div>
          </div>
        )}
        {accent === 'booking' && (
          <div class="ph-book">
            <div class="ph-book-head">stajnia-halicz.hovera.app</div>
            <div class="ph-book-body">
              <div class="ph-book-month">Maj 2026</div>
              <div class="ph-book-grid">
                {Array.from({ length: 7 }).map((_, i) => <div class="ph-day-head">{['Pn','Wt','Śr','Cz','Pt','Sb','Nd'][i]}</div>)}
                {Array.from({ length: 21 }).map((_, i) => <div class={`ph-day ${[2,3,5,8,9,11,15,16].includes(i) ? 'is-busy' : ''}`}>{i + 1}</div>)}
              </div>
            </div>
          </div>
        )}
        {accent === 'ai' && (
          <div class="ph-ai">
            <div class="ph-ai-bubble user">Ile godzin pracował Atos w marcu?</div>
            <div class="ph-ai-bubble bot">
              <div class="ph-ai-typing">
                <span></span><span></span><span></span>
              </div>
              <p>Atos miał <b>18 godzin</b> w marcu — głównie skoki (12h) i ujeżdżenie (6h). To <b>2h więcej</b> niż średnia stadnina. Sugeruję sprawdzić, czy nie potrzebuje dnia wolnego.</p>
            </div>
          </div>
        )}
      </div>
    </div>
  </div>
</section>

<style>
  .ph-mesh {
    position: absolute;
    inset: -10% -10% auto -10%;
    height: 100%;
    background:
      radial-gradient(circle at 30% 20%, rgba(168,149,107,0.32), transparent 50%),
      radial-gradient(circle at 75% 30%, rgba(232,221,208,0.7), transparent 55%);
    filter: blur(8px);
    z-index: -1;
  }
  .ph-frame {
    background: linear-gradient(180deg, #fff 0%, var(--color-sand-light) 100%);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-2xl);
    box-shadow: var(--shadow-warm);
    padding: 2rem;
    aspect-ratio: 16/9;
    position: relative;
    overflow: hidden;
  }

  /* Calendar */
  .ph-cal { display: flex; flex-direction: column; height: 100%; }
  .ph-cal-head { display: grid; grid-template-columns: repeat(7, 1fr); gap: 4px; }
  .ph-cal-head span { font-size: 11px; color: var(--color-fg-muted); text-align: center; padding: 6px; background: var(--color-cream); border-radius: 6px; }
  .ph-cal-body { position: relative; flex: 1; margin-top: 8px; background-image: repeating-linear-gradient(to right, transparent 0, transparent calc(100%/7 - 1px), var(--color-border) calc(100%/7 - 1px), var(--color-border) calc(100%/7)); border-radius: 8px; background-color: white; }
  .ph-cal-event { position: absolute; left: var(--x); top: var(--y); width: var(--w); background: var(--c); color: var(--color-cream); border-radius: 6px; padding: 5px 8px; font-size: 11px; font-weight: 500; box-shadow: 0 2px 6px rgba(61,46,34,0.18); animation: rowPop .8s var(--ease-out-expo) backwards; }
  .ph-cal-event:nth-child(1) { animation-delay: .1s; }
  .ph-cal-event:nth-child(2) { animation-delay: .2s; }
  .ph-cal-event:nth-child(3) { animation-delay: .3s; }
  .ph-cal-event:nth-child(4) { animation-delay: .4s; }
  .ph-cal-event:nth-child(5) { animation-delay: .5s; }
  .ph-cal-event:nth-child(6) { animation-delay: .6s; }
  .ph-cal-event:nth-child(7) { animation-delay: .7s; }
  .ph-conflict { animation: phPulse 2s ease-in-out infinite; }
  .ph-drag { animation: phDrag 4s ease-in-out infinite; }
  @keyframes rowPop { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: translateY(0);} }
  @keyframes phPulse { 0%,100% { box-shadow: 0 2px 6px rgba(177,72,72,0.4),0 0 0 0 rgba(177,72,72,0.4);} 50% { box-shadow: 0 2px 6px rgba(177,72,72,0.4),0 0 0 10px rgba(177,72,72,0);} }
  @keyframes phDrag { 0%,100% { transform: translate(0,0);} 50% { transform: translate(-15px,-8px); box-shadow: 0 12px 28px rgba(61,46,34,0.3);} }

  /* Pass */
  .ph-pass { display: flex; flex-direction: column; gap: 1.5rem; height: 100%; justify-content: center; }
  .ph-pass-card { background: white; border: 1px solid var(--color-border); border-radius: 14px; padding: 20px; max-width: 28rem; margin: 0 auto; width: 100%; }
  .ph-pass-header { display: flex; justify-content: space-between; align-items: center; font-weight: 500; }
  .ph-pill { font-size: 12px; padding: 4px 10px; background: var(--color-bark); color: var(--color-cream); border-radius: 999px; }
  .ph-meter { margin-top: 16px; height: 8px; background: var(--color-sand-light); border-radius: 999px; overflow: hidden; }
  .ph-meter-fill { height: 100%; width: 66%; background: linear-gradient(90deg, var(--color-ochre) 0%, var(--color-ochre-dark) 100%); border-radius: 999px; animation: phMeter 2s var(--ease-out-expo); }
  @keyframes phMeter { from { width: 0; } to { width: 66%; } }
  .ph-pass-meta { display: flex; justify-content: space-between; margin-top: 12px; font-size: 12px; color: var(--color-fg-muted); }
  .ph-flow { display: flex; gap: 12px; align-items: center; justify-content: center; flex-wrap: wrap; font-size: 13px; }
  .ph-flow > div { padding: 8px 16px; border: 1px solid var(--color-border); border-radius: 999px; background: var(--color-cream); }
  .ph-flow > div.active { background: var(--color-bark); color: var(--color-cream); border-color: var(--color-bark); }
  .ph-flow span { color: var(--color-fg-muted); }

  /* Invoice */
  .ph-invoice { display: flex; flex-direction: column; gap: .8rem; height: 100%; max-width: 30rem; margin: 0 auto; width: 100%; justify-content: center; }
  .ph-invoice-head { display: flex; justify-content: space-between; align-items: flex-start; }
  .ph-stamp { background: var(--color-bark); color: var(--color-cream); padding: 10px 14px; border-radius: 12px; text-align: center; transform: rotate(-3deg); animation: stampIn .8s var(--ease-out-expo); }
  .ph-stamp span { display: block; font-size: 12px; font-weight: 700; letter-spacing: 0.1em; }
  .ph-stamp small { font-size: 10px; opacity: 0.7; }
  @keyframes stampIn { from { transform: rotate(-15deg) scale(0.6); opacity: 0; } to { transform: rotate(-3deg) scale(1); opacity: 1; } }
  .ph-invoice-row { display: flex; justify-content: space-between; padding: 10px 0; border-bottom: 1px solid var(--color-border); font-size: 13px; }
  .ph-invoice-total { display: flex; justify-content: space-between; align-items: baseline; padding: 14px 16px; background: var(--color-sand-light); border-radius: 10px; font-weight: 500; margin-top: 6px; }
  .ph-invoice-status { display: inline-flex; align-items: center; gap: 6px; font-size: 12px; padding: 6px 12px; background: rgba(111,182,122,0.16); border-radius: 999px; align-self: flex-start; }
  .ph-invoice-status .dot { width: 6px; height: 6px; border-radius: 999px; background: #6FB67A; animation: pulseDot 2s infinite; }
  @keyframes pulseDot { 0% { box-shadow: 0 0 0 0 rgba(111,182,122,0.6);} 100% { box-shadow: 0 0 0 6px rgba(111,182,122,0);} }

  /* Journal */
  .ph-journal { display: flex; flex-direction: column; gap: 1rem; height: 100%; max-width: 30rem; margin: 0 auto; width: 100%; }
  .ph-jh { display: flex; gap: 12px; align-items: center; }
  .ph-jh-avatar { width: 48px; height: 48px; border-radius: 999px; background: var(--color-ochre); color: var(--color-cream); display: inline-flex; align-items: center; justify-content: center; font-weight: 600; }
  .ph-timeline { list-style: none; padding: 0 0 0 24px; margin: 0; position: relative; flex: 1; display: flex; flex-direction: column; gap: 14px; }
  .ph-timeline::before { content: ""; position: absolute; left: 8px; top: 4px; bottom: 4px; width: 2px; background: var(--color-border); }
  .ph-timeline li { position: relative; display: flex; gap: 6px; align-items: baseline; font-size: 13px; }
  .ph-timeline .dot { position: absolute; left: -19px; top: 4px; width: 12px; height: 12px; border-radius: 999px; border: 2px solid var(--color-cream); }
  .d-vet { background: #6FB67A; }
  .d-train { background: var(--color-ochre); }
  .d-shoe { background: var(--color-bark); }
  .d-note { background: #B14848; }
  .ph-timeline small { color: var(--color-fg-muted); margin-left: 4px; font-size: 11px; }

  /* Mobile */
  .ph-mobile { display: flex; align-items: center; justify-content: center; gap: 2rem; height: 100%; }
  .ph-phone { width: 200px; aspect-ratio: 9/19; background: var(--color-bark); border-radius: 28px; padding: 6px; box-shadow: var(--shadow-warm); }
  .ph-phone-screen { background: var(--color-cream); border-radius: 22px; height: 100%; padding: 20px 12px; display: flex; flex-direction: column; gap: 8px; }
  .ph-offline { background: rgba(168,149,107,0.16); padding: 6px 10px; border-radius: 8px; font-size: 10px; }
  .ph-mob-card { background: white; border-radius: 10px; padding: 10px; }
  .ph-mob-action { background: var(--color-bark); color: var(--color-cream); border-radius: 10px; text-align: center; padding: 10px; font-size: 11px; margin-top: auto; }
  .ph-mobile-callout { display: inline-flex; align-items: center; gap: 8px; padding: 10px 16px; background: white; border: 1px solid var(--color-border); border-radius: 999px; font-size: 12px; }
  .ph-mobile-callout .dot { width: 6px; height: 6px; border-radius: 999px; background: #6FB67A; animation: pulseDot 2s infinite; }

  /* Booking */
  .ph-book { background: white; border-radius: 14px; height: 100%; padding: 0; overflow: hidden; max-width: 32rem; margin: 0 auto; width: 100%; border: 1px solid var(--color-border); }
  .ph-book-head { background: var(--color-sand-light); padding: 10px 14px; font-size: 12px; color: var(--color-fg-muted); border-bottom: 1px solid var(--color-border); font-family: var(--font-mono); }
  .ph-book-body { padding: 16px; }
  .ph-book-month { font-weight: 500; margin-bottom: 12px; }
  .ph-book-grid { display: grid; grid-template-columns: repeat(7, 1fr); gap: 4px; }
  .ph-day-head { font-size: 10px; text-align: center; color: var(--color-fg-muted); padding: 4px; }
  .ph-day { aspect-ratio: 1; border-radius: 8px; background: var(--color-sand-light); display: flex; align-items: center; justify-content: center; font-size: 12px; cursor: pointer; transition: background 0.2s; }
  .ph-day:hover { background: var(--color-bark); color: var(--color-cream); }
  .ph-day.is-busy { background: rgba(177,72,72,0.12); color: rgba(177,72,72,0.7); pointer-events: none; }

  /* AI */
  .ph-ai { display: flex; flex-direction: column; gap: 1rem; padding: 2rem; max-width: 36rem; margin: 0 auto; width: 100%; }
  .ph-ai-bubble { padding: 1rem 1.25rem; border-radius: 18px; font-size: 14px; line-height: 1.5; max-width: 80%; }
  .ph-ai-bubble.user { align-self: flex-end; background: var(--color-bark); color: var(--color-cream); border-bottom-right-radius: 4px; }
  .ph-ai-bubble.bot { align-self: flex-start; background: white; border: 1px solid var(--color-border); border-bottom-left-radius: 4px; }
  .ph-ai-typing { display: flex; gap: 4px; margin-bottom: 8px; }
  .ph-ai-typing span { width: 6px; height: 6px; border-radius: 999px; background: var(--color-ochre); animation: typing 1.4s infinite ease-in-out both; }
  .ph-ai-typing span:nth-child(2) { animation-delay: .2s; }
  .ph-ai-typing span:nth-child(3) { animation-delay: .4s; }
  @keyframes typing {
    0%, 80%, 100% { opacity: 0.3; transform: scale(0.8); }
    40% { opacity: 1; transform: scale(1); }
  }
</style>

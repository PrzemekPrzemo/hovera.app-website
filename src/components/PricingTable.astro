---
import { type Locale, localizePath } from '../i18n/utils';
import PricingCalculator from './PricingCalculator.astro';
interface Props { locale: Locale; }
const { locale } = Astro.props;
const lp = (p: string) => localizePath(p, locale);
const t = (pl: string, en: string) => (locale === 'pl' ? pl : en);

const onboardingItems = locale === 'pl' ? [
  'Spotkanie 90 min: zrozumiemy Twoją stajnię, ułożymy plan migracji',
  'Import danych z Excela / arkusza Google / innego systemu',
  'Konfiguracja kalendarza, instruktorów, koni i klientów',
  'Setup karnetów, cenników i polityki anulowania',
  'Ustawienie publicznej strony stajni i bookingu online',
  'Konfiguracja powiadomień email + SMS',
  'Szkolenie zespołu (do 5 osób w ramach planów Stable / Pro)',
] : [
  '90 min onboarding call: we map your stable and the migration',
  'Data import from Excel / Google Sheets / another system',
  'Calendar, instructors, horses and clients configured',
  'Pass packages, pricing and cancellation policy setup',
  'Public stable page and online booking configured',
  'Email + SMS notifications setup',
  'Team training (up to 5 people on Stable / Pro plans)',
];

const UNL = t('bez limitu', 'unlimited');
const allFeatures = locale === 'pl' ? [
  { name: 'Konie', values: ['5', '10', '30', '100', UNL] },
  { name: 'Klienci', values: ['10', '30', '100', UNL, UNL] },
  { name: 'Pracownicy / instruktorzy', values: ['1', '1', '5', UNL, UNL] },
  { name: 'Kalendarz multi-resource', values: ['✓', '✓', '✓', '✓', '✓'] },
  { name: 'Booking online', values: ['20/mc', '✓', '✓', '✓', '✓'] },
  { name: 'Karnety + auto-rozliczanie', values: ['—', '—', '✓', '✓', '✓'] },
  { name: 'Faktury KSeF + Peppol', values: ['—', '—', '✓', '✓', '✓'] },
  { name: 'Eksport do biura rachunkowego', values: ['—', '—', '✓', '✓', '✓'] },
  { name: 'Pasza i żywienie', values: ['—', '—', '✓', '✓', '✓'] },
  { name: 'Pensjonat / livery + portal właściciela', values: ['—', '—', '—', '✓', '✓'] },
  { name: 'Hodowla i dziennik źrebaków', values: ['—', '—', '✓', '✓', '✓'] },
  { name: 'Public API + webhooks', values: ['—', '—', '—', '✓', '✓'] },
  { name: 'AuditLog (GoBD / RODO)', values: ['—', '—', '—', '✓', '✓'] },
  { name: 'SLA 99,9% + 24/7', values: ['—', '—', '—', '—', '✓'] },
  { name: 'Dedykowany account manager', values: ['—', '—', '—', '—', '✓'] },
  { name: 'Custom domena', values: ['—', '—', '+29 zł', '+29 zł', '✓'] },
  { name: 'Wsparcie', values: ['Email', 'Email', 'Email + chat', 'Priority', 'Dedicated 24/7'] },
] : [
  { name: 'Horses', values: ['5', '10', '30', '100', UNL] },
  { name: 'Clients', values: ['10', '30', '100', UNL, UNL] },
  { name: 'Staff / instructors', values: ['1', '1', '5', UNL, UNL] },
  { name: 'Multi-resource calendar', values: ['✓', '✓', '✓', '✓', '✓'] },
  { name: 'Online booking', values: ['20/mo', '✓', '✓', '✓', '✓'] },
  { name: 'Passes + auto-settlement', values: ['—', '—', '✓', '✓', '✓'] },
  { name: 'E-invoicing (KSeF + Peppol)', values: ['—', '—', '✓', '✓', '✓'] },
  { name: 'Bookkeeping export', values: ['—', '—', '✓', '✓', '✓'] },
  { name: 'Feed & nutrition', values: ['—', '—', '✓', '✓', '✓'] },
  { name: 'Boarding + owner portal', values: ['—', '—', '—', '✓', '✓'] },
  { name: 'Breeding & foal journal', values: ['—', '—', '✓', '✓', '✓'] },
  { name: 'Public API + webhooks', values: ['—', '—', '—', '✓', '✓'] },
  { name: 'AuditLog (GoBD / GDPR)', values: ['—', '—', '—', '✓', '✓'] },
  { name: 'SLA 99.9% + 24/7', values: ['—', '—', '—', '—', '✓'] },
  { name: 'Dedicated account manager', values: ['—', '—', '—', '—', '✓'] },
  { name: 'Custom domain', values: ['—', '—', '+€7', '+€7', '✓'] },
  { name: 'Support', values: ['Email', 'Email', 'Email + chat', 'Priority', 'Dedicated 24/7'] },
];

const faqs = locale === 'pl' ? [
  { q: 'Czy ceny są netto?', a: 'Tak. Wszystkie ceny w cenniku są podane netto. Doliczamy 23% VAT zgodnie z polskimi przepisami. Klienci z UE z ważnym numerem VAT UE — odwrotne obciążenie (VAT 0%). Klienci spoza UE — zwykle bez VAT.' },
  { q: 'Czym różni się plan Start od reszty?', a: 'Start to wejście dla hobbystycznych stajni i pojedynczych instruktorów: 50 zł/mc netto za podstawowy kalendarz, dziennik konia i 20 rezerwacji online miesięcznie. Bez karnetów, bez faktur KSeF. Dla małej szkółki wybierz Solo (99 zł).' },
  { q: 'Czy mogę zmienić plan w każdej chwili?', a: 'Tak. Upgrade jest natychmiastowy z proporcjonalnym rozliczeniem. Downgrade działa od kolejnego okresu rozliczeniowego.' },
  { q: 'Co obejmuje opłata wdrożeniowa 1 590 zł?', a: 'Spotkanie 90 min, import danych, konfiguracja kalendarza i karnetów, setup publicznej strony stajni, powiadomień i szkolenie do 5 osób. Jednorazowo, niezależnie od planu i okresu. W planie Enterprise wdrożenie indywidualne, wliczone w cenę.' },
  { q: 'Co znaczy „blokada ceny"?', a: 'Jeśli za rok podniesiemy cennik, Twoja stawka zostaje. Lock pricing działa przy każdej umowie rocznej, 2- i 3-letniej na cały okres jej trwania.' },
  { q: 'Ile zaoszczędzę na umowie wieloletniej?', a: 'Rocznie cena jest niższa niż 12 × miesięczna (np. Solo: 990 zł rocznie vs 99 × 12 = 1 188 zł). 2- i 3-letnie umowy dają dodatkowo -5% / -10% od ceny rocznej, z blokadą ceny na cały okres.' },
  { q: 'Co się dzieje, gdy przekroczę limit koni lub klientów?', a: 'Zaproponujemy upgrade, ale Twoje dane nie znikną — system po prostu poprosi o zwiększenie limitu. Bez ukrytego ucięcia funkcjonalności.' },
  { q: 'Plan Enterprise — co dokładnie?', a: 'Bez limitu koni, klientów i instruktorów. Wszystko z planu Pro plus: SLA 99,9%, 24/7 wsparcie, dedykowany account manager, wdrożenie on-site, niestandardowe integracje (SSO, white-label, ERP). Wycena indywidualna — zapytaj o stawkę.' },
  { q: 'Czy potrzebuję podpisać umowę?', a: 'Nie. Akceptujesz Regulamin online i działasz. Dla planu Enterprise mamy odrębną umowę ramową.' },
  { q: 'Jak wygląda 30-dniowa gwarancja zwrotu?', a: 'Jeśli w ciągu pierwszych 30 dni zdecydujesz, że to nie dla Ciebie, zwracamy 100% opłaty (włącznie z opłatą wdrożeniową) bez pytań.' },
] : [
  { q: 'Are prices VAT-inclusive?', a: 'No. All prices are net. 23% Polish VAT applies to invoices issued from Poland. EU B2B customers with a valid VAT ID — reverse charge (0% VAT). Non-EU customers — usually 0% VAT.' },
  { q: 'How is Start different from the rest?', a: 'Start is the entry tier for hobby stables and single instructors: €15/mo net for basic calendar, horse journal and 20 online bookings per month. No passes, no e-invoicing. For a small riding school pick Solo (€29).' },
  { q: 'Can I change my plan at any time?', a: 'Yes. Upgrades are instant with prorated billing. Downgrades take effect at the next billing period.' },
  { q: 'What does the onboarding fee cover?', a: '90-min call, data import, calendar and passes setup, public stable page, notifications, and team training for up to 5 people. One-time, regardless of plan or billing period. Enterprise gets a custom rollout included in the contract.' },
  { q: 'What does "price lock" mean?', a: "If we raise list prices next year, your rate stays the same. Price lock applies on every yearly, 2- and 3-year contract for the full term." },
  { q: 'How much do I save on a multi-year contract?', a: 'Yearly is already cheaper than 12 × monthly (e.g. Solo: €290/yr vs €29 × 12 = €348). 2- and 3-year contracts add an extra -5% / -10% on top of the yearly rate, with a price lock for the entire term.' },
  { q: 'What happens if I exceed horse or client limits?', a: "We'll suggest an upgrade — your data stays. The system simply prompts a higher limit." },
  { q: 'Enterprise plan — what exactly?', a: 'No limits on horses, clients or instructors. Everything in Pro plus: 99.9% SLA, 24/7 support, dedicated account manager, on-site rollout, custom integrations (SSO, white-label, ERP). Individual quote — ask us for a number.' },
  { q: 'Do I need to sign a contract?', a: 'No. You accept Terms online and you are good to go. Enterprise customers get a framework agreement.' },
  { q: 'How does the 30-day money-back guarantee work?', a: "Within the first 30 days you get 100% refund — including the onboarding fee — no questions asked." },
];

const setupFeeDisplay =
  locale === 'pl' ? '1 590 zł' :
  locale === 'de' ? '€490' :
  locale === 'fr' ? '€490' : '€490 / £429 / A$790 / NZ$850';
---

<section class="container-x">
  <PricingCalculator locale={locale} variant="full" />

  <div class="roi-banner mt-10" data-reveal>
    <div>
      <span class="eyebrow">{t('Nie wiesz co wybrać?', 'Not sure which plan?')}</span>
      <h3 class="text-2xl font-medium mt-2">{t('Policz, ile Hovera Ci zaoszczędzi.', 'See how much Hovera saves you.')}</h3>
      <p class="muted mt-2">{t('Interaktywny kalkulator oszczędności i zwrotu z inwestycji. 30 sekund.', 'Interactive savings & ROI calculator. 30 seconds.')}</p>
    </div>
    <a href={lp('/kalkulator-roi')} class="btn btn-primary">
      {t('Otwórz kalkulator', 'Open calculator')}
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
        <path d="M3 7h8m-3-3l3 3-3 3" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </a>
  </div>

  <div class="onboarding-section mt-16" data-reveal>
    <div class="onboarding-grid">
      <div>
        <span class="eyebrow">{t('Wdrożenie', 'Onboarding')}</span>
        <h3 class="display-3 mt-3 text-balance">{t('Setup, który robimy za Ciebie', 'Setup we do for you')}</h3>
        <p class="muted mt-4">
          {t(
            'Jednorazowa opłata wdrożeniowa 1 590 zł doliczana do każdego płatnego planu — niezależnie od okresu rozliczeniowego. Pokrywa pełen onboarding: import danych, konfigurację, szkolenie zespołu. Plan Enterprise ma indywidualny scope.',
            'A one-time €390 onboarding fee added to every paid plan, regardless of billing period. Covers full onboarding: data import, setup, team training. Enterprise scoped individually.'
          )}
        </p>
        <div class="setup-price-box">
          <div class="text-xs muted">{t('Opłata wdrożeniowa (jednorazowa)', 'Onboarding fee (one-time)')}</div>
          <div class="text-3xl font-medium mt-1" style="letter-spacing: -0.03em;">{setupFeeDisplay}</div>
          <div class="text-xs mt-2 muted">
            {t('Doliczana do pierwszej faktury, niezależnie od planu', 'Added to your first invoice on every paid plan')}
          </div>
        </div>
      </div>

      <div>
        <h4 class="text-sm font-medium uppercase tracking-widest" style="color: var(--color-fg-muted);">{t('Co dostajesz', 'What you get')}</h4>
        <ul class="onboarding-list mt-4">
          {onboardingItems.map((item) => (
            <li>
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                <path d="M3 7.5l2.5 2.5L11 4.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>

  <div class="mt-20" data-reveal>
    <h3 class="display-3 text-center">{t('Pełne porównanie funkcji', 'Full feature comparison')}</h3>
    <div class="comp-table mt-8">
      <div class="ct-row ct-head ct-row-5">
        <div></div>
        <div>Start</div>
        <div>Solo</div>
        <div class="ct-popular">Stable</div>
        <div>Pro</div>
        <div class="ct-enterprise">Enterprise</div>
      </div>
      {allFeatures.map((row) => (
        <div class="ct-row ct-row-5">
          <div class="ct-name">{row.name}</div>
          {row.values.map((v, i) => (
            <div class={i === 2 ? 'ct-popular' : i === 4 ? 'ct-enterprise' : ''}>{v}</div>
          ))}
        </div>
      ))}
    </div>
  </div>

  <div class="mt-20" data-reveal>
    <h3 class="display-3 text-center">{t('Pytania o cennik', 'Pricing FAQ')}</h3>
    <div class="faq-list mt-8 max-w-3xl mx-auto">
      {faqs.map((f) => (
        <details class="faq-item">
          <summary>
            <span>{f.q}</span>
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
              <path d="M2 5l5 5 5-5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </summary>
          <p class="muted">{f.a}</p>
        </details>
      ))}
    </div>
  </div>

  <div class="guarantee mt-20" data-reveal>
    <div class="g-icon">
      <svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.5">
        <path d="M16 4l10 4v8c0 6.5-4.5 10.5-10 12-5.5-1.5-10-5.5-10-12V8l10-4z"/>
        <path d="M11 16l3.5 3.5L21 13" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </div>
    <div>
      <h4 class="text-xl font-medium">{t('30-dniowa gwarancja zwrotu', '30-day money-back guarantee')}</h4>
      <p class="muted mt-1">{t('Pełen zwrot — łącznie z opłatą wdrożeniową — bez pytań.', 'Full refund, including the onboarding fee, no questions asked.')}</p>
    </div>
  </div>
</section>

<style>
  .enterprise-card { display: flex; flex-direction: column; gap: 1.5rem; padding: 2.5rem; border: 1px solid var(--color-border); border-radius: var(--radius-2xl); background: linear-gradient(135deg, var(--color-sand-light) 0%, var(--color-cream) 100%); }
  @media (min-width: 800px) { .enterprise-card { flex-direction: row; align-items: center; justify-content: space-between; } }
  .ec-cta { text-align: center; }
  .roi-banner { display: flex; flex-direction: column; gap: 1.5rem; padding: 2rem 2.5rem; border-radius: var(--radius-2xl); background: radial-gradient(800px 200px at 0% 50%, rgba(168, 149, 107, 0.18), transparent 70%), var(--color-cream); border: 1px solid var(--color-border); box-shadow: var(--shadow-soft); }
  @media (min-width: 800px) { .roi-banner { flex-direction: row; align-items: center; justify-content: space-between; } }
  .onboarding-grid { display: grid; gap: 3rem; grid-template-columns: 1fr; padding: 2.5rem; background: var(--color-cream); border: 1px solid var(--color-border); border-radius: var(--radius-2xl); }
  @media (min-width: 900px) { .onboarding-grid { grid-template-columns: 1fr 1.2fr; gap: 4rem; } }
  .setup-price-box { margin-top: 1.5rem; padding: 1.25rem 1.5rem; background: var(--color-sand-light); border-radius: 14px; display: inline-block; }
  .onboarding-list { list-style: none; padding: 0; display: flex; flex-direction: column; gap: 0.7rem; }
  .onboarding-list li { display: flex; gap: 0.6rem; align-items: flex-start; font-size: 0.95rem; line-height: 1.5; }
  .onboarding-list svg { color: var(--color-ochre); flex-shrink: 0; margin-top: 0.4rem; }
  .comp-table { border-radius: var(--radius-xl); border: 1px solid var(--color-border); overflow: hidden; background: var(--color-cream); }
  .ct-row { display: grid; grid-template-columns: 2fr 1fr 1fr 1fr 1fr 1fr; border-bottom: 1px solid var(--color-border); font-size: 0.9rem; }
  .ct-row:last-child { border-bottom: none; }
  .ct-head { background: var(--color-sand-light); font-weight: 500; text-transform: uppercase; font-size: 0.7rem; letter-spacing: 0.18em; }
  .ct-row > div { padding: 0.85rem 1rem; border-right: 1px solid var(--color-border); text-align: center; }
  .ct-row > div:first-child { text-align: left; }
  .ct-row > div:last-child { border-right: none; }
  .ct-popular { background: rgba(168,149,107,0.08); font-weight: 500; }
  .ct-enterprise { background: rgba(61,46,34,0.06); font-weight: 500; }
  .ct-name { color: var(--color-fg); }
  @media (max-width: 700px) { .comp-table { font-size: 0.72rem; } .ct-row { grid-template-columns: 1.6fr 0.85fr 0.85fr 0.85fr 0.85fr 0.85fr; } .ct-row > div { padding: 0.5rem 0.3rem; } }
  .faq-list { display: flex; flex-direction: column; gap: 0.5rem; }
  .faq-item { background: var(--color-cream); border: 1px solid var(--color-border); border-radius: 14px; }
  .faq-item summary { list-style: none; cursor: pointer; padding: 1rem 1.25rem; display: flex; justify-content: space-between; align-items: center; font-weight: 500; }
  .faq-item summary::-webkit-details-marker { display: none; }
  .faq-item summary svg { transition: transform 0.3s; }
  .faq-item[open] summary svg { transform: rotate(180deg); }
  .faq-item p { padding: 0 1.25rem 1.1rem; line-height: 1.6; }
  .guarantee { display: flex; gap: 1.25rem; align-items: center; padding: 1.5rem 2rem; border: 1px solid var(--color-border); border-radius: var(--radius-xl); background: rgba(111,182,122,0.08); max-width: 36rem; margin: 0 auto; }
  .g-icon { width: 56px; height: 56px; border-radius: 14px; background: rgba(111,182,122,0.18); color: #2c5530; display: inline-flex; align-items: center; justify-content: center; flex-shrink: 0; }
  .g-icon svg { width: 28px; height: 28px; }
</style>

---
import { type Locale, localizePath } from '../i18n/utils';
import PricingCalculator from './PricingCalculator.astro';
interface Props { locale: Locale; }
const { locale } = Astro.props;
const lp = (p: string) => localizePath(p, locale);
const t = (pl: string, en: string) => (locale === 'pl' ? pl : en);

const onboardingItems = locale === 'pl' ? [
  'Spotkanie 90 min: zrozumiemy Twoj─ů stajni─Ö, u┼éo┼╝ymy plan migracji',
  'Import danych z Excela / arkusza Google / innego systemu',
  'Konfiguracja kalendarza, instruktor├│w, koni i klient├│w',
  'Setup karnet├│w, cennik├│w i polityki anulowania',
  'Ustawienie publicznej strony stajni i bookingu online',
  'Konfiguracja powiadomie┼ä email + SMS',
  'Szkolenie zespo┼éu (do 5 os├│b w ramach plan├│w Stable / Pro)',
] : [
  '90 min onboarding call: we map your stable and the migration',
  'Data import from Excel / Google Sheets / another system',
  'Calendar, instructors, horses and clients configured',
  'Pass packages, pricing and cancellation policy setup',
  'Public stable page and online booking configured',
  'Email + SMS notifications setup',
  'Team training (up to 5 people on Stable / Pro plans)',
];

const allFeatures = locale === 'pl' ? [
  { name: 'Konie', values: ['5', '10', '30', '100'] },
  { name: 'Klienci', values: ['10', '30', '100', t('bez limitu', 'unlimited')] },
  { name: 'Pracownicy / instruktorzy', values: ['1', '1', '5', t('bez limitu', 'unlimited')] },
  { name: 'Kalendarz multi-resource', values: ['Ôťô', 'Ôťô', 'Ôťô', 'Ôťô'] },
  { name: 'Booking online', values: ['ÔÇö', 'Ôťô', 'Ôťô', 'Ôťô'] },
  { name: 'Karnety + auto-rozliczanie', values: ['ÔÇö', 'ÔÇö', 'Ôťô', 'Ôťô'] },
  { name: 'Faktury i rozliczenia', values: ['ÔÇö', 'ÔÇö', 'Ôťô', 'Ôťô'] },
  { name: 'Eksport do biura rachunkowego', values: ['ÔÇö', 'ÔÇö', 'Ôťô', 'Ôťô'] },
  { name: 'Pensjonat / livery + portal w┼éa┼Ťciciela', values: ['ÔÇö', 'ÔÇö', 'ÔÇö', 'Ôťô'] },
  { name: 'Hodowla i dziennik ┼║rebak├│w', values: ['ÔÇö', 'ÔÇö', 'Ôťô', 'Ôťô'] },
  { name: 'Public API + webhooks', values: ['ÔÇö', 'ÔÇö', 'ÔÇö', 'Ôťô'] },
  { name: 'Custom domena', values: ['ÔÇö', 'ÔÇö', '+29 z┼é', '+29 z┼é'] },
  { name: 'Wsparcie', values: ['Community', 'Email', 'Email + chat', 'Priority'] },
] : [
  { name: 'Horses', values: ['5', '10', '30', '100'] },
  { name: 'Clients', values: ['10', '30', '100', 'unlimited'] },
  { name: 'Staff / instructors', values: ['1', '1', '5', 'unlimited'] },
  { name: 'Multi-resource calendar', values: ['Ôťô', 'Ôťô', 'Ôťô', 'Ôťô'] },
  { name: 'Online booking', values: ['ÔÇö', 'Ôťô', 'Ôťô', 'Ôťô'] },
  { name: 'Passes + auto-settlement', values: ['ÔÇö', 'ÔÇö', 'Ôťô', 'Ôťô'] },
  { name: 'Invoicing & billing', values: ['ÔÇö', 'ÔÇö', 'Ôťô', 'Ôťô'] },
  { name: 'Bookkeeping export', values: ['ÔÇö', 'ÔÇö', 'Ôťô', 'Ôťô'] },
  { name: 'Boarding + owner portal', values: ['ÔÇö', 'ÔÇö', 'ÔÇö', 'Ôťô'] },
  { name: 'Breeding & foal journal', values: ['ÔÇö', 'ÔÇö', 'Ôťô', 'Ôťô'] },
  { name: 'Public API + webhooks', values: ['ÔÇö', 'ÔÇö', 'ÔÇö', 'Ôťô'] },
  { name: 'Custom domain', values: ['ÔÇö', 'ÔÇö', '+ÔéČ7', '+ÔéČ7'] },
  { name: 'Support', values: ['Community', 'Email', 'Email + chat', 'Priority'] },
];

const faqs = locale === 'pl' ? [
  { q: 'Czy mog─Ö zmieni─ç plan w ka┼╝dej chwili?', a: 'Tak. Upgrade jest natychmiastowy z proporcjonalnym rozliczeniem. Downgrade dzia┼éa od kolejnego okresu rozliczeniowego.' },
  { q: 'Co dok┼éadnie obejmuje op┼éata wdro┼╝eniowa 1 590 z┼é?', a: 'Spotkanie 90 min, import danych, konfiguracja kalendarza i karnet├│w, setup publicznej strony stajni, powiadomie┼ä i szkolenie do 5 os├│b. Pe┼éna lista wy┼╝ej.' },
  { q: 'Czy op┼éata wdro┼╝eniowa jest jednorazowa?', a: 'Tak ÔÇö to jednorazowe 1 590 z┼é, niezale┼╝nie od wybranego planu i okresu. Doliczana do pierwszej faktury.' },
  { q: 'Co znaczy ÔÇ×blokada ceny"?', a: 'Je┼Ťli za rok podniesiemy cennik, Twoja stawka zostaje. Lock pricing dzia┼éa przy ka┼╝dej umowie rocznej, 2- i 3-letniej na ca┼éy okres jej trwania.' },
  { q: 'Ile zaoszcz─Ödz─Ö na umowie wieloletniej?', a: 'Rocznie -10%, 2 lata -20%, 3 lata -30% wzgl─Ödem ceny miesi─Öcznej. Plan Stable p┼éacony 3 lata z g├│ry to 174 z┼é/mc effective vs 249 z┼é/mc miesi─Öcznie ÔÇö oszcz─Ödno┼Ť─ç 30%.' },
  { q: 'Co si─Ö dzieje, gdy przekrocz─Ö limit koni lub klient├│w?', a: 'Zaproponujemy upgrade, ale Twoje dane nie znikn─ů ÔÇö system po prostu poprosi o zwi─Ökszenie limitu. Bez ukrytego uci─Öcia funkcjonalno┼Ťci.' },
  { q: 'Czy potrzebuj─Ö podpisa─ç umow─Ö?', a: 'Nie. Akceptujesz Regulamin online i dzia┼éasz. Dla planu Enterprise mamy odr─Öbn─ů umow─Ö ramow─ů.' },
  { q: 'Jak wygl─ůda 30-dniowa gwarancja zwrotu?', a: 'Je┼Ťli w ci─ůgu pierwszych 30 dni zdecydujesz, ┼╝e to nie dla Ciebie, zwracamy 100% op┼éaty (w┼é─ůcznie z op┼éat─ů wdro┼╝eniow─ů) bez pyta┼ä.' },
] : [
  { q: 'Can I change my plan at any time?', a: 'Yes. Upgrades are instant with prorated billing. Downgrades take effect at the next billing period.' },
  { q: 'What does the onboarding fee include?', a: 'A 90-minute call, data import, calendar and passes setup, public stable page configuration, notifications, and team training for up to 5 people. Full list above.' },
  { q: 'Is the onboarding fee one-time?', a: 'Yes ÔÇö once, regardless of plan or billing period. Added to your first invoice.' },
  { q: 'What does "price lock" mean?', a: "If we raise list prices next year, your rate stays the same. Price lock applies on every yearly, 2- and 3-year contract for the full term." },
  { q: 'How much do I save on a multi-year contract?', a: 'Yearly -10%, 2 years -20%, 3 years -30% off the monthly rate. A 3-year Stable contract works out to about 70% of the monthly list price.' },
  { q: 'What happens if I exceed horse or client limits?', a: "We'll suggest an upgrade ÔÇö your data stays. The system simply prompts a higher limit." },
  { q: 'Do I need to sign a contract?', a: 'No. You accept Terms online and you are good to go. Enterprise customers get a framework agreement.' },
  { q: 'How does the 30-day money-back guarantee work?', a: "Within the first 30 days you get 100% refund ÔÇö including the onboarding fee ÔÇö no questions asked." },
];

const setupFeeDisplay =
  locale === 'pl' ? '1 590 z┼é' :
  locale === 'de' ? 'ÔéČ490' :
  locale === 'fr' ? 'ÔéČ490' : 'ÔéČ490 / ┬ú429 / A$790 / NZ$850';
---

<section class="container-x">
  <PricingCalculator locale={locale} variant="full" />

  <div class="enterprise-card mt-10" data-reveal>
    <div class="ec-content">
      <span class="eyebrow">Enterprise</span>
      <h3 class="display-3 mt-3">{t('Sieci stajni, kluby sportowe, hodowle 100+ koni.', 'Stable networks, sport clubs, 100+ horse breeders.')}</h3>
      <p class="muted mt-3">{t('White-label, multi-location, dedicated support, custom SLA, SSO, dedykowany customer success manager.', 'White-label, multi-location, dedicated support, custom SLA, SSO, dedicated CSM.')}</p>
    </div>
    <div class="ec-cta">
      <a href={lp('/kontakt') + '?plan=Enterprise'} class="btn btn-primary">{t('Skontaktuj si─Ö', 'Contact us')}</a>
      <p class="text-xs muted mt-2">{t('Wycena na zapytanie', 'Custom pricing')}</p>
    </div>
  </div>

  <div class="roi-banner mt-10" data-reveal>
    <div>
      <span class="eyebrow">{t('Nie wiesz co wybra─ç?', 'Not sure which plan?')}</span>
      <h3 class="text-2xl font-medium mt-2">{t('Policz, ile Hovera Ci zaoszcz─Ödzi.', 'See how much Hovera saves you.')}</h3>
      <p class="muted mt-2">{t('Interaktywny kalkulator oszcz─Ödno┼Ťci i zwrotu z inwestycji. 30 sekund.', 'Interactive savings & ROI calculator. 30 seconds.')}</p>
    </div>
    <a href={lp('/kalkulator-roi')} class="btn btn-primary">
      {t('Otw├│rz kalkulator', 'Open calculator')}
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
        <path d="M3 7h8m-3-3l3 3-3 3" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </a>
  </div>

  <div class="onboarding-section mt-16" data-reveal>
    <div class="onboarding-grid">
      <div>
        <span class="eyebrow">{t('Wdro┼╝enie', 'Onboarding')}</span>
        <h3 class="display-3 mt-3 text-balance">{t('Setup, kt├│ry robimy za Ciebie', 'Setup we do for you')}</h3>
        <p class="muted mt-4">
          {t(
            'Jednorazowa op┼éata wdro┼╝eniowa 1 590 z┼é doliczana do ka┼╝dego p┼éatnego planu ÔÇö niezale┼╝nie od okresu rozliczeniowego. Pokrywa pe┼éen onboarding: import danych, konfiguracj─Ö, szkolenie zespo┼éu. Plan Enterprise ma indywidualny scope.',
            'A one-time ÔéČ390 onboarding fee added to every paid plan, regardless of billing period. Covers full onboarding: data import, setup, team training. Enterprise scoped individually.'
          )}
        </p>
        <div class="setup-price-box">
          <div class="text-xs muted">{t('Op┼éata wdro┼╝eniowa (jednorazowa)', 'Onboarding fee (one-time)')}</div>
          <div class="text-3xl font-medium mt-1" style="letter-spacing: -0.03em;">{setupFeeDisplay}</div>
          <div class="text-xs mt-2 muted">
            {t('Doliczana do pierwszej faktury, niezale┼╝nie od planu', 'Added to your first invoice on every paid plan')}
          </div>
        </div>
      </div>

      <div>
        <h4 class="text-sm font-medium uppercase tracking-widest" style="color: var(--color-fg-muted);">{t('Co dostajesz', 'What you get')}</h4>
        <ul class="onboarding-list mt-4">
          {onboardingItems.map((item) => (
            <li>
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                <path d="M3 7.5l2.5 2.5L11 4.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>

  <div class="mt-20" data-reveal>
    <h3 class="display-3 text-center">{t('Pe┼éne por├│wnanie funkcji', 'Full feature comparison')}</h3>
    <div class="comp-table mt-8">
      <div class="ct-row ct-head">
        <div></div>
        <div>Free</div>
        <div>Solo</div>
        <div class="ct-popular">Stable</div>
        <div>Pro</div>
      </div>
      {allFeatures.map((row) => (
        <div class="ct-row">
          <div class="ct-name">{row.name}</div>
          {row.values.map((v, i) => (
            <div class={i === 2 ? 'ct-popular' : ''}>{v}</div>
          ))}
        </div>
      ))}
    </div>
  </div>

  <div class="mt-20" data-reveal>
    <h3 class="display-3 text-center">{t('Pytania o cennik', 'Pricing FAQ')}</h3>
    <div class="faq-list mt-8 max-w-3xl mx-auto">
      {faqs.map((f) => (
        <details class="faq-item">
          <summary>
            <span>{f.q}</span>
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
              <path d="M2 5l5 5 5-5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </summary>
          <p class="muted">{f.a}</p>
        </details>
      ))}
    </div>
  </div>

  <div class="guarantee mt-20" data-reveal>
    <div class="g-icon">
      <svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.5">
        <path d="M16 4l10 4v8c0 6.5-4.5 10.5-10 12-5.5-1.5-10-5.5-10-12V8l10-4z"/>
        <path d="M11 16l3.5 3.5L21 13" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </div>
    <div>
      <h4 class="text-xl font-medium">{t('30-dniowa gwarancja zwrotu', '30-day money-back guarantee')}</h4>
      <p class="muted mt-1">{t('Pe┼éen zwrot ÔÇö ┼é─ůcznie z op┼éat─ů wdro┼╝eniow─ů ÔÇö bez pyta┼ä.', 'Full refund, including the onboarding fee, no questions asked.')}</p>
    </div>
  </div>
</section>

<style>
  .enterprise-card { display: flex; flex-direction: column; gap: 1.5rem; padding: 2.5rem; border: 1px solid var(--color-border); border-radius: var(--radius-2xl); background: linear-gradient(135deg, var(--color-sand-light) 0%, var(--color-cream) 100%); }
  @media (min-width: 800px) { .enterprise-card { flex-direction: row; align-items: center; justify-content: space-between; } }
  .ec-cta { text-align: center; }
  .roi-banner { display: flex; flex-direction: column; gap: 1.5rem; padding: 2rem 2.5rem; border-radius: var(--radius-2xl); background: radial-gradient(800px 200px at 0% 50%, rgba(168, 149, 107, 0.18), transparent 70%), var(--color-cream); border: 1px solid var(--color-border); box-shadow: var(--shadow-soft); }
  @media (min-width: 800px) { .roi-banner { flex-direction: row; align-items: center; justify-content: space-between; } }
  .onboarding-grid { display: grid; gap: 3rem; grid-template-columns: 1fr; padding: 2.5rem; background: var(--color-cream); border: 1px solid var(--color-border); border-radius: var(--radius-2xl); }
  @media (min-width: 900px) { .onboarding-grid { grid-template-columns: 1fr 1.2fr; gap: 4rem; } }
  .setup-price-box { margin-top: 1.5rem; padding: 1.25rem 1.5rem; background: var(--color-sand-light); border-radius: 14px; display: inline-block; }
  .onboarding-list { list-style: none; padding: 0; display: flex; flex-direction: column; gap: 0.7rem; }
  .onboarding-list li { display: flex; gap: 0.6rem; align-items: flex-start; font-size: 0.95rem; line-height: 1.5; }
  .onboarding-list svg { color: var(--color-ochre); flex-shrink: 0; margin-top: 0.4rem; }
  .comp-table { border-radius: var(--radius-xl); border: 1px solid var(--color-border); overflow: hidden; background: var(--color-cream); }
  .ct-row { display: grid; grid-template-columns: 2fr 1fr 1fr 1fr 1fr; border-bottom: 1px solid var(--color-border); font-size: 0.9rem; }
  .ct-row:last-child { border-bottom: none; }
  .ct-head { background: var(--color-sand-light); font-weight: 500; text-transform: uppercase; font-size: 0.7rem; letter-spacing: 0.18em; }
  .ct-row > div { padding: 0.85rem 1rem; border-right: 1px solid var(--color-border); text-align: center; }
  .ct-row > div:first-child { text-align: left; }
  .ct-row > div:last-child { border-right: none; }
  .ct-popular { background: rgba(168,149,107,0.08); font-weight: 500; }
  .ct-name { color: var(--color-fg); }
  @media (max-width: 700px) { .comp-table { font-size: 0.78rem; } .ct-row { grid-template-columns: 1.6fr 1fr 1fr 1fr 1fr; } .ct-row > div { padding: 0.6rem 0.4rem; } }
  .faq-list { display: flex; flex-direction: column; gap: 0.5rem; }
  .faq-item { background: var(--color-cream); border: 1px solid var(--color-border); border-radius: 14px; }
  .faq-item summary { list-style: none; cursor: pointer; padding: 1rem 1.25rem; display: flex; justify-content: space-between; align-items: center; font-weight: 500; }
  .faq-item summary::-webkit-details-marker { display: none; }
  .faq-item summary svg { transition: transform 0.3s; }
  .faq-item[open] summary svg { transform: rotate(180deg); }
  .faq-item p { padding: 0 1.25rem 1.1rem; line-height: 1.6; }
  .guarantee { display: flex; gap: 1.25rem; align-items: center; padding: 1.5rem 2rem; border: 1px solid var(--color-border); border-radius: var(--radius-xl); background: rgba(111,182,122,0.08); max-width: 36rem; margin: 0 auto; }
  .g-icon { width: 56px; height: 56px; border-radius: 14px; background: rgba(111,182,122,0.18); color: #2c5530; display: inline-flex; align-items: center; justify-content: center; flex-shrink: 0; }
  .g-icon svg { width: 28px; height: 28px; }
</style>

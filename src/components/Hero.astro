---
import HorseshoeMark from './HorseshoeMark.astro';
import { useTranslations, localizePath, type Locale } from '../i18n/utils';

interface Props { locale: Locale; }
const { locale } = Astro.props;
const t = useTranslations(locale);
const lp = (p: string) => localizePath(p, locale);

const stats = [
  { value: '12 000+', label: t('social.stat1') },
  { value: '1 200+', label: t('social.stat2') },
  { value: '8 min', label: t('social.stat3') },
];
---

<section class="hovera-hero relative isolate overflow-hidden">
  <!-- Animated mesh background -->
  <div aria-hidden="true" class="hero-mesh"></div>

  <!-- Decorative horseshoe mark -->
  <div aria-hidden="true" class="hero-mark">
    <HorseshoeMark class="h-full w-full text-[var(--color-ochre)] opacity-[0.18]" />
  </div>

  <div class="container-x relative z-10 pt-12 pb-32 md:pt-24 md:pb-40">
    <div class="mx-auto max-w-4xl text-center" data-reveal>
      <span class="eyebrow">
        <span class="h-1.5 w-1.5 rounded-full bg-[var(--color-ochre)]"></span>
        {t('hero.eyebrow')}
      </span>

      <h1 class="display-1 mt-6 text-balance">
        <span class="block">{t('hero.title.line1')}</span>
        <span class="block hero-italic">{t('hero.title.line2')}</span>
      </h1>

      <p class="lead mt-7 mx-auto max-w-2xl text-balance">
        {t('hero.subtitle')}
      </p>

      <div class="mt-9 flex flex-wrap items-center justify-center gap-3">
        <a href={lp('/kontakt')} class="btn btn-primary magnetic">
          {t('hero.cta.primary')}
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
            <path d="M3 7h8m-3-3l3 3-3 3" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </a>
        <a href={lp('/demo')} class="btn btn-secondary">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="currentColor" aria-hidden="true">
            <path d="M4 2.5v9l8-4.5-8-4.5z" />
          </svg>
          {t('hero.cta.secondary')}
        </a>
      </div>

      <p class="mt-5 text-xs muted">{t('hero.note')}</p>

      <a
        href="https://app.hovera.app/demo"
        target="_blank"
        rel="noopener"
        class="hero-demo-link"
        aria-label={t('hero.demo.label')}
      >
        <span class="hero-demo-dot" aria-hidden="true"></span>
        <span>{t('hero.demo.label')}</span>
        <code class="hero-demo-code">demo@hovera.app · demo</code>
        <span aria-hidden="true">→</span>
      </a>
    </div>

    <!-- Animated product mockup -->
    <div class="mt-16 md:mt-24" data-reveal>
      <div class="hero-stage relative mx-auto max-w-6xl">
        <!-- Desktop mockup -->
        <div class="desktop-frame surface-warm">
          <div class="frame-bar">
            <div class="dots"><span></span><span></span><span></span></div>
            <div class="address">app.hovera.app/kalendarz</div>
            <div></div>
          </div>
          <div class="frame-body">
            <div class="cal-toolbar">
              <div class="cal-toolbar-left">
                <span class="cal-tab is-active">{locale === 'pl' ? 'Kalendarz' : 'Calendar'}</span>
                <span class="cal-tab">{locale === 'pl' ? 'Konie' : 'Horses'}</span>
                <span class="cal-tab">{locale === 'pl' ? 'Klienci' : 'Clients'}</span>
                <span class="cal-tab">{locale === 'pl' ? 'Karnety' : 'Passes'}</span>
                <span class="cal-tab">{locale === 'pl' ? 'Faktury' : 'Invoices'}</span>
              </div>
              <div class="cal-toolbar-right">
                <span class="cal-pill">{locale === 'pl' ? 'Tydzień' : 'Week'}</span>
                <span class="cal-pill is-active">{locale === 'pl' ? 'Dziś' : 'Today'}</span>
              </div>
            </div>
            <div class="cal-grid">
              <div class="cal-col cal-col-head">
                {(locale === 'pl' ? ['Pn 5', 'Wt 6', 'Śr 7', 'Cz 8', 'Pt 9', 'Sb 10', 'Nd 11'] : ['Mon 5', 'Tue 6', 'Wed 7', 'Thu 8', 'Fri 9', 'Sat 10', 'Sun 11']).map((d) => (
                  <div class="cal-day-head">{d}</div>
                ))}
              </div>
              <div class="cal-rows">
                <div class="cal-event" style="--c: #A8956B; --top: 12%; --left: 4%; --w: 11%; --h: 18%;">
                  <span>09:00 · {locale === 'pl' ? 'Anna K.' : 'Anna K.'}</span>
                  <small>{locale === 'pl' ? 'Lot · Halina' : 'Trot · Halina'}</small>
                </div>
                <div class="cal-event drag" style="--c: #3D2E22; --top: 24%; --left: 18%; --w: 11%; --h: 22%;">
                  <span>10:30 · Marek W.</span>
                  <small>{locale === 'pl' ? 'Skok · Atos' : 'Jump · Atos'}</small>
                </div>
                <div class="cal-event" style="--c: #A8956B; --top: 18%; --left: 32%; --w: 11%; --h: 14%;">
                  <span>11:00 · Karolina</span>
                  <small>{locale === 'pl' ? 'Ujeż. · Bonita' : 'Dressage'}</small>
                </div>
                <div class="cal-event conflict" style="--c: #B14848; --top: 36%; --left: 46%; --w: 11%; --h: 18%;">
                  <span>13:00 · Tomek</span>
                  <small>{locale === 'pl' ? 'Konflikt' : 'Conflict'}</small>
                </div>
                <div class="cal-event" style="--c: #A8956B; --top: 22%; --left: 60%; --w: 11%; --h: 26%;">
                  <span>14:00 · Grupa B</span>
                  <small>{locale === 'pl' ? 'Lonża · 4 konie' : 'Lunge · 4 horses'}</small>
                </div>
                <div class="cal-event" style="--c: #6FB67A; --top: 14%; --left: 74%; --w: 11%; --h: 14%;">
                  <span>09:00 · Open</span>
                  <small>{locale === 'pl' ? 'Spacer' : 'Hack'}</small>
                </div>
                <div class="cal-event" style="--c: #A8956B; --top: 30%; --left: 88%; --w: 11%; --h: 18%;">
                  <span>10:00 · Asia</span>
                  <small>{locale === 'pl' ? 'Sk. · Halina' : 'Jump'}</small>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Phone mockup hidden until mobile app is announced -->

        <!-- Floating callouts -->
        <div class="callout callout-1">
          <span class="callout-dot"></span>
          {locale === 'pl' ? 'Konflikt wykryty automatycznie' : 'Conflict detected automatically'}
        </div>
        <div class="callout callout-2">
          <span class="callout-dot"></span>
          {locale === 'pl' ? 'Faktura wysłana do KSeF' : 'Invoice sent to e-invoicing'}
        </div>
      </div>

      <!-- Stats strip -->
      <div class="mt-12 grid grid-cols-3 gap-4 md:gap-8 max-w-3xl mx-auto">
        {stats.map((s) => (
          <div class="text-center">
            <div class="text-2xl md:text-3xl font-medium tracking-tight">{s.value}</div>
            <div class="mt-1 text-xs muted">{s.label}</div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .hovera-hero {
    padding-top: 0;
  }
  .hero-demo-link {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    margin-top: 1.25rem;
    padding: 0.5rem 0.9rem;
    background: var(--color-bark);
    color: var(--color-cream);
    border-radius: 999px;
    font-size: 12px;
    font-weight: 500;
    text-decoration: none;
    transition: transform 0.25s var(--ease-out-expo), box-shadow 0.25s var(--ease-out-expo);
    box-shadow: 0 8px 24px -10px rgba(61,46,34,0.4);
  }
  .hero-demo-link:hover {
    transform: translateY(-1px);
    box-shadow: 0 12px 28px -10px rgba(61,46,34,0.5);
  }
  .hero-demo-dot {
    width: 7px; height: 7px; border-radius: 999px;
    background: #6FB67A;
    box-shadow: 0 0 0 4px rgba(111,182,122,0.25);
    animation: hero-demo-pulse 2.4s ease-in-out infinite;
  }
  @keyframes hero-demo-pulse {
    0%, 100% { box-shadow: 0 0 0 0 rgba(111,182,122,0.45); }
    50% { box-shadow: 0 0 0 6px rgba(111,182,122,0); }
  }
  .hero-demo-code {
    font-family: ui-monospace, SFMono-Regular, monospace;
    background: rgba(250,248,244,0.12);
    padding: 1px 8px;
    border-radius: 6px;
    font-size: 11px;
    letter-spacing: -0.01em;
  }
  .hero-mesh {
    position: absolute;
    inset: -10% -10% auto -10%;
    height: 90%;
    background:
      radial-gradient(circle at 22% 20%, rgba(168, 149, 107, 0.45), transparent 42%),
      radial-gradient(circle at 78% 18%, rgba(232, 221, 208, 0.85), transparent 50%),
      radial-gradient(circle at 50% 60%, rgba(168, 149, 107, 0.18), transparent 60%);
    filter: blur(8px);
    z-index: -1;
    animation: meshFloat 18s ease-in-out infinite alternate;
  }
  @keyframes meshFloat {
    from { transform: translate3d(0,0,0) scale(1); }
    to { transform: translate3d(2%, -2%, 0) scale(1.08); }
  }
  .hero-mark {
    position: absolute;
    width: 40rem;
    height: 40rem;
    top: -10rem;
    right: -12rem;
    pointer-events: none;
    z-index: 0;
    animation: markSpin 60s linear infinite;
  }
  @keyframes markSpin {
    from { transform: rotate(-4deg); }
    to { transform: rotate(4deg); }
  }
  .hero-italic {
    font-family: var(--font-serif);
    font-style: italic;
    font-weight: 400;
    color: var(--color-ochre-dark);
  }

  .hero-stage {
    position: relative;
    aspect-ratio: 16 / 9;
    perspective: 2000px;
  }
  .desktop-frame {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 10;
    border-radius: 18px;
    overflow: hidden;
    transform: rotateX(6deg) rotateY(-2deg);
    transform-origin: 50% 100%;
    transition: transform 0.6s var(--ease-out-expo);
  }
  .desktop-frame:hover { transform: rotateX(2deg) rotateY(0); }
  .frame-bar {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    padding: 10px 14px;
    border-bottom: 1px solid var(--color-border);
    background: linear-gradient(180deg, #fff 0%, var(--color-cream) 100%);
  }
  .dots { display: inline-flex; gap: 6px; }
  .dots span { width: 10px; height: 10px; border-radius: 999px; background: var(--color-sand-dark); }
  .dots span:first-child { background: #E07A6A; }
  .dots span:nth-child(2) { background: #E2C56B; }
  .dots span:last-child { background: #6FB67A; }
  .address {
    font-size: 11px; color: var(--color-fg-muted);
    background: var(--color-sand-light);
    padding: 4px 12px;
    border-radius: 999px;
    font-family: var(--font-mono);
  }

  .frame-body {
    padding: 14px 16px;
    background: var(--color-cream);
  }
  .cal-toolbar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 14px;
    flex-wrap: wrap;
    gap: 8px;
  }
  .cal-toolbar-left { display: inline-flex; gap: 4px; flex-wrap: wrap; }
  .cal-toolbar-right { display: inline-flex; gap: 6px; }
  .cal-tab {
    font-size: 11px;
    padding: 5px 10px;
    border-radius: 999px;
    color: var(--color-fg-muted);
  }
  .cal-tab.is-active {
    background: var(--color-bark);
    color: var(--color-cream);
  }
  .cal-pill {
    font-size: 11px;
    padding: 5px 10px;
    border-radius: 999px;
    border: 1px solid var(--color-border);
  }
  .cal-pill.is-active { background: var(--color-sand-light); }

  .cal-grid {
    border: 1px solid var(--color-border);
    border-radius: 12px;
    background: white;
    overflow: hidden;
  }
  .cal-col-head {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    border-bottom: 1px solid var(--color-border);
  }
  .cal-day-head {
    font-size: 10px;
    text-align: center;
    padding: 6px 4px;
    color: var(--color-fg-muted);
    border-right: 1px solid var(--color-border);
  }
  .cal-day-head:last-child { border-right: none; }
  .cal-rows {
    position: relative;
    height: 220px;
    background-image: repeating-linear-gradient(
      to right,
      transparent 0,
      transparent calc(100% / 7 - 1px),
      var(--color-border) calc(100% / 7 - 1px),
      var(--color-border) calc(100% / 7)
    );
  }
  .cal-event {
    position: absolute;
    top: var(--top);
    left: var(--left);
    width: var(--w);
    height: var(--h);
    background: var(--c);
    color: var(--color-cream);
    border-radius: 6px;
    padding: 4px 6px;
    font-size: 9px;
    line-height: 1.2;
    overflow: hidden;
    box-shadow: 0 2px 6px rgba(61,46,34,0.18);
    animation: eventPop 0.6s var(--ease-out-expo) backwards;
  }
  .cal-event span { display: block; font-weight: 600; }
  .cal-event small { display: block; opacity: 0.85; }
  .cal-event.drag {
    animation: drag 4s ease-in-out infinite;
  }
  .cal-event.conflict {
    animation: pulse 2s ease-in-out infinite;
  }
  @keyframes eventPop {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
  }
  @keyframes drag {
    0%, 100% { transform: translate(0, 0); }
    50% { transform: translate(8px, -4px); box-shadow: 0 8px 20px rgba(61,46,34,0.3); }
  }
  @keyframes pulse {
    0%, 100% { box-shadow: 0 2px 6px rgba(177,72,72,0.4), 0 0 0 0 rgba(177,72,72,0.4); }
    50% { box-shadow: 0 2px 6px rgba(177,72,72,0.4), 0 0 0 8px rgba(177,72,72,0); }
  }

  /* Phone */
  .phone-frame {
    position: absolute;
    right: -2%;
    bottom: -10%;
    width: 22%;
    aspect-ratio: 9 / 19;
    background: var(--color-bark);
    border-radius: 28px;
    padding: 6px;
    box-shadow: var(--shadow-deep);
    transform: rotate(6deg) translateY(0);
    animation: phoneFloat 6s ease-in-out infinite alternate;
  }
  @keyframes phoneFloat {
    from { transform: rotate(6deg) translateY(0); }
    to { transform: rotate(4deg) translateY(-12px); }
  }
  .phone-notch {
    position: absolute;
    top: 12px; left: 50%; transform: translateX(-50%);
    width: 36%; height: 14px;
    background: var(--color-bark);
    border-radius: 999px;
    z-index: 2;
  }
  .phone-screen {
    width: 100%; height: 100%;
    background: linear-gradient(180deg, var(--color-cream) 0%, var(--color-sand-light) 100%);
    border-radius: 22px;
    padding: 22px 12px 12px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .phone-status {
    display: flex; justify-content: space-between;
    font-size: 9px;
    font-weight: 600;
    color: var(--color-fg);
  }
  .phone-card-stack { display: flex; flex-direction: column; gap: 6px; flex: 1; }
  .phone-push {
    display: flex; gap: 6px;
    background: rgba(61,46,34,0.92);
    color: var(--color-cream);
    border-radius: 10px;
    padding: 6px 8px;
    backdrop-filter: blur(8px);
    animation: pushIn 0.8s var(--ease-out-expo) backwards;
    animation-delay: 1.2s;
  }
  @keyframes pushIn {
    from { opacity: 0; transform: translateY(-12px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .phone-push-icon {
    width: 18px; height: 18px;
    display: inline-flex; align-items: center; justify-content: center;
    background: var(--color-ochre);
    border-radius: 4px;
    flex-shrink: 0;
  }
  .phone-push-title { font-size: 9px; font-weight: 600; }
  .phone-push-text { font-size: 8px; opacity: 0.85; line-height: 1.2; }

  .phone-stat { background: white; border-radius: 10px; padding: 8px; }
  .phone-stat-row { display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 6px; }
  .phone-bars { display: flex; align-items: end; gap: 3px; height: 30px; }
  .phone-bar { flex: 1; background: linear-gradient(180deg, var(--color-ochre) 0%, var(--color-ochre-dark) 100%); height: var(--h); border-radius: 2px 2px 0 0; min-height: 4px; }

  .phone-action {
    display: flex; justify-content: space-between; align-items: center;
    background: white;
    border-radius: 10px;
    padding: 8px;
    font-size: 9px;
    font-weight: 500;
  }
  .phone-pill { font-size: 8px; background: var(--color-bark); color: var(--color-cream); padding: 2px 6px; border-radius: 999px; }

  .phone-offline {
    display: inline-flex; align-items: center; gap: 4px;
    font-size: 8px;
    color: var(--color-fg-muted);
    margin-top: auto;
    padding: 4px 6px;
  }
  .phone-offline-dot {
    width: 5px; height: 5px; border-radius: 999px; background: #6FB67A;
    box-shadow: 0 0 0 0 rgba(111,182,122,0.6);
    animation: pulseDot 2s infinite;
  }
  @keyframes pulseDot {
    0% { box-shadow: 0 0 0 0 rgba(111,182,122,0.6); }
    100% { box-shadow: 0 0 0 6px rgba(111,182,122,0); }
  }

  .callout {
    position: absolute;
    background: var(--color-cream);
    border: 1px solid var(--color-border);
    border-radius: 999px;
    padding: 8px 12px;
    font-size: 11px;
    box-shadow: var(--shadow-warm);
    display: inline-flex; align-items: center; gap: 6px;
    animation: floaty 5s ease-in-out infinite alternate;
  }
  .callout-dot { width: 6px; height: 6px; border-radius: 999px; background: var(--color-ochre); }
  .callout-1 {
    top: 35%; left: -2%;
    animation-delay: 0.5s;
  }
  .callout-1 .callout-dot { background: #B14848; }
  .callout-2 {
    bottom: -4%; right: 4%;
    animation-delay: 1.2s;
  }
  .callout-2 .callout-dot { background: #6FB67A; }
  @keyframes floaty {
    from { transform: translateY(0); }
    to { transform: translateY(-8px); }
  }

  @media (max-width: 768px) {
    .desktop-frame { transform: none; }
    .phone-frame { width: 32%; right: -4%; bottom: -16%; }
    .callout-1 { display: none; }
    .callout-2 { font-size: 10px; padding: 6px 10px; }
    .cal-rows { height: 160px; }
  }
</style>

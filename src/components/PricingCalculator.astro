---
import { type Locale, localizePath } from '../i18n/utils';

interface Props {
  locale: Locale;
  variant?: 'full' | 'teaser';
}
const { locale, variant = 'full' } = Astro.props;
const lp = (p: string) => localizePath(p, locale);

const t = (pl: string, en: string) => (locale === 'pl' ? pl : en);

// Pricing per currency. Each paid plan has an explicit { monthly, yearly }
// price; yearly is the amount paid for 12 months billed upfront (already
// discounted vs monthly). 2y and 3y commitments apply an *additional*
// discount on top of yearly (see periods below). Enterprise has no fixed
// price — individual quote. PLN is the authoritative source; other
// currencies are market-positioned placeholders.
const pricesByCurrency = {
  PLN: {
    start:  { monthly: 50,  yearly: 500 },
    solo:   { monthly: 99,  yearly: 990 },
    stable: { monthly: 249, yearly: 2690 },
    pro:    { monthly: 499, yearly: 5390 },
    setup: 1590,
  },
  // EUR: positioned below Equicty (€30-80 Stable) and EquineM (€40-100 Solo).
  EUR: {
    start:  { monthly: 15,  yearly: 150 },
    solo:   { monthly: 25,  yearly: 250 },
    stable: { monthly: 69,  yearly: 750 },
    pro:    { monthly: 139, yearly: 1490 },
    setup: 390,
  },
  // GBP: undercuts Stable Secretary (£24-49) and HorseSmart (£29-89).
  GBP: {
    start:  { monthly: 12,  yearly: 120 },
    solo:   { monthly: 22,  yearly: 220 },
    stable: { monthly: 59,  yearly: 640 },
    pro:    { monthly: 119, yearly: 1280 },
    setup: 349,
  },
  // AUD: below Equestrian Manager AU (A$45-120) and HorseDeskAU (A$55-150).
  AUD: {
    start:  { monthly: 22,  yearly: 220 },
    solo:   { monthly: 45,  yearly: 450 },
    stable: { monthly: 115, yearly: 1240 },
    pro:    { monthly: 229, yearly: 2470 },
    setup: 690,
  },
  // NZD: small market, ~10% premium over AUD to cover overhead.
  NZD: {
    start:  { monthly: 25,  yearly: 250 },
    solo:   { monthly: 49,  yearly: 490 },
    stable: { monthly: 125, yearly: 1350 },
    pro:    { monthly: 249, yearly: 2690 },
    setup: 749,
  },
} as const;
type CurrencyCode = keyof typeof pricesByCurrency;

const currencyMeta: Record<CurrencyCode, { symbol: string; pos: 'before' | 'after'; flag: string; label: string }> = {
  PLN: { symbol: 'zł', pos: 'after',  flag: '🇵🇱', label: 'PLN' },
  EUR: { symbol: '€',  pos: 'before', flag: '🇪🇺', label: 'EUR' },
  GBP: { symbol: '£',  pos: 'before', flag: '🇬🇧', label: 'GBP' },
  AUD: { symbol: 'A$', pos: 'before', flag: '🇦🇺', label: 'AUD' },
  NZD: { symbol: 'NZ$', pos: 'before', flag: '🇳🇿', label: 'NZD' },
};

// Default currency per locale; UI lets the user switch later.
const defaultCurrency: CurrencyCode =
  locale === 'pl' ? 'PLN' :
  locale === 'de' ? 'EUR' :
  locale === 'fr' ? 'EUR' : 'EUR';

// Currencies offered as switchable options for non-PL users.
const switchableCurrencies: CurrencyCode[] =
  locale === 'pl' ? ['PLN'] : ['EUR', 'GBP', 'AUD', 'NZD'];

const p0 = pricesByCurrency[defaultCurrency];

type Tier = {
  key: 'start' | 'solo' | 'stable' | 'pro' | 'enterprise';
  name: string;
  monthly: number;
  yearly: number;
  enterprise?: boolean;
  horses: number;
  clients: number;
  desc: string;
  features: string[];
  popular?: boolean;
};

const baseTiers: Tier[] = locale === 'pl' ? [
  { key: 'start',  name: 'Start',  monthly: p0.start.monthly,  yearly: p0.start.yearly,  horses: 5,   clients: 10,  desc: 'Hobby / pierwsze konie',
    features: ['Kalendarz + 1 arena', 'Dziennik konia (podstawowy)', 'Booking online (limit 20/mc)', 'Wsparcie email'] },
  { key: 'solo',   name: 'Solo',   monthly: p0.solo.monthly,   yearly: p0.solo.yearly,   horses: 10,  clients: 30,  desc: 'Mała szkółka, instruktor solo',
    features: ['Wszystko ze Start', 'Wiele aren i hal', 'Powtarzające się jazdy', 'Powiadomienia SMS', 'Email support'] },
  { key: 'stable', name: 'Stable', monthly: p0.stable.monthly, yearly: p0.stable.yearly, horses: 30,  clients: 100, desc: 'Standardowa stajnia',
    features: ['Wszystko z Solo', 'Karnety + auto-rozliczenie', 'Faktury KSeF + Peppol', 'Eksport do biura', 'Pasza i żywienie', 'Email + chat'], popular: true },
  { key: 'pro',    name: 'Pro',    monthly: p0.pro.monthly,    yearly: p0.pro.yearly,    horses: 100, clients: 9999, desc: 'Pensjonat / sieci stajni',
    features: ['Wszystko ze Stable', 'Pensjonat / livery (boksy, budynki)', 'Multi-instructor + role', 'Public API + webhooks', 'AuditLog (GoBD/RODO)', 'Priority support'] },
  { key: 'enterprise', name: 'Enterprise', monthly: 0, yearly: 0, enterprise: true, horses: 9999, clients: 9999, desc: 'Sieć stajni / hodowla / duża skala',
    features: ['Wszystko z Pro — wszystko w cenie', 'Bez limitu koni i klientów', 'Dedykowany account manager', 'SLA 99,9% + 24/7', 'Wdrożenie on-site', 'Niestandardowe integracje'] },
] : locale === 'de' ? [
  { key: 'start',  name: 'Start',  monthly: p0.start.monthly,  yearly: p0.start.yearly,  horses: 5,   clients: 10,  desc: 'Hobby / erste Pferde',
    features: ['Kalender + 1 Halle', 'Basisches Pferdetagebuch', 'Online-Buchung (Limit 20/Mon.)', 'E-Mail-Support'] },
  { key: 'solo',   name: 'Solo',   monthly: p0.solo.monthly,   yearly: p0.solo.yearly,   horses: 10,  clients: 30,  desc: 'Kleine Schule, Solo-Trainer',
    features: ['Alles aus Start', 'Mehrere Hallen und Plätze', 'Wiederkehrende Termine', 'SMS-Benachrichtigungen', 'E-Mail-Support'] },
  { key: 'stable', name: 'Stable', monthly: p0.stable.monthly, yearly: p0.stable.yearly, horses: 30,  clients: 100, desc: 'Standard-Reitstall',
    features: ['Alles aus Solo', 'Reitkarten + Auto-Abrechnung', 'E-Rechnung KSeF + Peppol', 'DATEV-Export', 'Futter & Ernährung', 'E-Mail + Chat'], popular: true },
  { key: 'pro',    name: 'Pro',    monthly: p0.pro.monthly,    yearly: p0.pro.yearly,    horses: 100, clients: 9999, desc: 'Pension / Stallnetzwerke',
    features: ['Alles aus Stable', 'Pension / Livery (Boxen, Gebäude)', 'Multi-Trainer + Rollen', 'Public API + Webhooks', 'AuditLog (GoBD/DSGVO)', 'Priority Support'] },
  { key: 'enterprise', name: 'Enterprise', monthly: 0, yearly: 0, enterprise: true, horses: 9999, clients: 9999, desc: 'Stallnetzwerk / Zucht / große Anlage',
    features: ['Alles aus Pro — alles inklusive', 'Keine Pferde-/Kundengrenze', 'Dedizierter Account-Manager', 'SLA 99,9% + 24/7', 'On-site Einführung', 'Custom-Integrationen'] },
] : locale === 'fr' ? [
  { key: 'start',  name: 'Start',  monthly: p0.start.monthly,  yearly: p0.start.yearly,  horses: 5,   clients: 10,  desc: 'Loisir / premiers chevaux',
    features: ['Calendrier + 1 manège', 'Carnet du cheval (basique)', 'Réservation en ligne (limite 20/mois)', 'Support e-mail'] },
  { key: 'solo',   name: 'Solo',   monthly: p0.solo.monthly,   yearly: p0.solo.yearly,   horses: 10,  clients: 30,  desc: 'Petit centre, moniteur solo',
    features: ['Tout de Start', 'Plusieurs manèges et carrières', 'Cours récurrents', 'Notifications SMS', 'Support e-mail'] },
  { key: 'stable', name: 'Stable', monthly: p0.stable.monthly, yearly: p0.stable.yearly, horses: 30,  clients: 100, desc: 'Centre équestre standard',
    features: ['Tout de Solo', 'Forfaits + auto-décompte', 'Facturation électronique', 'Export comptable', 'Alimentation', 'E-mail + chat'], popular: true },
  { key: 'pro',    name: 'Pro',    monthly: p0.pro.monthly,    yearly: p0.pro.yearly,    horses: 100, clients: 9999, desc: 'Pension / réseau d\'écuries',
    features: ['Tout de Stable', 'Pension / livery (boxes, bâtiments)', 'Multi-moniteur + rôles', 'API publique + webhooks', 'AuditLog (GoBD/RGPD)', 'Support prioritaire'] },
  { key: 'enterprise', name: 'Enterprise', monthly: 0, yearly: 0, enterprise: true, horses: 9999, clients: 9999, desc: 'Réseau d\'écuries / élevage / grande structure',
    features: ['Tout de Pro — tout inclus', 'Sans limite chevaux/clients', 'Account manager dédié', 'SLA 99,9% + 24/7', 'Mise en route sur place', 'Intégrations sur mesure'] },
] : [
  { key: 'start',  name: 'Start',  monthly: p0.start.monthly,  yearly: p0.start.yearly,  horses: 5,   clients: 10,  desc: 'Hobby / first horses',
    features: ['Calendar + 1 arena', 'Horse journal (basic)', 'Online booking (20/mo limit)', 'Email support'] },
  { key: 'solo',   name: 'Solo',   monthly: p0.solo.monthly,   yearly: p0.solo.yearly,   horses: 10,  clients: 30,  desc: 'Small school, solo instructor',
    features: ['Everything in Start', 'Multiple arenas + paddocks', 'Recurring rides', 'SMS notifications', 'Email support'] },
  { key: 'stable', name: 'Stable', monthly: p0.stable.monthly, yearly: p0.stable.yearly, horses: 30,  clients: 100, desc: 'Standard stable',
    features: ['Everything in Solo', 'Passes + auto-settlement', 'E-invoicing (KSeF + Peppol)', 'Bookkeeping export', 'Feed & nutrition', 'Email + chat'], popular: true },
  { key: 'pro',    name: 'Pro',    monthly: p0.pro.monthly,    yearly: p0.pro.yearly,    horses: 100, clients: 9999, desc: 'Boarding / stable networks',
    features: ['Everything in Stable', 'Boarding (boxes, buildings)', 'Multi-instructor + roles', 'Public API + webhooks', 'AuditLog (GoBD/GDPR)', 'Priority support'] },
  { key: 'enterprise', name: 'Enterprise', monthly: 0, yearly: 0, enterprise: true, horses: 9999, clients: 9999, desc: 'Stable network / breeding / large operation',
    features: ['Everything in Pro — all included', 'No horse/client limit', 'Dedicated account manager', 'SLA 99.9% + 24/7', 'On-site rollout', 'Custom integrations'] },
];

const tiers = baseTiers;
const currency = currencyMeta[defaultCurrency].symbol;
const currencyPos: 'after' | 'before' = currencyMeta[defaultCurrency].pos;
const pricingDataAttr = JSON.stringify(pricesByCurrency);
const currencyMetaAttr = JSON.stringify(currencyMeta);

// Period options. Yearly price per plan is explicit (already discounted vs
// monthly). 2y and 3y apply an *additional* discount on top of yearly.
const periods = locale === 'pl' ? [
  { key: 'monthly', label: 'Miesięcznie', extraDiscount: 0,    months: 1,   note: '' },
  { key: 'yearly',  label: 'Rocznie',     extraDiscount: 0,    months: 12,  note: '' },
  { key: 'two',     label: '2 lata',      extraDiscount: 0.05, months: 24,  note: '-5%' },
  { key: 'three',   label: '3 lata',      extraDiscount: 0.10, months: 36,  note: '-10% ⭐' },
] : locale === 'de' ? [
  { key: 'monthly', label: 'Monatlich', extraDiscount: 0,    months: 1,   note: '' },
  { key: 'yearly',  label: 'Jährlich',  extraDiscount: 0,    months: 12,  note: '' },
  { key: 'two',     label: '2 Jahre',   extraDiscount: 0.05, months: 24,  note: '-5%' },
  { key: 'three',   label: '3 Jahre',   extraDiscount: 0.10, months: 36,  note: '-10% ⭐' },
] : locale === 'fr' ? [
  { key: 'monthly', label: 'Mensuel',   extraDiscount: 0,    months: 1,   note: '' },
  { key: 'yearly',  label: 'Annuel',    extraDiscount: 0,    months: 12,  note: '' },
  { key: 'two',     label: '2 ans',     extraDiscount: 0.05, months: 24,  note: '-5%' },
  { key: 'three',   label: '3 ans',     extraDiscount: 0.10, months: 36,  note: '-10% ⭐' },
] : [
  { key: 'monthly', label: 'Monthly',   extraDiscount: 0,    months: 1,   note: '' },
  { key: 'yearly',  label: 'Yearly',    extraDiscount: 0,    months: 12,  note: '' },
  { key: 'two',     label: '2 years',   extraDiscount: 0.05, months: 24,  note: '-5%' },
  { key: 'three',   label: '3 years',   extraDiscount: 0.10, months: 36,  note: '-10% ⭐' },
];

const setupFee = pricesByCurrency[defaultCurrency].setup;
---

<div
  class="pricing-calc"
  data-pricing-calc
  data-currency={currency}
  data-currency-pos={currencyPos}
  data-setup-fee={setupFee}
  data-default-currency={defaultCurrency}
  data-prices={pricingDataAttr}
  data-currency-meta={currencyMetaAttr}
>
  {switchableCurrencies.length > 1 && (
    <div class="currency-switch" role="tablist" aria-label={t('Wybierz walutę', 'Choose currency')}>
      <span class="currency-label">{t('Waluta', 'Currency')}:</span>
      {switchableCurrencies.map((c) => (
        <button
          type="button"
          class={`currency-btn ${c === defaultCurrency ? 'is-active' : ''}`}
          data-currency-code={c}
          role="tab"
          aria-selected={c === defaultCurrency ? 'true' : 'false'}
        >
          <span class="currency-flag" aria-hidden="true">{currencyMeta[c].flag}</span>
          <span>{currencyMeta[c].label}</span>
        </button>
      ))}
    </div>
  )}

  <!-- Period toggle -->
  <div class="period-toggle" role="tablist" aria-label={t('Wybierz okres rozliczeniowy', 'Choose billing period')}>
    {periods.map((p, i) => (
      <button
        type="button"
        class={`period-btn ${i === 1 ? 'is-active' : ''}`}
        data-period={p.key}
        data-extra-discount={p.extraDiscount}
        data-months={p.months}
        role="tab"
        aria-selected={i === 1 ? 'true' : 'false'}
      >
        <span class="period-label">{p.label}</span>
        {p.note && <span class="period-note">{p.note}</span>}
      </button>
    ))}
  </div>

  <p class="period-hint">
    <span data-period-hint-prefix>
      {t(
        'Do każdego płatnego planu doliczamy jednorazową opłatę wdrożeniową ',
        'A one-time onboarding fee of '
      )}
    </span>
    <strong data-setup-display>{currencyPos === 'before' ? `${currency}${setupFee}` : `${setupFee} ${currency}`}</strong>
    <span data-period-hint-suffix>
      {t(
        '. Płatności roczne, 2- i 3-letnie blokują cenę na cały okres.',
        ' is added to every paid plan. Yearly, 2-year and 3-year plans lock the price for the full term.'
      )}
    </span>
  </p>

  <p class="vat-hint">
    {locale === 'pl' && 'Wszystkie ceny są podane w kwotach netto. Doliczamy 23% VAT zgodnie z polskimi przepisami. Klienci z UE z ważnym numerem VAT UE — odwrotne obciążenie (VAT 0%).'}
    {locale === 'en' && 'All prices are net. 23% Polish VAT applies to invoices issued from Poland. EU B2B customers with a valid VAT ID — reverse charge (0% VAT).'}
    {locale === 'de' && 'Alle Preise verstehen sich netto. 23% polnische MwSt. kommt hinzu. EU-B2B-Kunden mit gültiger USt-IdNr. — Reverse-Charge-Verfahren (0% MwSt.).'}
    {locale === 'fr' && 'Tous les prix sont nets de TVA. TVA polonaise 23% applicable. Clients B2B UE avec numéro de TVA valide — autoliquidation (TVA 0%).'}
  </p>

  <!-- Tier cards -->
  <div class={`tiers-grid ${variant === 'teaser' ? 'tiers-3' : ''}`}>
    {tiers.filter((t) => variant === 'full' || t.key !== 'enterprise').map((tier) => (
      <div
        class={`tier ${tier.popular ? 'tier-popular' : ''} ${tier.enterprise ? 'tier-enterprise' : ''}`}
        data-tier={tier.key}
        data-base-monthly={tier.monthly}
        data-base-yearly={tier.yearly}
      >
        {tier.popular && <span class="tier-badge">{t('Najczęściej wybierany', 'Most popular')}</span>}
        {tier.enterprise && <span class="tier-badge tier-badge--enterprise">{t('Wycena indywidualna', 'Individual quote')}</span>}
        <div class="tier-name">{tier.name}</div>
        <div class="tier-desc muted">{tier.desc}</div>

        <div class="tier-price">
          {tier.enterprise ? (
            <span class="price-num price-num--quote">{t('Zapytaj', 'Get a quote')}</span>
          ) : (
            <>
              <span class="price-num" data-price-effective>{currencyPos === 'before' ? `${currency}${tier.monthly}` : `${tier.monthly} ${currency}`}</span>
              <span class="price-period muted">{t('/ mies.', '/ mo')}</span>
            </>
          )}
        </div>

        {!tier.enterprise && (
          <div class="tier-totals">
            <span class="total-line" data-total-line>
              <span data-total-amount></span>
              <span class="muted" data-total-period></span>
            </span>
            <span class="setup-line" data-setup-line></span>
          </div>
        )}
        {tier.enterprise && (
          <div class="tier-totals">
            <span class="total-line">
              <span class="muted">{t('Wszystko w cenie. Wdrożenie, SLA, dedykowany manager.', 'Everything included. Onboarding, SLA, dedicated manager.')}</span>
            </span>
          </div>
        )}

        <div class="tier-limits">
          <span>{tier.horses}{tier.horses === 9999 ? '+' : ''} {t('koni', 'horses')}</span>
          <span>·</span>
          <span>{tier.clients === 9999 ? t('bez limitu klientów', 'unlimited clients') : `${tier.clients} ${t('klientów', 'clients')}`}</span>
        </div>

        <ul class="tier-features">
          {tier.features.map((f) => (
            <li>
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                <path d="M3 7.5l2.5 2.5L11 4.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              {f}
            </li>
          ))}
        </ul>

        <a
          href={`${lp('/kontakt')}?plan=${tier.name}`}
          class={`btn ${tier.popular || tier.enterprise ? 'btn-primary' : 'btn-secondary'} w-full mt-8`}
          data-cta
        >
          {tier.enterprise ? t('Skontaktuj się z nami', 'Contact us') : t(`Wybierz ${tier.name}`, `Choose ${tier.name}`)}
        </a>
      </div>
    ))}
  </div>
</div>

<style>
  .pricing-calc { width: 100%; }

  .currency-switch {
    display: inline-flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    align-items: center;
    margin: 0 auto 1.25rem;
    padding: 0.4rem 0.8rem;
    background: var(--color-cream);
    border: 1px solid var(--color-border);
    border-radius: 999px;
    font-size: 0.85rem;
    width: max-content;
    max-width: 100%;
  }
  .currency-label { color: var(--color-fg-muted); margin-right: 0.25rem; }
  .currency-btn {
    display: inline-flex; gap: 0.35rem; align-items: center;
    padding: 0.3rem 0.7rem;
    border: 1px solid transparent;
    background: transparent;
    border-radius: 999px;
    font-family: inherit;
    font-size: 0.85rem;
    color: var(--color-fg);
    cursor: pointer;
    transition: background 0.2s, border-color 0.2s, color 0.2s;
  }
  .currency-btn:hover { background: var(--color-sand-light); }
  .currency-btn.is-active {
    background: var(--color-bark);
    color: var(--color-cream);
    border-color: var(--color-bark);
  }
  .currency-flag { font-size: 0.95rem; line-height: 1; }

  .period-toggle {
    display: inline-flex;
    flex-wrap: wrap;
    gap: 0.25rem;
    padding: 0.4rem;
    background: var(--color-cream);
    border: 1px solid var(--color-border);
    border-radius: 999px;
    box-shadow: var(--shadow-soft);
    margin: 0 auto 1rem;
    width: max-content;
    max-width: 100%;
  }
  @media (max-width: 600px) {
    .period-toggle {
      width: 100%;
      justify-content: center;
    }
  }
  .period-btn {
    display: inline-flex; align-items: center; gap: 0.4rem;
    padding: 0.55rem 1rem;
    border: none;
    background: transparent;
    border-radius: 999px;
    font-family: inherit;
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--color-fg);
    cursor: pointer;
    transition: background 0.25s var(--ease-out-expo), color 0.25s var(--ease-out-expo);
    white-space: nowrap;
  }
  .period-btn:hover { background: var(--color-sand-light); }
  .period-btn.is-active {
    background: var(--color-bark);
    color: var(--color-cream);
    box-shadow: var(--shadow-soft);
  }
  .period-note {
    font-size: 11px;
    font-weight: 600;
    padding: 2px 7px;
    border-radius: 999px;
    background: rgba(168,149,107,0.22);
    color: var(--color-ochre-dark);
  }
  .period-btn.is-active .period-note {
    background: var(--color-ochre);
    color: var(--color-bark);
  }
  .period-hint {
    text-align: center;
    font-size: 0.8rem;
    color: var(--color-fg-muted);
    margin-top: 0.4rem;
    margin-bottom: 0.5rem;
  }
  .vat-hint {
    text-align: center;
    font-size: 0.72rem;
    color: var(--color-fg-muted);
    max-width: 44rem;
    margin: 0 auto 2rem;
    line-height: 1.45;
    opacity: 0.85;
  }

  .tiers-grid {
    display: grid;
    gap: 1.25rem;
    grid-template-columns: 1fr;
  }
  @media (min-width: 720px)  { .tiers-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1100px) { .tiers-grid { grid-template-columns: repeat(5, 1fr); } }
  .tiers-grid.tiers-3 { grid-template-columns: 1fr; }
  @media (min-width: 720px)  { .tiers-grid.tiers-3 { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1100px) { .tiers-grid.tiers-3 { grid-template-columns: repeat(4, 1fr); } }

  .tier {
    position: relative;
    padding: 2rem 1.75rem;
    border-radius: var(--radius-xl);
    border: 1px solid var(--color-border);
    background: var(--color-cream);
    box-shadow: var(--shadow-soft);
    display: flex;
    flex-direction: column;
    transition: transform 0.4s var(--ease-out-expo), box-shadow 0.4s var(--ease-out-expo);
  }
  .tier:hover { transform: translateY(-3px); box-shadow: var(--shadow-warm); }
  .tier-popular {
    background: linear-gradient(180deg, var(--color-bark) 0%, #2a2018 100%);
    color: var(--color-cream);
    border-color: var(--color-bark);
    box-shadow: var(--shadow-deep);
  }
  .tier-popular .muted, .tier-popular .price-period { color: rgba(250,248,244,0.65); }
  .tier-badge {
    position: absolute;
    top: -10px; left: 50%; transform: translateX(-50%);
    background: var(--color-ochre);
    color: var(--color-bark);
    font-size: 11px; font-weight: 600;
    padding: 4px 12px;
    border-radius: 999px;
    letter-spacing: 0.04em;
    white-space: nowrap;
  }
  .tier-badge--enterprise {
    background: var(--color-bark);
    color: var(--color-cream);
  }
  .tier-enterprise {
    border-color: var(--color-bark-300, var(--color-bark));
    background: linear-gradient(180deg, var(--color-sand-light) 0%, var(--color-cream) 100%);
  }
  .price-num--quote {
    font-size: 1.4rem;
    color: var(--color-bark);
    font-weight: 600;
    letter-spacing: -0.01em;
  }
  .tier-name { font-size: 11px; font-weight: 500; text-transform: uppercase; letter-spacing: 0.18em; }
  .tier-desc { font-size: 0.82rem; margin-top: 0.25rem; }
  .tier-price {
    margin-top: 1.25rem;
    display: flex; align-items: baseline; gap: 0.4rem;
  }
  .price-num {
    font-size: 2.6rem; line-height: 1; font-weight: 500; letter-spacing: -0.04em;
    transition: opacity 0.25s var(--ease-out-expo);
  }
  .price-period { font-size: 0.85rem; }
  .tier-totals {
    margin-top: 0.5rem;
    min-height: 3.4rem;
  }
  .total-line {
    display: block;
    font-size: 0.78rem;
    color: var(--color-fg-muted);
    line-height: 1.4;
  }
  .tier-popular .total-line { color: rgba(250,248,244,0.7); }
  .setup-line {
    display: block;
    font-size: 0.72rem;
    margin-top: 0.2rem;
    line-height: 1.4;
  }
  .setup-included {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    color: #2c5530;
    font-weight: 500;
  }
  .tier-popular .setup-included { color: #b8e0bc; }
  .setup-extra { color: var(--color-fg-muted); }
  .tier-popular .setup-extra { color: rgba(250,248,244,0.55); }

  .tier-limits {
    margin-top: 1rem;
    padding-top: 1rem;
    padding-bottom: 0.25rem;
    border-top: 1px solid var(--color-border);
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    font-size: 0.85rem;
    color: var(--color-fg-muted);
  }
  .tier-popular .tier-limits {
    border-top-color: rgba(250,248,244,0.18);
    color: rgba(250,248,244,0.7);
  }
  .tier-features { list-style: none; padding: 0; margin-top: 1.25rem; display: flex; flex-direction: column; gap: 0.55rem; flex: 1; }
  .tier-features li { display: flex; gap: 0.5rem; align-items: center; font-size: 0.9rem; }
  .tier-features svg { color: var(--color-ochre); flex-shrink: 0; }
  .tier-popular .tier-features svg { color: var(--color-ochre-light); }
</style>

<script>
  type Period = { key: string; extraDiscount: number; months: number };
  type PlanPrice = { monthly: number; yearly: number };
  type PriceSet = {
    start: PlanPrice; solo: PlanPrice; stable: PlanPrice; pro: PlanPrice; setup: number;
  };
  type CurrencyMeta = { symbol: string; pos: 'before' | 'after'; flag: string; label: string };

  // Map browser country/region → currency code; used for first-visit auto-pick.
  function detectCurrencyFromBrowser(): string | null {
    try {
      const lang = (navigator.language || '').toLowerCase();
      // Region after the dash, e.g. en-GB → GB
      const region = lang.split('-')[1];
      const map: Record<string, string> = {
        gb: 'GBP', uk: 'GBP',
        au: 'AUD',
        nz: 'NZD',
        pl: 'PLN',
      };
      if (region && map[region]) return map[region];
      // Try language-only as a fallback
      const lang2 = lang.split('-')[0];
      if (lang2 === 'pl') return 'PLN';
      return null;
    } catch { return null; }
  }

  function init() {
    const calcs = document.querySelectorAll<HTMLElement>('[data-pricing-calc]');
    calcs.forEach((calc) => {
      const setupBaseAttr = Number(calc.dataset.setupFee || 0);
      let pricesAll: Record<string, PriceSet> = {};
      let metaAll: Record<string, CurrencyMeta> = {};
      try { pricesAll = JSON.parse(calc.dataset.prices || '{}'); } catch {}
      try { metaAll = JSON.parse(calc.dataset.currencyMeta || '{}'); } catch {}

      let currentCode = calc.dataset.defaultCurrency || 'PLN';
      const buttons = calc.querySelectorAll<HTMLButtonElement>('.period-btn');
      const currencyButtons = calc.querySelectorAll<HTMLButtonElement>('.currency-btn');
      const tiers = calc.querySelectorAll<HTMLElement>('.tier[data-base-monthly]');

      const isPL = () => currentCode === 'PLN';
      const tr = (pl: string, en: string) => (isPL() ? pl : en);

      const fmtPrice = (n: number) => {
        const meta = metaAll[currentCode];
        if (!meta) return String(n);
        const rounded = Math.round(n);
        const formatted = isPL()
          ? rounded.toLocaleString('pl-PL').replace(/,/g, ' ')
          : rounded.toLocaleString('en-GB');
        return meta.pos === 'after' ? `${formatted} ${meta.symbol}` : `${meta.symbol}${formatted}`;
      };

      const currentSetupFee = () => (pricesAll[currentCode]?.setup ?? setupBaseAttr);

      const refreshTierBasePrices = () => {
        const ps = pricesAll[currentCode];
        if (!ps) return;
        const planMap: Record<string, PlanPrice | undefined> = {
          start: ps.start, solo: ps.solo, stable: ps.stable, pro: ps.pro,
        };
        tiers.forEach((tier) => {
          const key = tier.dataset.tier || '';
          const plan = planMap[key];
          if (plan) {
            tier.dataset.baseMonthly = String(plan.monthly);
            tier.dataset.baseYearly = String(plan.yearly);
          }
        });
      };

      const refreshSetupHint = () => {
        const setupEl = calc.querySelector<HTMLElement>('[data-setup-display]');
        if (setupEl) setupEl.textContent = fmtPrice(currentSetupFee());
      };

      const update = (period: Period) => {
        const setupFee = currentSetupFee();
        tiers.forEach((tier) => {
          if (tier.classList.contains('tier-enterprise')) return;
          const baseMonthly = Number(tier.dataset.baseMonthly || 0);
          const baseYearly  = Number(tier.dataset.baseYearly || 0);
          if (baseMonthly === 0) return;

          // Per-plan price model:
          //   monthly: pay baseMonthly each month
          //   yearly:  pay baseYearly upfront for 12 months
          //   2y:      pay (baseYearly × 2 × (1 - extraDiscount)) upfront for 24 months
          //   3y:      pay (baseYearly × 3 × (1 - extraDiscount)) upfront for 36 months
          let effectiveMonthly: number;
          let total: number;

          if (period.key === 'monthly') {
            effectiveMonthly = baseMonthly;
            total = baseMonthly;
          } else if (period.key === 'yearly') {
            effectiveMonthly = baseYearly / 12;
            total = baseYearly;
          } else {
            const years = period.months / 12;
            total = baseYearly * years * (1 - period.extraDiscount);
            effectiveMonthly = total / period.months;
          }

          const priceEl = tier.querySelector<HTMLElement>('[data-price-effective]');
          if (priceEl) priceEl.textContent = fmtPrice(effectiveMonthly);

          const totalAmount = tier.querySelector<HTMLElement>('[data-total-amount]');
          const totalPeriod = tier.querySelector<HTMLElement>('[data-total-period]');
          const setupLine = tier.querySelector<HTMLElement>('[data-setup-line]');

          const setupHtml = `<span class="setup-extra">+ ${fmtPrice(setupFee)} ${tr('opłata wdrożeniowa (jednorazowa)', 'onboarding fee (one-time)')}</span>`;

          if (period.key === 'monthly') {
            if (totalAmount) totalAmount.textContent = '';
            if (totalPeriod) totalPeriod.textContent = '';
            if (setupLine) setupLine.innerHTML = setupHtml;
          } else {
            const periodLabel = period.key === 'yearly' ? tr('za rok z góry', 'billed yearly')
              : period.key === 'two' ? tr('za 2 lata z góry', 'billed for 2 years')
              : tr('za 3 lata z góry', 'billed for 3 years');
            const lockMonths = period.key === 'yearly' ? '12' : period.key === 'two' ? '24' : '36';
            if (totalAmount) totalAmount.textContent = `${fmtPrice(total)}`;
            if (totalPeriod) totalPeriod.textContent = ` ${periodLabel}`;
            if (setupLine) {
              setupLine.innerHTML = `${setupHtml}<br/><span class="setup-included">✓ ${tr(`Blokada ceny na ${lockMonths} mc`, `Price locked for ${lockMonths} mo`)}</span>`;
            }
          }
        });
      };

      const getActivePeriod = (): Period => {
        const active = calc.querySelector<HTMLButtonElement>('.period-btn.is-active');
        return {
          key: active?.dataset.period || 'yearly',
          extraDiscount: Number(active?.dataset.extraDiscount || 0),
          months: Number(active?.dataset.months || 12),
        };
      };

      const switchCurrency = (code: string) => {
        if (!pricesAll[code]) return;
        currentCode = code;
        currencyButtons.forEach((b) => {
          const isActive = b.dataset.currencyCode === code;
          b.classList.toggle('is-active', isActive);
          b.setAttribute('aria-selected', isActive ? 'true' : 'false');
        });
        const elPriceNum = calc.querySelectorAll<HTMLElement>('.price-num');
        // Update tier base prices in DOM, then re-render via period update
        refreshTierBasePrices();
        refreshSetupHint();
        // Update Free tier "0 X" display too
        elPriceNum.forEach((el) => {
          if (el.textContent && /^0\s/.test(el.textContent)) {
            el.textContent = fmtPrice(0);
          }
        });
        try { localStorage.setItem('hovera-currency', code); } catch {}
        update(getActivePeriod());
      };

      buttons.forEach((btn) => {
        btn.addEventListener('click', () => {
          buttons.forEach((b) => { b.classList.remove('is-active'); b.setAttribute('aria-selected', 'false'); });
          btn.classList.add('is-active');
          btn.setAttribute('aria-selected', 'true');
          update({
            key: btn.dataset.period || 'yearly',
            extraDiscount: Number(btn.dataset.extraDiscount || 0),
            months: Number(btn.dataset.months || 12),
          });
        });
      });

      currencyButtons.forEach((btn) => {
        btn.addEventListener('click', () => {
          const code = btn.dataset.currencyCode || '';
          if (code) switchCurrency(code);
        });
      });

      // First-load: try saved choice, else auto-detect from browser locale
      try {
        const saved = localStorage.getItem('hovera-currency');
        if (saved && pricesAll[saved] && currencyButtons.length > 1) {
          if (saved !== currentCode) {
            switchCurrency(saved);
            return; // switchCurrency runs update()
          }
        } else if (currencyButtons.length > 1) {
          const detected = detectCurrencyFromBrowser();
          if (detected && pricesAll[detected] && detected !== currentCode) {
            switchCurrency(detected);
            return;
          }
        }
      } catch {}

      // Default render
      update(getActivePeriod());
    });
  }

  init();
  document.addEventListener('astro:page-load', init);
</script>

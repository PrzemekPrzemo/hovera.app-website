---
import Logo from './Logo.astro';
import { useTranslations, localizePath, type Locale } from '../i18n/utils';

interface Props { locale: Locale; }
const { locale } = Astro.props;
const t = useTranslations(locale);
const lp = (p: string) => localizePath(p, locale);

const cols = [
  {
    title: t('footer.product'),
    links: [
      { href: lp('/produkt/kalendarz'), label: t('nav.product.calendar') },
      { href: lp('/produkt/karnety'), label: t('nav.product.passes') },
      { href: lp('/produkt/dziennik-konia'), label: t('nav.product.horse-journal') },
      { href: lp('/produkt/finanse-ksef'), label: t('nav.product.finance') },
      { href: lp('/produkt/zapisy-online'), label: t('nav.product.online-booking') },
      { href: lp('/co-nowego'), label: t('nav.changelog') },
    ],
  },
  {
    title: t('footer.for'),
    links: [
      { href: lp('/dla/szkolki'), label: t('nav.for.school') },
      { href: lp('/dla/pensjonatu'), label: t('nav.for.boarding') },
      { href: lp('/dla/sportu'), label: t('nav.for.sport') },
      { href: lp('/dla/hodowli'), label: t('nav.for.breeding') },
      { href: lp('/dla/sieci-stajni'), label: t('nav.for.network') },
    ],
  },
  {
    title: t('footer.resources'),
    links: [
      { href: lp('/cennik'), label: t('nav.pricing') },
      { href: lp('/kalkulator-roi'), label: locale === 'pl' ? 'Kalkulator ROI' : 'ROI calculator' },
      { href: lp('/integracje'), label: locale === 'pl' ? 'Integracje' : 'Integrations' },
      { href: lp('/demo'), label: t('nav.demo') },
      { href: lp('/blog'), label: 'Blog' },
      { href: lp('/pomoc'), label: locale === 'pl' ? 'Pomoc' : 'Help' },
      { href: lp('/kontakt'), label: locale === 'pl' ? 'Kontakt' : 'Contact' },
    ],
  },
  {
    title: t('footer.company'),
    links: [
      { href: lp('/o-nas'), label: locale === 'pl' ? 'O nas' : 'About' },
      { href: lp('/regulamin'), label: locale === 'pl' ? 'Regulamin' : 'Terms' },
      { href: lp('/polityka-prywatnosci'), label: locale === 'pl' ? 'Polityka prywatności' : 'Privacy' },
      { href: lp('/rodo'), label: 'GDPR / RODO' },
      { href: lp('/cookies'), label: 'Cookies' },
      { href: lp('/dostepnosc'), label: locale === 'pl' ? 'Dostępność' : 'Accessibility' },
    ],
  },
];

const year = new Date().getFullYear();
---

<footer class="hovera-footer relative mt-32 pt-24 pb-10">
  <div class="container-x">
    <div class="grid gap-12 md:grid-cols-12">
      <div class="md:col-span-4">
        <a href={lp('/')} class="inline-flex items-center gap-2 text-2xl">
          <Logo />
        </a>
        <p class="mt-4 max-w-xs text-sm muted">{t('footer.tagline')}</p>
        <div class="mt-6 flex items-center gap-3">
          <a class="footer-social" href="https://www.instagram.com/hovera.app" aria-label="Instagram" rel="noopener" target="_blank">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor"/></svg>
          </a>
        </div>

      </div>

      {cols.map((col) => (
        <div class="md:col-span-2">
          <h4 class="text-[11px] font-medium tracking-[0.18em] uppercase muted">{col.title}</h4>
          <ul class="mt-4 space-y-2.5 text-sm">
            {col.links.map((l) => (
              <li><a class="footer-link" href={l.href}>{l.label}</a></li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <div class="mt-16 flex flex-col items-start justify-between gap-4 border-t pt-6 text-xs md:flex-row md:items-center" style="border-color: var(--color-border);">
      <p class="muted">© {year} Hovera. {locale === 'pl' ? 'Wszystkie prawa zastrzeżone.' : 'All rights reserved.'}</p>
      <p class="muted flex items-center gap-2">
        <span class="h-1.5 w-1.5 rounded-full" style="background: #6FB67A;" aria-hidden="true"></span>
        {locale === 'pl' ? 'Wszystkie systemy działają' : 'All systems operational'}
      </p>
    </div>
  </div>

  <!-- Big wordmark watermark -->
  <div aria-hidden="true" class="pointer-events-none mt-16 overflow-hidden">
    <div class="container-x">
      <div class="hovera-watermark select-none text-center font-medium leading-none tracking-[-0.045em]">
        hovera
      </div>
    </div>
  </div>

  <style>
    .footer-link {
      color: var(--color-fg);
      transition: color 0.2s;
    }
    .footer-link:hover { color: var(--color-ochre-dark); }
    .footer-social {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 36px;
      height: 36px;
      border-radius: 999px;
      border: 1px solid var(--color-border);
      color: var(--color-fg);
      transition: all 0.2s;
    }
    .footer-social:hover {
      background: var(--color-bark);
      color: var(--color-cream);
      border-color: var(--color-bark);
    }
    .badge {
      display: inline-flex;
      align-items: center;
      padding: 0.5rem 0.9rem;
      border: 1px solid var(--color-border);
      border-radius: 999px;
      font-size: 12px;
      transition: all 0.2s;
    }
    .badge:hover {
      background: var(--color-bark);
      color: var(--color-cream);
      border-color: var(--color-bark);
    }
    .hovera-watermark {
      font-size: clamp(6rem, 22vw, 22rem);
      background: linear-gradient(180deg, rgba(168, 149, 107, 0.32) 0%, rgba(168, 149, 107, 0.04) 100%);
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
    }
  </style>
</footer>

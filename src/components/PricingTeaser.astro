---
import { useTranslations, localizePath, type Locale } from '../i18n/utils';
import PricingCalculator from './PricingCalculator.astro';
interface Props { locale: Locale; }
const { locale } = Astro.props;
const t = useTranslations(locale);
const lp = (p: string) => localizePath(p, locale);
const tt = (pl: string, en: string) => (locale === 'pl' ? pl : en);
---

<section class="container-x py-24 md:py-32" data-reveal>
  <header class="mx-auto max-w-3xl text-center">
    <span class="eyebrow">{t('pricing.eyebrow')}</span>
    <h2 class="display-2 mt-4 text-balance">{t('pricing.title')}</h2>
    <p class="lead mt-5">{t('pricing.subtitle')}</p>
  </header>

  <div class="mt-12">
    <PricingCalculator locale={locale} variant="teaser" />
  </div>

  <div class="mt-12 flex flex-col items-center gap-3">
    <a href={lp('/cennik')} class="btn btn-primary">
      {t('pricing.cta')}
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
        <path d="M3 7h8m-3-3l3 3-3 3" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </a>
    <a href={lp('/kalkulator-roi')} class="text-sm muted hover:text-[var(--color-ochre-dark)]">
      {tt('Nie wiesz co wybrać? Otwórz kalkulator ROI →', 'Not sure which plan? Open the ROI calculator →')}
    </a>
  </div>
</section>

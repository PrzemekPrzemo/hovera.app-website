      start: { name: 'Start', desc: 'Petites flottes et transporteurs solo', features: ['Calculateur complet avec routage PL (ORS)', 'Devis PDF + acceptation publique + WhatsApp/email', 'CRM clients avec tarifs personnalisés', 'POI lieux personnalisés + import Google Maps', 'Calendrier transports + flux iCal', 'Page publique d\'entreprise (PL)', 'Paiements + coûts avec import CSV', 'Factures (KSEF et autres)', 'Rapports : chauffeurs, clients, véhicules, trésorerie', 'Support e-mail · réponse en 24h'] },
      pro: { name: 'Pro', desc: 'Flottes en croissance', popular: true, features: ['Tout de Start +', 'Page publique multilingue (PL + EN + DE)', 'Tarifs et montants minimums par client', 'Estimation auto des péages (ORS tollways)', 'Dictionnaire de types d\'arrêt (chargement/déchargement/véto/nuit)', 'Galerie publique avec photos de transports'] },
      business: { name: 'Business', desc: 'Entreprises de transport moyennes et grandes', features: ['Tout de Pro +', 'Branding personnalisé (logo + couleurs sur page et PDF)', 'Rapports avancés : marges, top routes, popularité', 'Export CSV/JSON de toutes les données (RGPD)', 'Tarifs péages configurables (léger vs HGV)', 'Priorité roadmap (votez sur les features)'] },
      enterprise: { name: 'Enterprise', desc: 'Au-delà de 15 chauffeurs / 25 véhicules, ou besoins spéciaux', features: ['Aucune limite. Contrat individuel.', 'Environnement dédié (VPS séparé)', 'SLA 99,9% avec garantie financière', 'Onboarding sur place (2-4h formateur)', 'Migration de données — gratuite', 'White-label (système sous votre marque)', 'API REST pour intégrations', 'Backup vers stockage dédié (S3 / GDrive)', 'Intégrations sur mesure (CRM/ERP/compta)'] },
    },
    limitsLabels: { drivers: 'Chauffeurs', vehicles: 'Véhicules/remorques', offers: 'Missions/mois', clients: 'Clients en base', storage: 'Pièces jointes' },
    monthly: '/ mois',
    enterpriseCta: 'Contactez-nous',
    addOnsTitle: '➕ Options additionnelles (one-time et mensuelles)',
    addOnsSubtitle: 'Payez uniquement ce dont vous avez besoin. Tous les prix nets.',
    addOnsLabels: {
      migrate_excel: 'Migration de données Excel (jusqu\'à 500 entrées)',
      migrate_system: 'Migration depuis un autre système (jusqu\'à 2 000 entrées)',
      onboarding_live: 'Onboarding en ligne — 2h formation live, partage d\'écran',
      invoice_setup: 'Configuration factures / facturation électronique + modèles PDF',
      extra_driver: 'Chauffeur supplémentaire au-delà du plan',
      extra_vehicle: 'Véhicule supplémentaire au-delà du plan',
    },
    addOnsRecurring: '/ mois',
    addOnsOneTime: 'unique',
    ctaTitle: 'Envoyez votre candidature à hi@galoptrans.pl',
    ctaBody: 'Dans l\'email indiquez : nom de l\'entreprise, N° TVA, région d\'opération, nombre de véhicules et chauffeurs, plan choisi. Joignez les scans PDF/JPG de tous les documents de la liste ci-dessus (immatriculation, licence de transport, certificat transporteur d\'animaux, attestation de capacité, assurance RC, cartes grises, permis + certificats de transport animal des chauffeurs). Vérification 2 à 5 jours ouvrés. Après validation, nous activons votre plan avec le premier mois gratuit.',
    ctaButton: 'Écrire à hi@galoptrans.pl',
    ctaEmail: 'hi@galoptrans.pl',
    ctaMailSubject: 'Candidature transporteur — Hovera × GalopTrans',
    freeNote: '🎁 Les écuries et propriétaires de chevaux utilisent le module Transport entièrement GRATUITEMENT — inclus dans chaque plan Hovera dès Start. Seuls les transporteurs choisissent l\'un des 4 plans d\'abonnement.',
  },
};

const t = text[locale];
const planKeys = ['start', 'pro', 'business', 'enterprise'] as const;
const planPricesAttr = JSON.stringify(planPrices);
const addOnsAttr = JSON.stringify(addOns);
const currencyMetaAttr = JSON.stringify(currencyMeta);
const cm = currencyMeta[defaultCurrency];
const pp = planPrices[defaultCurrency];
const ao = addOns[defaultCurrency];
const fmt = (n: number) => cm.pos === 'after' ? `${n.toLocaleString(locale === 'pl' ? 'pl-PL' : 'en-GB').replace(/,/g, ' ')} ${cm.symbol}` : `${cm.symbol}${n}`;
---

<section
  class="container-x py-20"
  data-reveal
  data-carrier-pricing
  data-default-currency={defaultCurrency}
  data-plan-prices={planPricesAttr}
  data-addons={addOnsAttr}
  data-currency-meta={currencyMetaAttr}
>
  <div class="co-wrap">
    <header class="co-header">
      <span class="eyebrow">{t.eyebrow}</span>
      <h2 class="display-3 mt-3 text-balance">{t.title}</h2>
      <p class="muted mt-4 max-w-2xl mx-auto">{t.subtitle}</p>
      <span class="co-trial-badge mt-5">{t.trialBadge}</span>
    </header>

    <div class="co-roi" data-reveal>
      <span class="co-roi-title">{t.roiTitle}</span>
      <p class="co-roi-body">{t.roiBody}</p>
      <p class="co-roi-calc" data-roi-calc>{t.roiCalc}</p>
      <p class="co-roi-punch">{t.roiPunch}</p>
    </div>

    <div class="co-reqs-box">
      <h3 class="co-col-title">{t.reqsTitle}</h3>
      <ul class="co-reqs">
        {t.reqs.map((r) => (
          <li>
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
              <path d="M3 7.5l2.5 2.5L11 4.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <span>{r}</span>
          </li>
        ))}
      </ul>
    </div>

    <div class="co-plans-head" id="cennik-transport">
      <h3 class="co-section-title">{t.plansTitle}</h3>
      <p class="co-section-sub">{t.plansSubtitle}</p>

      <div class="co-promo">
        <p>{t.pricingTerms}</p>
      </div>

      <div class="co-curr-switch" role="tablist" aria-label={t.currencyLabel}>
        <span class="co-curr-label">{t.currencyLabel}:</span>
        {(Object.keys(currencyMeta) as CurrencyCode[]).map((c) => (
          <button
            type="button"
            class={`co-curr-btn ${c === defaultCurrency ? 'is-active' : ''}`}
            data-curr={c}
            role="tab"
            aria-selected={c === defaultCurrency ? 'true' : 'false'}
          >
            <span aria-hidden="true">{currencyMeta[c].flag}</span>
            <span>{currencyMeta[c].label}</span>
          </button>
        ))}
      </div>
    </div>

    <div class="co-plans">
      {planKeys.map((key) => {
        const plan = t.plans[key];
        const isEnterprise = key === 'enterprise';
        const popular = 'popular' in plan && plan.popular;
        return (
          <div class={`co-plan ${popular ? 'is-popular' : ''} ${isEnterprise ? 'is-enterprise' : ''}`} data-plan={key}>
            {popular && <span class="co-plan-badge">★</span>}
            <div class="co-plan-name">{plan.name}</div>
            <div class="co-plan-desc">{plan.desc}</div>

            <div class="co-plan-price">
              {isEnterprise ? (
                <span class="co-plan-price-tba">{t.enterpriseCta}</span>
              ) : (
                <>
                  <span class="co-plan-price-num" data-price>{fmt(pp[key as 'start' | 'pro' | 'business'])}</span>
                  <span class="co-plan-price-period">{t.monthly}</span>
                </>
              )}
            </div>

            <ul class="co-plan-limits">
              {planLimits.map((l) => (
                <li>
                  <span class="muted">{t.limitsLabels[l.key as keyof typeof t.limitsLabels]}</span>
                  <strong>{l[key]}</strong>
                </li>
              ))}
            </ul>

            <ul class="co-plan-feats">
              {plan.features.map((f) => (
                <li>
                  <svg width="12" height="12" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                    <path d="M3 7.5l2.5 2.5L11 4.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                  <span>{f}</span>
                </li>
              ))}
            </ul>
          </div>
        );
      })}
    </div>

    <div class="co-addons">
      <h3 class="co-section-title">{t.addOnsTitle}</h3>
      <p class="co-section-sub">{t.addOnsSubtitle}</p>
      <ul class="co-addons-list">
        {(Object.keys(t.addOnsLabels)).map((kRaw) => {
          const k = kRaw as keyof typeof t.addOnsLabels;
          const item = ao[k as keyof typeof ao];
          return (
            <li class="co-addon-row" data-addon={k}>
              <div class="co-addon-label">{t.addOnsLabels[k]}</div>
              <div class="co-addon-meta">
                <span class="co-addon-price" data-addon-price>{item.price}</span>
                <span class="co-addon-period muted">{item.recurring ? t.addOnsRecurring : t.addOnsOneTime}</span>
              </div>
            </li>
          );
        })}
      </ul>
    </div>

    <div class="co-cta" id="zglos-firme">
      <h3 class="co-cta-title">{t.ctaTitle}</h3>
      <p class="co-cta-body">{t.ctaBody}</p>
      <a
        href={`mailto:${t.ctaEmail}?subject=${encodeURIComponent(t.ctaMailSubject)}`}
        class="btn btn-primary mt-5"
      >
        {t.ctaButton} →
      </a>
    </div>

    <div class="co-free">
      <p>{t.freeNote}</p>
    </div>
  </div>
</section>


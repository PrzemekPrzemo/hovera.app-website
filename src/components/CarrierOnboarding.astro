<script>
  // Currency switcher for the carrier pricing block. Mirrors the main
  // PricingCalculator behaviour: click a chip, swap plan prices and
  // add-on prices, persist the choice.
  type PlanPriceMap = { start: number; pro: number; business: number };
  type AddOnItem = { price: string; recurring: boolean };
  type AddOnMap = Record<string, AddOnItem>;
  type CMeta = { symbol: string; pos: 'before' | 'after'; flag: string; label: string };

  function init() {
    document.querySelectorAll<HTMLElement>('[data-carrier-pricing]').forEach((root) => {
      let plans: Record<string, PlanPriceMap> = {};
      let addons: Record<string, AddOnMap> = {};
      let meta: Record<string, CMeta> = {};
      try { plans = JSON.parse(root.dataset.planPrices || '{}'); } catch {}
      try { addons = JSON.parse(root.dataset.addons || '{}'); } catch {}
      try { meta = JSON.parse(root.dataset.currencyMeta || '{}'); } catch {}

      let current = root.dataset.defaultCurrency || 'PLN';

      const fmt = (n: number, code: string) => {
        const m = meta[code];
        if (!m) return String(n);
        const formatted = code === 'PLN'
          ? n.toLocaleString('pl-PL').replace(/,/g, ' ')
          : n.toLocaleString('en-GB');
        return m.pos === 'after' ? `${formatted} ${m.symbol}` : `${m.symbol}${formatted}`;
      };

      const apply = (code: string) => {
        if (!plans[code]) return;
        current = code;
        // Plan prices
        root.querySelectorAll<HTMLElement>('.co-plan[data-plan]').forEach((card) => {
          const key = card.dataset.plan as 'start' | 'pro' | 'business' | 'enterprise';
          if (key === 'enterprise') return;
          const priceEl = card.querySelector<HTMLElement>('[data-price]');
          if (priceEl) priceEl.textContent = fmt(plans[code][key], code);
        });
        // Add-on prices
        root.querySelectorAll<HTMLElement>('.co-addon-row[data-addon]').forEach((row) => {
          const key = row.dataset.addon!;
          const item = addons[code]?.[key];
          const priceEl = row.querySelector<HTMLElement>('[data-addon-price]');
          if (priceEl && item) priceEl.textContent = item.price;
        });
        // Currency button active state
        root.querySelectorAll<HTMLButtonElement>('.co-curr-btn').forEach((btn) => {
          const isActive = btn.dataset.curr === code;
          btn.classList.toggle('is-active', isActive);
          btn.setAttribute('aria-selected', isActive ? 'true' : 'false');
        });
        try { localStorage.setItem('hovera-currency', code); } catch {}
      };

      root.querySelectorAll<HTMLButtonElement>('.co-curr-btn').forEach((btn) => {
        btn.addEventListener('click', () => {
          const code = btn.dataset.curr;
          if (code) apply(code);
        });
      });

      // Pick up saved choice if it differs from default
      try {
        const saved = localStorage.getItem('hovera-currency');
        if (saved && saved !== current && plans[saved]) apply(saved);
      } catch {}
    });
  }
  init();
  document.addEventListener('astro:page-load', init);
</script>

---
import Logo from './Logo.astro';
import { useTranslations, localizePath, unlocalizePath, locales, localeMeta, type Locale } from '../i18n/utils';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = useTranslations(locale);
const canonicalPath = unlocalizePath(Astro.url.pathname);
const langOptions = locales.map((loc) => ({
  code: loc,
  ...localeMeta[loc],
  href: localizePath(canonicalPath, loc),
  isCurrent: loc === locale,
}));

const lp = (p: string) => localizePath(p, locale);

const productItems = [
  { href: lp('/produkt/kalendarz'), label: t('nav.product.calendar') },
  { href: lp('/produkt/karnety'), label: t('nav.product.passes') },
  { href: lp('/produkt/dziennik-konia'), label: t('nav.product.horse-journal') },
  { href: lp('/produkt/pensjonat'), label: t('nav.product.boarding') },
  { href: lp('/produkt/pasza-zywienie'), label: t('nav.product.feed') },
  { href: lp('/produkt/finanse-ksef'), label: t('nav.product.finance') },
  { href: lp('/produkt/zapisy-online'), label: t('nav.product.online-booking') },
];

const forItems = [
  { href: lp('/dla/szkolki'), label: t('nav.for.school') },
  { href: lp('/dla/pensjonatu'), label: t('nav.for.boarding') },
  { href: lp('/dla/sportu'), label: t('nav.for.sport') },
  { href: lp('/dla/hodowli'), label: t('nav.for.breeding') },
  { href: lp('/dla/sieci-stajni'), label: t('nav.for.network') },
];
---

<header class="hovera-nav fixed inset-x-0 top-0 z-50" data-nav>
  <div class="container-x">
    <div class="hovera-nav-shell mt-4 flex items-center justify-between gap-6 rounded-full border px-4 py-2.5 backdrop-blur-md md:px-5">
      <a href={lp('/')} class="flex items-center gap-2 text-[1.35rem] tracking-tight" aria-label="Hovera">
        <Logo />
      </a>

      <nav class="hidden items-center gap-1 lg:flex">
        <div class="hovera-dropdown group relative">
          <button class="dropdown-trigger" type="button">
            {t('nav.product')}
            <svg width="10" height="10" viewBox="0 0 10 10" fill="none" aria-hidden="true">
              <path d="M2 4l3 3 3-3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </button>
          <div class="dropdown-panel" role="menu">
            {productItems.map((it) => (
              <a href={it.href} class="dropdown-item">{it.label}</a>
            ))}
          </div>
        </div>

        <div class="hovera-dropdown group relative">
          <button class="dropdown-trigger" type="button">
            {t('nav.for')}
            <svg width="10" height="10" viewBox="0 0 10 10" fill="none" aria-hidden="true">
              <path d="M2 4l3 3 3-3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </button>
          <div class="dropdown-panel" role="menu">
            {forItems.map((it) => (
              <a href={it.href} class="dropdown-item">{it.label}</a>
            ))}
          </div>
        </div>

        <a class="nav-link" href={lp('/cennik')}>{t('nav.pricing')}</a>
        <a class="nav-link" href={lp('/blog')}>{t('nav.blog')}</a>
        <a class="nav-link" href={lp('/co-nowego')}>{t('nav.changelog')}</a>
        <a class="nav-link" href={lp('/demo')}>{t('nav.demo')}</a>
      </nav>

      <div class="flex items-center gap-2">
        <div class="hovera-dropdown lang-switcher group relative hidden md:block">
          <button class="dropdown-trigger lang-trigger" type="button" aria-label="Language">
            <span class="lang-flag">{localeMeta[locale].flag}</span>
            <span>{localeMeta[locale].short}</span>
            <svg width="10" height="10" viewBox="0 0 10 10" fill="none" aria-hidden="true">
              <path d="M2 4l3 3 3-3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </button>
          <div class="dropdown-panel lang-panel" role="menu">
            {langOptions.map((opt) => (
              <a href={opt.href} class={`dropdown-item lang-item ${opt.isCurrent ? 'is-current' : ''}`} data-lang={opt.code}>
                <span class="lang-flag">{opt.flag}</span>
                <span>{opt.label}</span>
              </a>
            ))}
          </div>
        </div>
        <a href={lp('/kontakt')} class="btn btn-primary text-[13px] px-4 py-2">
          {t('nav.cta')}
        </a>
        <button
          class="lg:hidden inline-flex h-9 w-9 items-center justify-center rounded-full border"
          aria-label="Menu"
          data-mobile-toggle
          type="button"
        >
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
            <path d="M2 4h12M2 8h12M2 12h12" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" />
          </svg>
        </button>
      </div>
    </div>
  </div>

  <div class="hovera-mobile lg:hidden" data-mobile-panel hidden>
    <div class="container-x py-4">
      <div class="surface p-4 space-y-1">
        <details class="group">
          <summary class="flex cursor-pointer items-center justify-between py-2 text-sm font-medium">
            {t('nav.product')}
            <svg width="10" height="10" viewBox="0 0 10 10" fill="none" class="transition-transform group-open:rotate-180" aria-hidden="true">
              <path d="M2 4l3 3 3-3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </summary>
          <div class="ml-2 mt-1 flex flex-col">
            {productItems.map((it) => (
              <a href={it.href} class="dropdown-item">{it.label}</a>
            ))}
          </div>
        </details>
        <details class="group">
          <summary class="flex cursor-pointer items-center justify-between py-2 text-sm font-medium">
            {t('nav.for')}
            <svg width="10" height="10" viewBox="0 0 10 10" fill="none" class="transition-transform group-open:rotate-180" aria-hidden="true">
              <path d="M2 4l3 3 3-3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </summary>
          <div class="ml-2 mt-1 flex flex-col">
            {forItems.map((it) => (
              <a href={it.href} class="dropdown-item">{it.label}</a>
            ))}
          </div>
        </details>
        <a class="block py-2 text-sm font-medium" href={lp('/cennik')}>{t('nav.pricing')}</a>
        <a class="block py-2 text-sm font-medium" href={lp('/blog')}>{t('nav.blog')}</a>
        <a class="block py-2 text-sm font-medium" href={lp('/co-nowego')}>{t('nav.changelog')}</a>
        <a class="block py-2 text-sm font-medium" href={lp('/demo')}>{t('nav.demo')}</a>
        <div class="border-t pt-3 mt-2 flex flex-wrap gap-3">
          {langOptions.map((opt) => (
            <a class={`text-sm ${opt.isCurrent ? 'font-semibold' : ''}`} href={opt.href} data-lang={opt.code}>
              {opt.flag} {opt.short}
            </a>
          ))}
        </div>
      </div>
    </div>
  </div>
</header>

<style>
  .hovera-nav-shell {
    background: rgba(250, 248, 244, 0.78);
    border-color: var(--color-border);
    box-shadow: var(--shadow-soft);
    transition: background 0.4s var(--ease-out-expo), box-shadow 0.4s var(--ease-out-expo);
  }
  [data-nav].is-scrolled .hovera-nav-shell {
    background: rgba(250, 248, 244, 0.92);
    box-shadow: var(--shadow-warm);
  }
  .nav-link {
    border-radius: 9999px;
    padding: 0.5rem 0.75rem;
    font-size: 0.875rem;
    font-weight: 500;
    transition: background-color 0.2s, color 0.2s;
    color: var(--color-fg);
  }
  .nav-link:hover {
    background: var(--color-sand-light);
  }
  .dropdown-trigger {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    border-radius: 9999px;
    padding: 0.5rem 0.75rem;
    font-size: 0.875rem;
    font-weight: 500;
    transition: background-color 0.2s;
    color: var(--color-fg);
  }
  .dropdown-trigger:hover {
    background: var(--color-sand-light);
  }
  .dropdown-panel {
    position: absolute;
    top: calc(100% + 8px);
    left: 50%;
    transform: translateX(-50%) translateY(-6px);
    min-width: 240px;
    background: var(--color-cream);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-warm);
    padding: 8px;
    opacity: 0;
    pointer-events: none;
    transition:
      opacity 0.2s var(--ease-out-expo),
      transform 0.2s var(--ease-out-expo);
    transition-delay: 0.18s;
    z-index: 60;
  }
  .dropdown-panel::before {
    content: '';
    position: absolute;
    top: -14px;
    left: 0;
    right: 0;
    height: 14px;
  }
  .hovera-dropdown:hover .dropdown-panel,
  .hovera-dropdown:focus-within .dropdown-panel {
    opacity: 1;
    pointer-events: auto;
    transform: translateX(-50%) translateY(0);
    transition-delay: 0s;
  }
  .dropdown-item {
    display: block;
    border-radius: 0.5rem;
    padding: 0.5rem 0.75rem;
    font-size: 0.875rem;
    transition: background-color 0.2s, color 0.2s;
    color: var(--color-fg);
  }
  .dropdown-item:hover {
    background: var(--color-sand-light);
    color: var(--color-bark);
  }
  .hovera-mobile[hidden] {
    display: none;
  }
  .lang-trigger { padding: 0.4rem 0.7rem; }
  .lang-flag { font-size: 1rem; line-height: 1; }
  .lang-panel { min-width: 180px; left: auto; right: 0; transform: translateY(-6px); }
  .hovera-dropdown.lang-switcher:hover .lang-panel,
  .hovera-dropdown.lang-switcher:focus-within .lang-panel { transform: translateY(0); }
  .lang-item { display: flex; gap: 0.6rem; align-items: center; }
  .lang-item.is-current { background: var(--color-sand-light); font-weight: 500; }
</style>

<script>
  const nav = document.querySelector<HTMLElement>('[data-nav]');
  const onScroll = () => {
    if (!nav) return;
    if (window.scrollY > 8) nav.classList.add('is-scrolled');
    else nav.classList.remove('is-scrolled');
  };
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();

  const toggle = document.querySelector<HTMLButtonElement>('[data-mobile-toggle]');
  const panel = document.querySelector<HTMLElement>('[data-mobile-panel]');
  toggle?.addEventListener('click', () => {
    if (!panel) return;
    panel.hidden = !panel.hidden;
  });

  // Manual override: clicking a language link saves the choice
  document.querySelectorAll<HTMLAnchorElement>('a[data-lang]').forEach((a) => {
    a.addEventListener('click', () => {
      try { localStorage.setItem('hovera-lang', a.dataset.lang || 'pl'); } catch {}
    });
  });

  // Auto-detect on first visit only — never override a saved preference
  (() => {
    try {
      const saved = localStorage.getItem('hovera-lang');
      if (saved) return;
      const supported = ['pl', 'en', 'de', 'fr'] as const;
      type L = typeof supported[number];
      const browser = (navigator.language || 'pl').slice(0, 2).toLowerCase() as L;
      if (!supported.includes(browser)) return;

      const path = location.pathname;
      const seg = path.split('/')[1] || '';
      const currentLang: L = (supported as readonly string[]).includes(seg) ? (seg as L) : 'pl';
      if (currentLang === browser) {
        localStorage.setItem('hovera-lang', browser);
        return;
      }
      // Compute target path: strip current locale prefix, then add browser one
      const stripped = (currentLang === 'pl') ? path : (path.replace(new RegExp(`^/${currentLang}`), '') || '/');
      const target = browser === 'pl' ? stripped : `/${browser}${stripped === '/' ? '' : stripped}`;
      localStorage.setItem('hovera-lang', browser);
      if (target !== path) location.replace(target);
    } catch {}
  })();
</script>

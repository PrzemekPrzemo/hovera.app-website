---
import Base from '../layouts/Base.astro';
import PageHero from '../components/PageHero.astro';
import FinalCTA from '../components/FinalCTA.astro';
import { localizePath } from '../i18n/utils';

const locale = 'pl' as const;
const lp = (p: string) => localizePath(p, locale);

const features = [
  { title: 'Kalendarz w kieszeni', body: 'Pełna nawigacja, drag&drop, widoki dzienne i tygodniowe.' },
  { title: 'Tryb offline', body: 'Read i write w stajni bez wifi. Synchronizacja gdy wrócisz w sieć.' },
  { title: 'Push notifications', body: 'Jutrzejsza szczepionka. Klient odwołał. Faktura zapłacona. Wszystko w czasie rzeczywistym.' },
  { title: 'Dziennik konia w 3 kliknięciach', body: 'Notatka, zdjęcie, geo-tag — wszystko z poziomu boksu.' },
  { title: 'Widgety home screen', body: 'Najbliższa jazda, dzisiejszy plan, najczęściej używane akcje — bez wchodzenia do aplikacji.' },
  { title: 'Quick actions', body: 'Długie przyciśnięcie ikony aplikacji = '+'Dodaj jazdę' + ', ' + 'Wystaw fakturę' + ', ' + 'Pokaż dzisiaj' + '.' },
];
---

<Base
  title="Aplikacja mobilna — Hovera iOS i Android"
  description="Hovera w kieszeni. iOS 16+ i Android 10+. Pełen tryb offline, push notifications, widgety home screen."
>
  <PageHero
    eyebrow="Aplikacja mobilna"
    title="Stajnia w kieszeni"
    subtitle="Pełna funkcjonalność iOS i Android. Działa nawet w boksie bez wifi. iOS 16+ / Android 10+. RAM 2GB+."
  >
    <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
      <a href="#" class="badge-store">
        <svg width="16" height="20" viewBox="0 0 16 20" fill="currentColor"><path d="M11.6 9.6c0-2.4 2-3.6 2.1-3.6-1.1-1.7-2.9-1.9-3.5-1.9-1.5-.2-2.9.9-3.6.9-.8 0-1.9-.9-3.1-.8C2 4.3.7 5.2 0 6.5c-1.6 2.7-.4 6.7 1.1 8.9.7 1.1 1.6 2.3 2.8 2.3 1.1 0 1.6-.7 2.9-.7 1.4 0 1.7.7 2.9.7 1.2 0 2-1.1 2.7-2.2.9-1.3 1.2-2.5 1.3-2.6 0 0-2.5-1-2.5-3.8.1-2.3 1.9-3.4 2-3.5-.4-.6-2-2-3.6-1z"/></svg>
        <span><small>Pobierz w</small><br/><b>App Store</b></span>
      </a>
      <a href="#" class="badge-store">
        <svg width="16" height="20" viewBox="0 0 16 20" fill="currentColor"><path d="M.4 0C.2.3 0 .8 0 1.4v17.2c0 .6.2 1 .5 1.3l9.6-9.9L.4 0zm10.7 10.5L1.6 19.9l9-5.2 1.7-1c.4-.2.6-.5.5-.8 0-.3-.2-.6-.6-.8L11.1 11l-.8-.5z"/></svg>
        <span><small>Pobierz w</small><br/><b>Google Play</b></span>
      </a>
    </div>
    <p class="mt-4 text-xs muted">Aplikacja w cenie każdego planu, w tym Free.</p>
  </PageHero>

  <section class="container-x py-24">
    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {features.map((f, i) => (
        <article class="mob-feat-card" data-reveal>
          <div class="mob-feat-num">{(i+1).toString().padStart(2, '0')}</div>
          <h3 class="mob-feat-title">{f.title}</h3>
          <p class="muted mt-3">{f.body}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="container-x py-16" data-reveal>
    <div class="qr-card">
      <div>
        <span class="eyebrow">Skanuj</span>
        <h3 class="display-3 mt-3">Pobierz aplikację bezpośrednio</h3>
        <p class="muted mt-3 max-w-md">Zeskanuj kod QR aparatem telefonu — kierujemy do App Store lub Google Play w zależności od Twojego systemu.</p>
      </div>
      <div class="qr-box" aria-hidden="true">
        <svg viewBox="0 0 100 100" width="120" height="120">
          {Array.from({ length: 25 }).map((_, i) => Array.from({ length: 25 }).map((_, j) => {
            const fill = (i + j) % 3 === 0 || (i * j) % 7 === 0 ? '#3D2E22' : 'transparent';
            return <rect x={i*4} y={j*4} width="4" height="4" fill={fill} />;
          }))}
          <rect x="0" y="0" width="28" height="28" fill="none" stroke="#3D2E22" stroke-width="4"/>
          <rect x="6" y="6" width="16" height="16" fill="#3D2E22"/>
          <rect x="72" y="0" width="28" height="28" fill="none" stroke="#3D2E22" stroke-width="4"/>
          <rect x="78" y="6" width="16" height="16" fill="#3D2E22"/>
          <rect x="0" y="72" width="28" height="28" fill="none" stroke="#3D2E22" stroke-width="4"/>
          <rect x="6" y="78" width="16" height="16" fill="#3D2E22"/>
        </svg>
      </div>
    </div>
  </section>

  <FinalCTA locale={locale} />
</Base>

<style>
  .badge-store {
    display: inline-flex; align-items: center; gap: 10px;
    padding: 12px 20px;
    background: var(--color-bark);
    color: var(--color-cream);
    border-radius: 14px;
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .badge-store:hover { transform: translateY(-1px); box-shadow: var(--shadow-warm); }
  .badge-store small { font-size: 11px; opacity: 0.7; }
  .badge-store b { font-size: 16px; font-weight: 500; }

  .mob-feat-card {
    padding: 2rem;
    background: var(--color-cream);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    transition: all 0.4s var(--ease-out-expo);
  }
  .mob-feat-card:hover { transform: translateY(-2px); box-shadow: var(--shadow-warm); }
  .mob-feat-num { font-family: var(--font-mono); font-size: 0.85rem; color: var(--color-ochre-dark); letter-spacing: 0.18em; }
  .mob-feat-title { font-size: 1.25rem; line-height: 1.2; letter-spacing: -0.02em; font-weight: 500; margin-top: 0.6rem; }

  .qr-card {
    display: flex; flex-direction: column; gap: 2rem;
    align-items: center;
    padding: 3rem;
    border-radius: var(--radius-2xl);
    background: linear-gradient(135deg, var(--color-sand-light) 0%, var(--color-cream) 100%);
    border: 1px solid var(--color-border);
    max-width: 56rem; margin: 0 auto;
  }
  @media (min-width: 800px) { .qr-card { flex-direction: row; justify-content: space-between; } }
  .qr-box {
    width: 160px; height: 160px;
    background: white;
    padding: 20px;
    border-radius: 16px;
    box-shadow: var(--shadow-soft);
  }
  .qr-box svg { width: 100%; height: 100%; }
</style>

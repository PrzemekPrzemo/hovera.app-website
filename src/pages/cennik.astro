---
import Base from '../layouts/Base.astro';
import PageHero from '../components/PageHero.astro';
import PricingTable from '../components/PricingTable.astro';
import FinalCTA from '../components/FinalCTA.astro';

const locale = 'pl' as const;
---

<Base
  title="Cennik — Hovera"
  description="Transparentne ceny. Wybierz plan dopasowany do Twojej stajni. Free, Solo, Stable, Pro i Enterprise. 30-dniowa gwarancja zwrotu."
>
  <PageHero
    eyebrow="Cennik"
    title="Wybierz plan dopasowany do Twojej stajni"
    subtitle="Pełna transparentność. Bez gier z ukrytymi kosztami. KSeF w cenie. 30-dniowa gwarancja zwrotu."
  />
  <PricingTable locale={locale} />
  <FinalCTA locale={locale} />
</Base>

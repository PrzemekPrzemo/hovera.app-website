---
import Base from '../../layouts/Base.astro';
import PageHero from '../../components/PageHero.astro';
import PricingTable from '../../components/PricingTable.astro';
import FinalCTA from '../../components/FinalCTA.astro';

const locale = 'de' as const;
---

<Base
  title="Preise — Hovera"
  description="Transparente Preise. Wähle einen Plan, der zu deinem Stall passt. Free, Solo, Stable, Pro und Enterprise. 30 Tage Geld-zurück-Garantie."
>
  <PageHero
    eyebrow="Preise"
    title="Wähle einen Plan, der zu deinem Stall passt"
    subtitle="Volle Transparenz. Keine versteckten Kosten. E-Rechnung inklusive. 30 Tage Geld-zurück-Garantie."
  />
  <PricingTable locale={locale} />
  <FinalCTA locale={locale} />
</Base>

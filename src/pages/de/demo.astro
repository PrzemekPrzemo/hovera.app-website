---
import Base from '../../layouts/Base.astro';
import PageHero from '../../components/PageHero.astro';
import LiveDemoCard from '../../components/LiveDemoCard.astro';
import FinalCTA from '../../components/FinalCTA.astro';
import { localizePath } from '../../i18n/utils';
const locale = 'de' as const;
const lp = (p: string) => localizePath(p, locale);
---

<Base title="Demo — Hovera" description="Hovera in Aktion erleben. Interaktiver Produkt-Rundgang oder 1-zu-1-Termin mit unserem Team.">
  <PageHero
    eyebrow="Demo"
    title="Hovera in Aktion erleben"
    subtitle="Vier Wege: Live-Demo der laufenden App mit fertigem Zugang, interaktiver Rundgang, 1-zu-1 mit unserem Team oder Erklärvideo (in Kürze)."
  />

  <LiveDemoCard locale={locale} />

  <section class="container-x pb-8">
    <a href={lp('/demo/jak-to-dziala')} class="tour-cta" data-reveal>
      <div class="tour-cta__visual" aria-hidden="true">
        <div class="tour-frame">
          <div class="tour-dots"><span></span><span></span><span></span></div>
          <div class="tour-bars">
            <div class="tour-bar tour-bar--w70"></div>
            <div class="tour-bar tour-bar--w50"></div>
            <div class="tour-bar tour-bar--w85"></div>
            <div class="tour-bar tour-bar--w40"></div>
          </div>
        </div>
      </div>
      <div class="tour-cta__content">
        <span class="eyebrow">Interaktiver Rundgang</span>
        <h2 class="display-3 mt-2">So funktioniert Hovera in der Praxis</h2>
        <p class="muted mt-3">11 Szenen mit echten App-Screens: Dashboard, Kalender, Buchungskonflikte, Online-Zahlung, Pferdebesitzer-Portal, Tagesreport. Kein Login, keine Formulare.</p>
        <span class="btn btn-primary mt-6">Rundgang öffnen →</span>
      </div>
    </a>
  </section>

  <section class="container-x py-16">
    <div class="grid gap-6 md:grid-cols-2 max-w-5xl mx-auto">
      <article class="demo-card" data-reveal>
        <div class="demo-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 5h18v14H3z" stroke-linejoin="round"/><path d="M3 5l9 7 9-7" stroke-linejoin="round"/></svg></div>
        <h3 class="display-3 mt-4">Live-Demo für deinen Stall</h3>
        <p class="muted mt-3">30-minütiges Online-Meeting. Wir zeigen Hovera im Kontext deines Stalls: Reitschule, Pension, Sport oder Zucht.</p>
        <ul class="demo-list mt-6">
          <li>Kurzes Gespräch über deinen Stall</li>
          <li>Demo zu konkreten Anwendungsfällen</li>
          <li>Live-Fragen</li>
          <li>Migrationsplan von deinem aktuellen Tool</li>
          <li>Planempfehlung</li>
        </ul>
        <a href={lp('/kontakt')} class="btn btn-primary mt-6">Demo buchen</a>
      </article>

      <article class="demo-card" data-reveal>
        <div class="demo-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="4" width="20" height="14" rx="2"/><path d="M10 9l5 3-5 3V9z" fill="currentColor"/></svg></div>
        <h3 class="display-3 mt-4">Produktvideo (in Kürze)</h3>
        <p class="muted mt-3">5-minütige Bildschirmaufnahme der echten App mit Voiceover. Kein Login, kein Formular. Kommt, sobald die App für die öffentliche Vorschau bereit ist.</p>
        <ul class="demo-list mt-6">
          <li>Onboarding eines neuen Kunden</li>
          <li>Einrichten der ersten Pferde und Trainer</li>
          <li>Reitkarten konfigurieren</li>
          <li>Erste Rechnung erstellen</li>
        </ul>
        <button class="btn btn-secondary mt-6" disabled>In Kürze</button>
      </article>
    </div>
  </section>

  <FinalCTA locale={locale} />
</Base>

<style>
  .tour-cta { display: grid; grid-template-columns: 1fr; gap: 2rem; max-width: 64rem; margin: 0 auto; padding: 2.5rem; background: linear-gradient(135deg, var(--color-cream) 0%, var(--color-sand-light) 100%); border: 1px solid var(--color-border); border-radius: var(--radius-2xl); box-shadow: var(--shadow-warm); text-decoration: none; color: inherit; transition: transform 0.4s var(--ease-out-expo), box-shadow 0.4s var(--ease-out-expo); }
  .tour-cta:hover { transform: translateY(-4px); box-shadow: 0 20px 40px -12px rgba(61,46,34,0.18); }
  @media (min-width: 800px) { .tour-cta { grid-template-columns: 1fr 1.2fr; align-items: center; } }
  .tour-cta__visual { display: flex; justify-content: center; }
  .tour-frame { width: 100%; max-width: 22rem; aspect-ratio: 16 / 10; background: var(--color-bark); border-radius: 14px; padding: 0.6rem; box-shadow: 0 12px 30px -8px rgba(61,46,34,0.4); display: flex; flex-direction: column; gap: 0.6rem; }
  .tour-dots { display: flex; gap: 0.4rem; }
  .tour-dots span { width: 10px; height: 10px; border-radius: 999px; background: var(--color-sand-light); opacity: 0.55; }
  .tour-dots span:nth-child(1) { background: #E2725B; opacity: 0.9; }
  .tour-dots span:nth-child(2) { background: var(--color-ochre); opacity: 0.9; }
  .tour-dots span:nth-child(3) { background: #6B8E5A; opacity: 0.9; }
  .tour-bars { flex: 1; background: var(--color-cream); border-radius: 8px; padding: 0.85rem; display: flex; flex-direction: column; gap: 0.55rem; }
  .tour-bar { height: 0.65rem; border-radius: 999px; background: var(--color-sand-light); }
  .tour-bar--w70 { width: 70%; background: var(--color-ochre); opacity: 0.7; }
  .tour-bar--w50 { width: 50%; }
  .tour-bar--w85 { width: 85%; }
  .tour-bar--w40 { width: 40%; background: var(--color-bark); opacity: 0.35; }
  .demo-card { padding: 2.5rem; background: var(--color-cream); border: 1px solid var(--color-border); border-radius: var(--radius-2xl); transition: all 0.4s var(--ease-out-expo); }
  .demo-card:hover { transform: translateY(-2px); box-shadow: var(--shadow-warm); }
  .demo-icon { width: 56px; height: 56px; border-radius: 14px; background: var(--color-sand-light); color: var(--color-bark); display: inline-flex; align-items: center; justify-content: center; }
  .demo-icon svg { width: 28px; height: 28px; }
  .demo-list { list-style: none; padding: 0; display: flex; flex-direction: column; gap: 0.4rem; font-size: 0.95rem; color: var(--color-fg-muted); }
  .demo-list li { padding-left: 1.5rem; position: relative; }
  .demo-list li::before { content: "→"; position: absolute; left: 0; color: var(--color-ochre); }
</style>

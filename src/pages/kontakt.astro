---
import Base from '../layouts/Base.astro';
import PageHero from '../components/PageHero.astro';
import InquiryForm from '../components/InquiryForm.astro';

const locale = 'pl' as const;
---

<Base
  title="Kontakt — Hovera"
  description="Wyślij zapytanie. Odpowiadamy w 24h, doradzamy plan i przeprowadzamy przez setup."
>
  <PageHero
    eyebrow="Kontakt"
    title="Porozmawiajmy o Twojej stajni"
    subtitle="Wypełnij formularz — odpowiemy w 24h. Doradzimy plan, pokażemy demo, pomożemy wystartować."
  />

  <section class="container-x pb-24">
    <div class="contact-grid">
      <div class="contact-form-card" data-reveal>
        <InquiryForm locale={locale} />
      </div>

      <aside class="contact-sidebar" data-reveal>
        <h3 class="text-lg font-medium">Sposoby kontaktu</h3>
        <ul class="contact-list mt-4">
          <li>
            <span class="cl-label">Email</span>
            <a href="mailto:hello@hovera.app">hello@hovera.app</a>
          </li>
          <li>
            <span class="cl-label">Telefon</span>
            <a href="tel:+48791301019">+48 791 301 019</a>
          </li>
          <li>
            <span class="cl-label">Firma</span>
            <span>Sendormeco Holding sp. z o.o.</span>
          </li>
          </li>
        </ul>

        <div class="contact-times mt-8">
          <h4 class="text-sm font-medium">Godziny wsparcia</h4>
          <p class="muted text-sm mt-2">
            Pon–Pt: 8:00–18:00<br/>
            Sb: 10:00–14:00<br/>
            Niedziela: zamknięte
          </p>
        </div>

        <div class="mt-8 p-4 rounded-xl" style="background: rgba(111,182,122,0.12);">
          <p class="text-sm">Średni czas odpowiedzi w godzinach pracy: <b>~2h</b>. Poza godzinami: do 24h.</p>
        </div>
      </aside>
    </div>
  </section>
</Base>

<style>
  .contact-grid {
    display: grid;
    gap: 3rem;
    grid-template-columns: 1fr;
  }
  @media (min-width: 900px) {
    .contact-grid { grid-template-columns: 2fr 1fr; }
  }
  .contact-form-card {
    background: var(--color-cream);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-2xl);
    padding: 2rem;
    box-shadow: var(--shadow-soft);
  }
  .contact-sidebar { padding: 0.5rem; }
  .contact-list { list-style: none; padding: 0; display: flex; flex-direction: column; gap: 1rem; }
  .contact-list li { display: flex; flex-direction: column; gap: 0.2rem; font-size: 0.95rem; }
  .cl-label { font-size: 0.7rem; letter-spacing: 0.18em; text-transform: uppercase; color: var(--color-fg-muted); font-weight: 500; }
  .contact-list a:hover { color: var(--color-ochre-dark); }
</style>

<script>
  // Pre-fill plan from query string
  const params = new URLSearchParams(window.location.search);
  const plan = params.get('plan');
  if (plan) {
    const sel = document.querySelector<HTMLSelectElement>('select[name="plan"]');
    if (sel) {
      const opt = Array.from(sel.options).find((o) => o.value === plan);
      if (opt) sel.value = plan;
    }
  }
</script>

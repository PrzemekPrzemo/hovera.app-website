---
import Base from '../../layouts/Base.astro';
import PageHero from '../../components/PageHero.astro';
---

<Base title="Cookie policy — Hovera" description="Cookies used by Hovera.">
  <PageHero eyebrow="Legal" title="Cookie policy" subtitle="Last updated: 6 May 2026" />
  <article class="container-x py-16">
    <div class="legal-body max-w-3xl mx-auto">
      <h2>What are cookies?</h2>
      <p>Cookies are small text files saved by the browser. We use them so the Hovera site works correctly and is convenient to use.</p>

      <h2>What we use</h2>

      <h3>Essential (always on)</h3>
      <ul>
        <li><code>_session</code> — user session, required</li>
        <li><code>_csrf</code> — CSRF protection</li>
        <li><code>_locale</code> — saved language preference</li>
      </ul>

      <h3>Functional (optional)</h3>
      <ul>
        <li><code>_theme</code> — light / dark theme preference</li>
      </ul>

      <h3>Analytics (optional)</h3>
      <p>We use Plausible Analytics — a tool without user identification, no tracking cookies. Aggregated, anonymous data only.</p>

      <h2>Managing consent</h2>
      <p>You can change cookie settings any time via your browser or via the "Cookies" link in the footer.</p>

      <h2>Storage</h2>
      <p>Most cookies expire after 1 year. Session — removed when you close the browser.</p>
    </div>
  </article>
</Base>

<style>
  .legal-body :global(h2) { font-size: 1.5rem; line-height: 1.2; letter-spacing: -0.02em; font-weight: 500; margin-top: 2.5rem; }
  .legal-body :global(h3) { font-size: 1.15rem; line-height: 1.3; font-weight: 500; margin-top: 1.75rem; }
  .legal-body :global(p) { margin-top: 1rem; line-height: 1.7; }
  .legal-body :global(ul) { margin-top: 1rem; padding-left: 1.5rem; line-height: 1.7; list-style: disc; }
  .legal-body :global(li) { margin-top: 0.4rem; }
  .legal-body :global(a) { color: var(--color-ochre-dark); text-decoration: underline; }
</style>

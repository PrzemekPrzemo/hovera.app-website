---
import Base from '../../layouts/Base.astro';
import PageHero from '../../components/PageHero.astro';
import InquiryForm from '../../components/InquiryForm.astro';

const locale = 'en' as const;
---

<Base
  title="Contact — Hovera"
  description="Send us a note. We reply within 24h, recommend a plan and walk you through setup."
>
  <PageHero
    eyebrow="Contact"
    title="Let's talk about your stable"
    subtitle="Fill in the form — we reply within 24h. We'll recommend a plan, show you a demo and help you get started."
  />

  <section class="container-x pb-24">
    <div class="contact-grid">
      <div class="contact-form-card" data-reveal>
        <InquiryForm locale={locale} />
      </div>

      <aside class="contact-sidebar" data-reveal>
        <h3 class="text-lg font-medium">Ways to reach us</h3>
        <ul class="contact-list mt-4">
          <li><span class="cl-label">Email</span><a href="mailto:hello@hovera.app">hello@hovera.app</a></li>
          <li><span class="cl-label">Phone</span><a href="tel:+48791301019">+48 791 301 019</a></li>
          <li><span class="cl-label">Company</span><span>Sendormeco Holding sp. z o.o.</span></li>
        </ul>

        <div class="contact-times mt-8">
          <h4 class="text-sm font-medium">Support hours</h4>
          <p class="muted text-sm mt-2">
            Mon–Fri: 08:00–18:00 CET<br/>
            Sat: 10:00–14:00 CET<br/>
            Sunday: closed
          </p>
        </div>

        <div class="mt-8 p-4 rounded-xl" style="background: rgba(111,182,122,0.12);">
          <p class="text-sm">Average response time during business hours: <b>~2h</b>. Otherwise: within 24h.</p>
        </div>
      </aside>
    </div>
  </section>
</Base>

<style>
  .contact-grid { display: grid; gap: 3rem; grid-template-columns: 1fr; }
  @media (min-width: 900px) { .contact-grid { grid-template-columns: 2fr 1fr; } }
  .contact-form-card { background: var(--color-cream); border: 1px solid var(--color-border); border-radius: var(--radius-2xl); padding: 2rem; box-shadow: var(--shadow-soft); }
  .contact-list { list-style: none; padding: 0; display: flex; flex-direction: column; gap: 1rem; }
  .contact-list li { display: flex; flex-direction: column; gap: 0.2rem; font-size: 0.95rem; }
  .cl-label { font-size: 0.7rem; letter-spacing: 0.18em; text-transform: uppercase; color: var(--color-fg-muted); font-weight: 500; }
</style>

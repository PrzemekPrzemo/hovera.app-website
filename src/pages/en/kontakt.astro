---
import Base from '../../layouts/Base.astro';
import PageHero from '../../components/PageHero.astro';
import HorseshoeMark from '../../components/HorseshoeMark.astro';
const locale = 'en' as const;

const email = 'hello@hovera.app';
const phone = '+48 791 301 019';
const phoneRaw = '+48791301019';
---

<Base
  title="Contact — Hovera"
  description="The fastest way to reach us is email. We reply within 24h, to every message, personally."
>
  <PageHero
    eyebrow="Contact"
    title="Drop us a line. We'll write back."
    subtitle="No twenty-field forms. No chatbots. No sales funnels. Just write to us — we'll reply within 24h, personally."
  />

  <section class="container-x pb-12">
    <div class="contact-card" data-reveal>
      <div class="contact-mark" aria-hidden="true">
        <HorseshoeMark class="h-full w-full text-[var(--color-ochre)]" />
      </div>

      <div class="contact-content">
        <h2 class="display-3 text-balance">The best way: email</h2>
        <p class="muted mt-4 text-lg leading-relaxed">
          Every message is read by a human on our team. On a working day we usually reply within
          4-6 hours. Weekends within 24h. No automation.
        </p>

        <a
          href={`mailto:${email}`}
          class="btn btn-primary btn-lg mt-8 magnetic"
          id="mailto-link"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
            <path d="M3 8l9 6 9-6M5 6h14a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2z" stroke-linejoin="round"/>
          </svg>
          {email}
        </a>

        <p class="contact-fineprint mt-5">
          Just "Hi, I run a stable with X horses, I have a question about Y" works — we'll come back with specifics.
        </p>
      </div>
    </div>

    <div class="contact-grid mt-16" data-reveal>
      <div class="contact-block">
        <span class="eyebrow">📞 Prefer to call?</span>
        <h3 class="text-2xl font-medium mt-2">{phone}</h3>
        <p class="muted text-sm mt-2">
          Mon–Fri: 8am–6pm CET<br/>
          Sat: 10am–2pm CET
        </p>
        <a href={`tel:${phoneRaw}`} class="btn btn-secondary mt-4 text-sm">Call us</a>
      </div>

      <div class="contact-block">
        <span class="eyebrow">📍 Address</span>
        <h3 class="text-lg font-medium mt-2">Sendormeco Holding sp. z o.o.</h3>
        <p class="muted text-sm mt-2">
          ul. Złota 75a/7<br/>
          00-819 Warsaw, Poland<br/>
          VAT ID: PL5252866457
        </p>
      </div>

      <div class="contact-block">
        <span class="eyebrow">⏱️ Response time</span>
        <h3 class="text-lg font-medium mt-2">Typically 4-6h</h3>
        <p class="muted text-sm mt-2">
          During business hours. Otherwise within 24h.<br/>
          Every email read by a human.
        </p>
      </div>
    </div>

    <div class="contact-tips mt-16 max-w-2xl mx-auto" data-reveal>
      <h3 class="text-xl font-medium text-center">What's helpful in your first email?</h3>
      <p class="muted text-center mt-2 text-sm">Optional — but helps us help you faster.</p>

      <ul class="tips-list mt-6">
        <li>
          <span class="tip-num">1</span>
          <div>
            <strong>Stable profile</strong>
            <span class="muted">— riding school, boarding, sport, breeding?</span>
          </div>
        </li>
        <li>
          <span class="tip-num">2</span>
          <div>
            <strong>Scale</strong>
            <span class="muted">— how many horses, clients, instructors?</span>
          </div>
        </li>
        <li>
          <span class="tip-num">3</span>
          <div>
            <strong>What you're after</strong>
            <span class="muted">— a specific module, a pricing plan, or a general demo?</span>
          </div>
        </li>
        <li>
          <span class="tip-num">4</span>
          <div>
            <strong>Your context</strong>
            <span class="muted">— using Excel? Another system? Opening a new stable?</span>
          </div>
        </li>
      </ul>
    </div>
  </section>
</Base>

<style>
  .contact-card {
    position: relative;
    max-width: 48rem;
    margin: 0 auto;
    padding: 3rem 3rem;
    background: linear-gradient(180deg, var(--color-cream) 0%, var(--color-sand-light) 100%);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-2xl);
    box-shadow: var(--shadow-warm);
    overflow: hidden;
  }
  @media (max-width: 600px) { .contact-card { padding: 2rem 1.5rem; } }
  .contact-mark {
    position: absolute;
    width: 22rem;
    height: 22rem;
    top: -8rem;
    right: -8rem;
    opacity: 0.18;
    pointer-events: none;
    animation: spin 30s linear infinite;
  }
  @keyframes spin { from { transform: rotate(-4deg); } to { transform: rotate(4deg); } }
  .contact-content { position: relative; z-index: 1; }
  .btn-lg { font-size: 1.125rem; padding: 1rem 2rem; }
  .contact-fineprint { font-size: 0.85rem; color: var(--color-fg-muted); font-style: italic; }

  .contact-grid { display: grid; gap: 1.5rem; grid-template-columns: 1fr; max-width: 56rem; margin: 4rem auto 0; }
  @media (min-width: 800px) { .contact-grid { grid-template-columns: repeat(3, 1fr); } }
  .contact-block { padding: 1.75rem; background: var(--color-cream); border: 1px solid var(--color-border); border-radius: var(--radius-xl); transition: transform 0.3s var(--ease-out-expo); }
  .contact-block:hover { transform: translateY(-2px); }
  .contact-block .eyebrow { font-size: 0.7rem; }
  .contact-block .btn { background: transparent; }

  .contact-tips { padding: 2rem; }
  .tips-list { list-style: none; padding: 0; display: flex; flex-direction: column; gap: 1rem; }
  .tips-list li { display: flex; gap: 1rem; align-items: flex-start; padding: 1rem 1.25rem; background: var(--color-cream); border: 1px solid var(--color-border); border-radius: 12px; font-size: 0.95rem; }
  .tips-list li > div { display: flex; flex-direction: column; gap: 0.2rem; }
  .tip-num { flex-shrink: 0; width: 28px; height: 28px; border-radius: 999px; background: var(--color-bark); color: var(--color-cream); display: inline-flex; align-items: center; justify-content: center; font-weight: 600; font-size: 0.85rem; margin-top: 0.1rem; }
</style>

<script>
  // Pre-fill mailto subject and body when arriving from /cennik?plan=Stable etc.
  document.addEventListener('astro:page-load', () => {
    const link = document.getElementById('mailto-link') as HTMLAnchorElement | null;
    if (!link) return;

    const params = new URLSearchParams(window.location.search);
    const plan = params.get('plan');
    const subject = plan ? `Hovera — question about ${plan} plan` : 'Hovera — inquiry';

    let body = '';
    if (plan) {
      body = [
        'Hi,',
        '',
        `I'd like to know more about the ${plan} plan.`,
        '',
        'Quick info about my stable:',
        '- Type (school / boarding / sport / breeding):',
        '- Number of horses:',
        '- Number of clients:',
        '',
        'Best regards',
      ].join('\n');
    } else {
      body = [
        'Hi,',
        '',
        "I'm writing with a question about Hovera.",
        '',
        'Quick info about my stable:',
        '- Type:',
        '- Number of horses:',
        '',
        'Best regards',
      ].join('\n');
    }

    const params2 = new URLSearchParams();
    params2.set('subject', subject);
    params2.set('body', body);
    link.href = `mailto:hello@hovera.app?${params2.toString()}`;
  });
</script>

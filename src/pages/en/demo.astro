---
import Base from '../../layouts/Base.astro';
import PageHero from '../../components/PageHero.astro';
import InteractiveProductTour from '../../components/InteractiveProductTour.astro';
import FinalCTA from '../../components/FinalCTA.astro';
import { localizePath } from '../../i18n/utils';
const locale = 'en' as const;
const lp = (p: string) => localizePath(p, locale);
---

<Base title="Demo — Hovera" description="See Hovera in action. Interactive product tour or 1-on-1 call with our team.">
  <PageHero
    eyebrow="Demo"
    title="See Hovera in action"
    subtitle="9 scenes showing a typical day at the stable — from morning to the evening report. Click whenever, or let it play."
  />

  <section class="container-x pb-12">
    <div data-reveal>
      <InteractiveProductTour locale={locale} />
    </div>
  </section>

  <section class="container-x py-16">
    <div class="grid gap-6 md:grid-cols-2 max-w-5xl mx-auto">
      <article class="demo-card" data-reveal>
        <div class="demo-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 5h18v14H3z" stroke-linejoin="round"/><path d="M3 5l9 7 9-7" stroke-linejoin="round"/></svg></div>
        <h3 class="display-3 mt-4">Live demo for your stable</h3>
        <p class="muted mt-3">30-minute online meeting. We show Hovera in the context of your stable: school, livery, sport or breeding.</p>
        <ul class="demo-list mt-6">
          <li>Quick interview about your stable</li>
          <li>Demo for specific use cases</li>
          <li>Live questions</li>
          <li>Migration plan from your current tool</li>
          <li>Plan recommendation</li>
        </ul>
        <a href={lp('/kontakt')} class="btn btn-primary mt-6">Book a demo</a>
      </article>

      <article class="demo-card" data-reveal>
        <div class="demo-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="4" width="20" height="14" rx="2"/><path d="M10 9l5 3-5 3V9z" fill="currentColor"/></svg></div>
        <h3 class="display-3 mt-4">Product video (coming soon)</h3>
        <p class="muted mt-3">5-minute screen recording of the real app with voice-over. No login, no form. Coming once the app is ready for public preview.</p>
        <ul class="demo-list mt-6">
          <li>New customer onboarding</li>
          <li>Setting up first horses and instructors</li>
          <li>Configuring passes</li>
          <li>Issuing the first invoice</li>
        </ul>
        <button class="btn btn-secondary mt-6" disabled>Coming soon</button>
      </article>
    </div>
  </section>

  <FinalCTA locale={locale} />
</Base>

<style>
  .demo-card { padding: 2.5rem; background: var(--color-cream); border: 1px solid var(--color-border); border-radius: var(--radius-2xl); transition: all 0.4s var(--ease-out-expo); }
  .demo-card:hover { transform: translateY(-2px); box-shadow: var(--shadow-warm); }
  .demo-icon { width: 56px; height: 56px; border-radius: 14px; background: var(--color-sand-light); color: var(--color-bark); display: inline-flex; align-items: center; justify-content: center; }
  .demo-icon svg { width: 28px; height: 28px; }
  .demo-list { list-style: none; padding: 0; display: flex; flex-direction: column; gap: 0.4rem; font-size: 0.95rem; color: var(--color-fg-muted); }
  .demo-list li { padding-left: 1.5rem; position: relative; }
  .demo-list li::before { content: "→"; position: absolute; left: 0; color: var(--color-ochre); }
</style>

---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import PageHero from '../../components/PageHero.astro';
import { localizePath } from '../../i18n/utils';

const posts = (await getCollection('post', (e) => e.data.locale === 'pl'))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

const locale = 'pl' as const;
const lp = (p: string) => localizePath(p, locale);
---

<Base title="Blog — Hovera" description="Pisma o zarządzaniu stajnią. Operacje, finanse, KSeF, narzędzia. Krótko, konkretnie, bez korpo-mowy.">
  <PageHero eyebrow="Blog" title="Krótko o tym, jak prowadzić stajnię" subtitle="Operacje, finanse, KSeF, narzędzia. Bez teoretyzowania, bez 'rewolucjonizujemy'. Konkret z naszej praktyki i naszych klientów." />

  <section class="container-x py-16">
    <div class="grid gap-6 max-w-3xl mx-auto">
      {posts.map((p) => (
        <a href={lp(`/blog/${p.data.slug}`)} class="post-card" data-reveal>
          <div class="post-meta">
            <time datetime={p.data.date}>{new Date(p.data.date).toLocaleDateString('pl-PL', { day: 'numeric', month: 'long', year: 'numeric' })}</time>
            {p.data.tags && (<span class="post-tags">
              {p.data.tags.map((t: string) => <span class="post-tag">{t}</span>)}
            </span>)}
          </div>
          <h2 class="post-title mt-3">{p.data.title}</h2>
          <p class="muted mt-2">{p.data.description}</p>
          <span class="post-read">Czytaj →</span>
        </a>
      ))}
    </div>
  </section>
</Base>

<style>
  .post-card {
    display: block;
    padding: 2rem;
    background: var(--color-cream);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    transition: all 0.4s var(--ease-out-expo);
  }
  .post-card:hover { transform: translateY(-2px); box-shadow: var(--shadow-warm); border-color: var(--color-bark-300); }
  .post-meta { display: flex; gap: 0.75rem; align-items: center; flex-wrap: wrap; font-size: 0.85rem; color: var(--color-fg-muted); }
  .post-tags { display: inline-flex; gap: 0.4rem; }
  .post-tag { font-size: 11px; padding: 2px 8px; background: var(--color-sand-light); border-radius: 999px; }
  .post-title { font-size: 1.5rem; line-height: 1.2; letter-spacing: -0.025em; font-weight: 500; }
  .post-read { display: inline-block; margin-top: 1rem; font-weight: 500; color: var(--color-ochre-dark); font-size: 0.9rem; }
</style>

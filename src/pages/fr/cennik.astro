---
import Base from '../../layouts/Base.astro';
import PageHero from '../../components/PageHero.astro';
import PricingTable from '../../components/PricingTable.astro';
import FinalCTA from '../../components/FinalCTA.astro';

const locale = 'fr' as const;
---

<Base
  title="Tarifs — Hovera"
  description="Tarifs transparents. Choisissez un plan adapté à votre écurie. Free, Solo, Stable, Pro et Enterprise. Garantie satisfait ou remboursé 30 jours."
>
  <PageHero
    eyebrow="Tarifs"
    title="Choisissez un plan adapté à votre écurie"
    subtitle="Transparence totale. Sans frais cachés. Facturation électronique incluse. Garantie satisfait ou remboursé 30 jours."
  />
  <PricingTable locale={locale} />
  <FinalCTA locale={locale} />
</Base>

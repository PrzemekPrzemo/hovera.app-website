---
import Base from '../../layouts/Base.astro';
import PageHero from '../../components/PageHero.astro';
import HorseshoeMark from '../../components/HorseshoeMark.astro';
const locale = 'fr' as const;

const email = 'hello@hovera.app';
const phone = '+48 791 301 019';
const phoneRaw = '+48791301019';
---

<Base
  title="Contact — Hovera"
  description="Le plus rapide est de nous écrire un e-mail. Nous répondons en 24h, à chaque message, personnellement."
>
  <PageHero
    eyebrow="Contact"
    title="Écrivez-nous. Nous répondrons."
    subtitle="Pas de formulaires à vingt champs. Pas de chatbots. Pas de tunnels de vente. Écrivez simplement — nous répondons en 24h, personnellement."
  />

  <section class="container-x pb-12">
    <div class="contact-card" data-reveal>
      <div class="contact-mark" aria-hidden="true">
        <HorseshoeMark class="h-full w-full text-[var(--color-ochre)]" />
      </div>

      <div class="contact-content">
        <h2 class="display-3 text-balance">Le mieux : l'e-mail</h2>
        <p class="muted mt-4 text-lg leading-relaxed">
          Chaque message est lu par un humain de notre équipe. En semaine, nous répondons généralement en 4 à 6 heures. Le week-end en 24h. Aucune automatisation.
        </p>

        <a href={`mailto:${email}`} class="btn btn-primary btn-lg mt-8 magnetic" id="mailto-link">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
            <path d="M3 8l9 6 9-6M5 6h14a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2z" stroke-linejoin="round"/>
          </svg>
          {email}
        </a>

        <p class="contact-fineprint mt-5">
          Il suffit d'écrire : « Bonjour, je gère une écurie de X chevaux, j'ai une question sur Y » — nous reviendrons avec du concret.
        </p>
      </div>
    </div>

    <div class="contact-grid mt-16" data-reveal>
      <div class="contact-block">
        <span class="eyebrow">📞 Préférez appeler ?</span>
        <h3 class="text-2xl font-medium mt-2">{phone}</h3>
        <p class="muted text-sm mt-2">Lun–Ven : 8h–18h CET<br/>Sam : 10h–14h CET</p>
        <a href={`tel:${phoneRaw}`} class="btn btn-secondary mt-4 text-sm">Nous appeler</a>
      </div>

      <div class="contact-block">
        <span class="eyebrow">📍 Adresse</span>
        <h3 class="text-lg font-medium mt-2">Sendormeco Holding sp. z o.o.</h3>
        <p class="muted text-sm mt-2">ul. Złota 75a/7<br/>00-819 Varsovie, Pologne<br/>N° TVA : PL5252866457</p>
      </div>

      <div class="contact-block">
        <span class="eyebrow">⏱️ Délai de réponse</span>
        <h3 class="text-lg font-medium mt-2">En moyenne 4-6h</h3>
        <p class="muted text-sm mt-2">Pendant les heures de bureau. Sinon sous 24h.<br/>Chaque mail est lu par un humain.</p>
      </div>
    </div>
  </section>
</Base>

<style>
  .contact-card { position: relative; max-width: 48rem; margin: 0 auto; padding: 3rem 3rem; background: linear-gradient(180deg, var(--color-cream) 0%, var(--color-sand-light) 100%); border: 1px solid var(--color-border); border-radius: var(--radius-2xl); box-shadow: var(--shadow-warm); overflow: hidden; }
  @media (max-width: 600px) { .contact-card { padding: 2rem 1.5rem; } }
  .contact-mark { position: absolute; width: 22rem; height: 22rem; top: -8rem; right: -8rem; opacity: 0.18; pointer-events: none; animation: spin 30s linear infinite; }
  @keyframes spin { from { transform: rotate(-4deg); } to { transform: rotate(4deg); } }
  .contact-content { position: relative; z-index: 1; }
  .btn-lg { font-size: 1.125rem; padding: 1rem 2rem; }
  .contact-fineprint { font-size: 0.85rem; color: var(--color-fg-muted); font-style: italic; }
  .contact-grid { display: grid; gap: 1.5rem; grid-template-columns: 1fr; max-width: 56rem; margin: 4rem auto 0; }
  @media (min-width: 800px) { .contact-grid { grid-template-columns: repeat(3, 1fr); } }
  .contact-block { padding: 1.75rem; background: var(--color-cream); border: 1px solid var(--color-border); border-radius: var(--radius-xl); transition: transform 0.3s var(--ease-out-expo); }
  .contact-block:hover { transform: translateY(-2px); }
  .contact-block .eyebrow { font-size: 0.7rem; }
  .contact-block .btn { background: transparent; }
</style>

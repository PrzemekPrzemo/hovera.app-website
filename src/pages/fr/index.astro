---
import Base from '../../layouts/Base.astro';
import Hero from '../../components/Hero.astro';
import ProductTour from '../../components/ProductTour.astro';
import UseCases from '../../components/UseCases.astro';
import Differentiators from '../../components/Differentiators.astro';
import PricingTeaser from '../../components/PricingTeaser.astro';
import TechBar from '../../components/TechBar.astro';
import FinalCTA from '../../components/FinalCTA.astro';

const locale = 'fr' as const;
---

